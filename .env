# This file is the base environment configuration.
# Override values in .env.local (not committed to git).

APP_ENV=dev
APP_SECRET=change_me

DATABASE_URL="mysql://${MYSQLUSER:-root}:${MYSQLPASSWORD:-password}@${MYSQLHOST:-127.0.0.1}:${MYSQLPORT:-3306}/${MYSQLDATABASE:-naccessories}?serverVersion=8.0.32&charset=utf8mb4"

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

MAILER_DSN=smtp://localhost

JWT_PASSPHRASE=change_me
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

DEFAULT_URI=http://localhost
