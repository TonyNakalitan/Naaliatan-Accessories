APP_ENV=prod
APP_SECRET=YOUR_APP_SECRET_HERE
DATABASE_URL="mysql://${MYSQLUSER}:${MYSQLPASSWORD}@${MYSQLHOST}:${MYSQLPORT}/${MYSQLDATABASE}?serverVersion=8.0&charset=utf8mb4"
CORS_ALLOW_ORIGIN='^https?://.*\.up\.railway\.app$'
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
MAILER_DSN=smtp://user:password@smtp-relay.brevo.com:587
MAIL_FROM_ADDRESS=noreply@example.com
JWT_PASSPHRASE=YOUR_JWT_PASSPHRASE_HERE
