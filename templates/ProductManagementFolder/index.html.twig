{% extends 'base.html.twig' %}

{% block title %}Product Management | Naaliatan{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('ProductManagementFolder/index.css?v=' ~ random()) }}">
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css">
{% endblock %}

{% block body %}
    <main class="content-area">
        <header class="top-nav">
            <div class="search-global">
                <i class="fas fa-search"></i>
                <input type="text" id="globalSearch" placeholder="Search products...">
            </div>
            <div class="user-widget">
                <button class="icon-btn"><i class="fas fa-bell"></i></button>
                <div class="avatar">
                    {% if app.user.profilePicture %}
                        <img src="{{ asset('images/profiles/' ~ app.user.profilePicture) }}" alt="{{ app.user.displayName ?: app.user.username }}">
                    {% else %}
                        {{ (app.user.displayName ?: app.user.username)|default('A')|slice(0,1)|upper }}
                    {% endif %}
                </div>
                <div class="user-info">
                    <p class="user-name">{{ app.user.displayName ?: app.user.username }}</p>
                    <p class="user-role">{{ is_granted('ROLE_ADMIN') ? 'Admin' : 'Staff' }}</p>
                </div>
            </div>
        </header>

        <div class="page-container">
            <div class="page-intro">
                <div>
                    <h1 class="page-title">Product Management</h1>
                    <p class="page-subtitle">Manage your hero-themed merchandise and product catalog</p>
                </div>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}

            <div class="stats-grid">
                <div class="stat-card stat-card-blue">
                    <div class="stat-icon">
                        <i class="fas fa-box"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Total Products</h3>
                        <p class="value">{{ products|length }}</p>
                        <span class="stat-badge">Catalog</span>
                    </div>
                </div>

                <div class="stat-card stat-card-purple">
                    <div class="stat-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="stat-info">
                        <h3>In Stock</h3>
                        <p class="value">{{ products|filter(p => p.stockQuantity > 0)|length }}</p>
                        <span class="stat-badge">Available</span>
                    </div>
                </div>

                <div class="stat-card stat-card-emerald">
                    <div class="stat-icon">
                        <i class="fas fa-coins"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Total Value</h3>
                        <p class="value">₱{{ products|reduce((carry, p) => carry + (p.price * p.stockQuantity), 0)|number_format(0, '.', ',') }}</p>
                        <span class="stat-badge">Inventory</span>
                    </div>
                </div>

                <div class="stat-card stat-card-amber">
                    <div class="stat-icon">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Out of Stock</h3>
                        <p class="value">{{ products|filter(p => p.stockQuantity == 0)|length }}</p>
                        <span class="stat-badge">Alert</span>
                    </div>
                </div>
            </div>

            <div class="data-panel">
                <div class="panel-header">
                    <div class="panel-title-wrapper">
                        <div class="panel-icon">
                            <i class="fas fa-box-open"></i>
                        </div>
                        <span class="panel-title">All Products</span>
                    </div>
                    <div class="badge-group">
                        {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ role_path('product_management_new') }}" class="btn-add-product">
                            <i class="fas fa-plus"></i>
                            Add New Product
                        </a>
                        {% endif %}
                        <select id="statusFilter" class="filter-select">
                            <option value="all">All Status</option>
                            <option value="in stock">In Stock</option>
                            <option value="out of stock">Out of Stock</option>
                        </select>
                    </div>
                </div>

                <div class="table-container">
                    <table id="myTable" class="product-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Product</th>
                                <th>Character</th>
                                <th>Price</th>
                                <th>Stock</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th class="action-column">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="productTableBody">
                            {% for product in products %}
                                <tr>
                                    <td>{{ product.id }}</td>
                                    <td>
                                        <div class="product-cell">
                                            <div class="product-image">
                                                {% if product.image %}
                                                    <img src="{{ asset('images/products/' ~ product.image) }}" alt="{{ product.name }}">
                                                {% else %}
                                                    <i class="fas fa-box"></i>
                                                {% endif %}
                                            </div>
                                            <div class="product-details">
                                                <span class="product-name">{{ product.name }}</span>
                                                <span class="product-code">{{ product.productCode }}</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        {% if product.character %}
                                            <span class="character-badge">
                                                <i class="fas fa-user-ninja"></i>
                                                {{ product.character.name }}
                                            </span>
                                        {% else %}
                                            <span class="character-badge character-none">
                                                <i class="fas fa-minus-circle"></i>
                                                None
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td><strong class="price-text">₱{{ product.price|number_format(2, '.', ',') }}</strong></td>
                                    <td><span class="stock-qty">{{ product.stockQuantity ?? 0 }} units</span></td>
                                    <td>
                                        {% if product.stockQuantity > 0 %}
                                            <span class="status-badge status-in-stock">
                                                <i class="fas fa-circle"></i>
                                                In Stock
                                            </span>
                                        {% else %}
                                            <span class="status-badge status-out-stock">
                                                <i class="fas fa-circle"></i>
                                                Out of Stock
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td>{{ product.createdAt|date('M d, Y') }}</td>
                                    <td>
                                        <div class="action-buttons">
                                            <a href="{{ role_path('product_management_show', {'id': product.id}) }}" class="btn-action btn-view" title="View">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="{{ role_path('product_management_edit', {'id': product.id}) }}" class="btn-action btn-edit" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            {% if isAdmin %}
                                                <form method="post" action="{{ role_path('product_management_delete', {'id': product.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this product?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                                    <button type="submit" class="btn-action btn-delete" title="Delete">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="8" class="empty-state">
                                        <i class="fas fa-box-open"></i>
                                        <p>No products found</p>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.3.7/js/dataTables.min.js"></script>
    <script src="{{ asset('ProductManagementFolder/index.js') }}"></script>
{% endblock %}
