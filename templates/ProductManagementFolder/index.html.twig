{% extends 'base.html.twig' %}

{% block title %}Product Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('ProductManagementFolder/index.css') }}?v={{ random() }}">
{% endblock %}

{% block body %}
<div id="product-app-wrapper" class="min-h-screen">

    <!-- App Wrapper -->
    <div id="app" class="relative w-full h-screen glass-container overflow-x-auto flex flex-col">
        
        <!-- Header -->
        <header class="relative z-50 flex items-center justify-between px-10 py-8">
            <div class="flex items-center gap-3">
                <button class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/80 hover:bg-white border border-gray-200 hover:shadow-md transition-all text-gray-700 hover:text-gray-900" id="sidebarToggle" title="Toggle Sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="text-3xl font-bold tracking-tighter text-gray-800">
                    Product Management
                </span>
            </div>

            <!-- Search bar -->
            <div class="hidden md:flex items-center bg-gray-100/50 rounded-full px-5 py-2 w-72 border border-gray-200">
                <i class="fa fa-search text-gray-400 mr-3"></i>
                <input type="text" id="searchInput" placeholder="Search products..." class="bg-transparent outline-none text-sm w-full">
            </div>

            <div class="flex items-center gap-6">
                {% if isAdmin %}
                    <a href="{{ path('app_admin_product_management_new') }}" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors font-medium">
                        <i class="fa fa-plus mr-2"></i>Add Product
                    </a>
                {% endif %}
                <a href="{{ isAdmin ? path('app_admin_profile_edit') : path('app_staff_profile_edit') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors">
                    {% if app.user.profilePicture %}
                        <img src="{{ app.user.profilePicture|image_url('images/profiles') }}" alt="Profile" class="w-10 h-10 rounded-full object-cover border-2 border-white shadow-md">
                    {% else %}
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 text-white font-bold text-sm">
                            {% set displayText = app.user.displayName ?: app.user.username %}
                            {% set words = displayText|split(' ') %}
                            {% if words|length > 1 %}
                                {{ words[0]|slice(0, 1)|upper }}{{ words[1]|slice(0, 1)|upper }}
                            {% else %}
                                {{ displayText|slice(0, 2)|upper }}
                            {% endif %}
                        </div>
                    {% endif %}
                    <div class="flex flex-col items-start">
                        <span class="font-semibold text-gray-800 text-sm">{{ app.user.displayName ?: app.user.username }}</span>
                        <span class="text-xs text-gray-500">{{ isAdmin ? 'Admin' : 'Staff' }}</span>
                    </div>
                </a>
            </div>
        </header>

        <!-- Viewport -->
        <main class="relative flex-1 overflow-x-auto">
            
            <!-- TABLE VIEW -->
            <div id="gridView" class="grid-view absolute inset-0 flex flex-col px-12 py-8 transition-all duration-500">
                <div class="flex-1 overflow-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Product</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Code</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Price</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Stock</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Character</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Status</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="productTableBody">
                            <!-- Table rows injected by JS -->
                        </tbody>
                    </table>
                </div>

                <!-- Footer Stats -->
                <div class="flex items-center gap-6 pt-4 pb-2 text-sm font-medium text-gray-500">
                    <span>Total Products: <span id="totalCount">{{ totalProducts }}</span></span>
                    <span>Low Stock: <span class="text-amber-600 font-bold">{{ products|filter(p => p.stockQuantity > 0 and p.stockQuantity < 10)|length }}</span></span>
                    <span>In Stock: <span class="text-emerald-600 font-bold">{{ products|filter(p => p.stockQuantity > 0)|length }}</span></span>
                </div>
            </div>

            <!-- DETAIL / HERO VIEW -->
            <div id="heroView" class="hero-view absolute inset-0 z-40 bg-white">
                <div id="heroBg" class="absolute inset-0 w-1/2 rounded-r-[80px] transition-colors duration-700"></div>
                
                <button onclick="closeHero()" class="absolute top-8 right-10 z-50 flex items-center gap-2 font-bold text-gray-800 hover:scale-105 transition-transform">
                    <i class="fa fa-times text-red-500"></i> Close
                </button>

                <div class="relative z-10 h-full flex items-center px-16">
                    <!-- Left Side: Large Image with Frame -->
                    <div class="w-1/2 flex justify-center items-center">
                        <div class="hero-image-frame">
                            <img id="heroImage" src="" alt="" class="hero-image">
                        </div>
                    </div>

                    <!-- Right Side: Content -->
                    <div class="w-1/2 pl-12 pr-8">
                        <div class="hero-content-wrapper">
                            <h2 id="heroName" class="hero-title slide-in" style="animation-delay: 0.1s"></h2>
                            
                            <div class="hero-meta-section slide-in" style="animation-delay: 0.2s">
                                <div class="meta-item">
                                    <i class="fa fa-barcode text-blue-500"></i>
                                    <span class="meta-label">Code:</span>
                                    <span id="heroCode" class="meta-value"></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fa fa-tag text-green-500"></i>
                                    <span class="meta-label">Price:</span>
                                    <span id="heroPrice" class="meta-value"></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fa fa-boxes text-purple-500"></i>
                                    <span class="meta-label">Stock:</span>
                                    <span id="heroStock" class="stock-badge"></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fa fa-user-ninja text-emerald-500"></i>
                                    <span class="meta-label">Character:</span>
                                    <span id="heroCharacter" class="meta-value"></span>
                                </div>
                            </div>
                            
                            <div class="hero-description-section slide-in" style="animation-delay: 0.3s">
                                <h3 class="description-title">Description</h3>
                                <p id="heroDesc" class="description-text"></p>
                            </div>

                            <div class="hero-actions slide-in" style="animation-delay: 0.4s">
                                <a id="heroViewBtn" href="#" class="action-btn action-btn-view">
                                    <i class="fa fa-eye"></i>
                                    <span>View Product</span>
                                </a>
                                <a id="heroEditBtn" href="#" class="action-btn action-btn-primary">
                                    <i class="fa fa-edit"></i>
                                    <span>Edit Product</span>
                                </a>
                                {% if isAdmin %}
                                    <button id="heroDeleteBtn" onclick="deleteProduct()" class="action-btn action-btn-danger">
                                        <i class="fa fa-trash"></i>
                                        <span>Delete</span>
                                    </button>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Delete Form Template (hidden) -->
    <form id="deleteForm" method="POST" style="display: none;">
        <input type="hidden" name="_token" value="">
    </form>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
    <script>
        // Load products from Symfony
        const allProductsData = [
            {% for product in products %}
            {
                id: {{ product.id }},
                name: {{ product.name|json_encode|raw }},
                productCode: {{ product.productCode|json_encode|raw }},
                price: {{ product.price }},
                stockQuantity: {{ product.stockQuantity ?? 0 }},
                image: {{ product.image|json_encode|raw }},
                description: {{ product.description|json_encode|raw }},
                characterName: {{ product.character ? product.character.name|json_encode|raw : 'null' }},
                characterColor: {{ product.character ? product.character.colorCode|json_encode|raw : '"#6c757d"' }}
            }{% if not loop.last %},{% endif %}
            {% endfor %}
        ];
        
        const isAdmin = {{ isAdmin ? 'true' : 'false' }};
        const isStaff = {{ isStaff ? 'true' : 'false' }};
        const baseUrl = '{{ app.request.schemeAndHttpHost }}';
        const imageBasePath = '{{ asset('images/products/') }}';
        
        console.log('Total products loaded:', allProductsData.length);
        
        // Transform products to match the expected format
        let products = allProductsData.map(prod => ({
            id: prod.id,
            name: prod.name || 'Unknown Product',
            productCode: prod.productCode || 'N/A',
            price: prod.price || 0,
            stockQuantity: prod.stockQuantity || 0,
            characterName: prod.characterName || 'None',
            colorCode: prod.characterColor || '#6c757d',
            image: prod.image ? imageBasePath + prod.image : 'https://via.placeholder.com/400x600?text=' + encodeURIComponent(prod.name || 'Product'),
            description: prod.description || 'No description available.'
        }));
        
        let filteredProducts = [...products];
        
        console.log('Processed products:', products);

        // Helper function to lighten/darken colors
        function adjustColor(color, amount) {
            const num = parseInt(color.replace("#",""), 16);
            const r = Math.min(255, Math.max(0, (num >> 16) + amount));
            const g = Math.min(255, Math.max(0, ((num >> 8) & 0x00FF) + amount));
            const b = Math.min(255, Math.max(0, (num & 0x0000FF) + amount));
            return "#" + ((r << 16) | (g << 8) | b).toString(16).padStart(6, '0');
        }

        function getStockStatus(quantity) {
            if (quantity === 0) return { text: 'Out of Stock', class: 'stock-critical' };
            if (quantity < 10) return { text: 'Low Stock', class: 'stock-low' };
            return { text: 'In Stock', class: 'stock-good' };
        }

        function renderTable() {
            const tbody = document.getElementById('productTableBody');
            tbody.innerHTML = '';
            
            if (!filteredProducts || filteredProducts.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center text-gray-500 text-xl py-20">No products found.' + (isAdmin ? ' <a href="{{ path('app_admin_product_management_new') }}" class="text-blue-600 hover:underline">Add one now!</a>' : '') + '</td></tr>';
                return;
            }

            filteredProducts.forEach((prod) => {
                const stockStatus = getStockStatus(prod.stockQuantity);
                const row = document.createElement('tr');
                
                row.innerHTML = `
                    <td>
                        <div class="product-info">
                            <img src="${prod.image}" alt="${prod.name}" class="product-table-image" onerror="this.src='https://via.placeholder.com/100x100?text=${encodeURIComponent(prod.name)}'">
                            <div>
                                <div class="product-name">${prod.name}</div>
                                <div class="product-code">${prod.characterName}</div>
                            </div>
                        </div>
                    </td>
                    <td class="text-gray-700">${prod.productCode}</td>
                    <td class="text-gray-700">₱${prod.price.toLocaleString('en-PH', {minimumFractionDigits: 2})}</td>
                    <td class="text-gray-700">${prod.stockQuantity}</td>
                    <td class="text-gray-700">${prod.characterName}</td>
                    <td><span class="table-stock-badge ${stockStatus.class}">${stockStatus.text}</span></td>
                    <td>
                        <div class="table-actions">
                            <a href="${isAdmin ? baseUrl + '/admin/products/' + prod.id : baseUrl + '/staff/products/' + prod.id}" class="table-action-btn table-action-view" title="View">
                                <i class="fa fa-eye"></i>
                            </a>
                            <a href="${isAdmin ? baseUrl + '/admin/products/' + prod.id + '/edit' : baseUrl + '/staff/products/' + prod.id + '/edit'}" class="table-action-btn table-action-edit" title="Edit">
                                <i class="fa fa-edit"></i>
                            </a>
                            ${isAdmin ? `
                            <button onclick="deleteProduct(${prod.id})" class="table-action-btn table-action-delete" title="Delete">
                                <i class="fa fa-trash"></i>
                            </button>
                            ` : ''}
                        </div>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }
        
        // Search functionality
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.addEventListener('input', function(e) {
                const searchTerm = e.target.value.toLowerCase();
                filteredProducts = products.filter(prod => 
                    prod.name.toLowerCase().includes(searchTerm) ||
                    prod.productCode.toLowerCase().includes(searchTerm) ||
                    prod.characterName.toLowerCase().includes(searchTerm)
                );
                const totalCountEl = document.getElementById('totalCount');
                if (totalCountEl) {
                    totalCountEl.textContent = filteredProducts.length;
                }
                renderTable();
            });
        }

        let currentProduct = null;
        
        function openHero(prod) {
            currentProduct = prod;
            const app = document.getElementById('app');
            const heroBg = document.getElementById('heroBg');
            const heroImage = document.getElementById('heroImage');
            const heroName = document.getElementById('heroName');
            const heroCode = document.getElementById('heroCode');
            const heroPrice = document.getElementById('heroPrice');
            const heroStock = document.getElementById('heroStock');
            const heroCharacter = document.getElementById('heroCharacter');
            const heroDesc = document.getElementById('heroDesc');

            // Set content
            const colorLight = adjustColor(prod.colorCode, 30);
            const colorDark = adjustColor(prod.colorCode, -30);
            heroBg.style.background = `linear-gradient(180deg, ${colorLight} 0%, ${colorDark} 100%)`;
            
            heroImage.src = prod.image;
            heroImage.onerror = function() {
                this.src = 'https://via.placeholder.com/400x600?text=' + encodeURIComponent(prod.name);
            };
            
            heroName.innerText = prod.name;
            heroCode.innerText = prod.productCode;
            heroPrice.innerText = '₱' + prod.price.toLocaleString('en-PH', {minimumFractionDigits: 2});
            
            const stockStatus = getStockStatus(prod.stockQuantity);
            heroStock.innerText = `${prod.stockQuantity} units`;
            heroStock.className = `stock-badge ${stockStatus.class}`;
            
            heroCharacter.innerText = prod.characterName;
            heroDesc.innerText = prod.description;
            
            // Update action buttons
            const viewBtn = document.getElementById('heroViewBtn');
            if (viewBtn) {
                const viewRoute = isAdmin ?
                    `${baseUrl}/admin/products/${prod.id}` :
                    `${baseUrl}/staff/products/${prod.id}`;
                viewBtn.href = viewRoute;
            }

            const editBtn = document.getElementById('heroEditBtn');
            if (editBtn) {
                const editRoute = isAdmin ? 
                    `${baseUrl}/admin/products/${prod.id}/edit` : 
                    `${baseUrl}/staff/products/${prod.id}/edit`;
                editBtn.href = editRoute;
            }

            // Trigger animation
            app.classList.add('hero-active');
            
            // Reset text animations
            const animatedElements = document.querySelectorAll('.slide-in');
            animatedElements.forEach(el => {
                el.style.animation = 'none';
                el.offsetHeight; // trigger reflow
                el.style.animation = null;
            });
        }
        
        function deleteProduct(productId) {
            const product = products.find(p => p.id === productId);
            if (!product || !isAdmin) return;
            
            if (confirm(`Are you sure you want to delete "${product.name}"?`)) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = `${baseUrl}/admin/products/${product.id}`;
                
                const csrfToken = document.createElement('input');
                csrfToken.type = 'hidden';
                csrfToken.name = '_token';
                csrfToken.value = '{{ csrf_token("delete_product") }}';
                
                form.appendChild(csrfToken);
                document.body.appendChild(form);
                form.submit();
            }
        }

        function closeHero() {
            document.getElementById('app').classList.remove('hero-active');
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM loaded, rendering table...');
            renderTable();
            
            // Sidebar toggle functionality
            const sidebarToggle = document.getElementById('sidebarToggle');
            const sidebar = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');
            
            if (sidebarToggle && sidebar && sidebarOverlay) {
                sidebarToggle.addEventListener('click', function() {
                    sidebar.classList.toggle('active');
                    sidebarOverlay.classList.toggle('active');
                });
                
                sidebarOverlay.addEventListener('click', function() {
                    sidebar.classList.remove('active');
                    sidebarOverlay.classList.remove('active');
                });
            }
        });
    </script>
{% endblock %}
