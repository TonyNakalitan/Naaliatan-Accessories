{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('DashboardFolder/admin_dashboard.css') }}?v={{ random() }}">
{% endblock %}

{% block body %}
<div id="dashboard-app-wrapper">

    <!-- Sidebar Toggle -->
    <button class="sidebar-toggle-btn" id="sidebarToggle" title="Toggle Sidebar">
        <i class="fas fa-bars"></i>
    </button>

    <div class="dashboard-layout">

        <!-- ===== HEADER ===== -->
        <header class="dash-header">
            <div class="dash-header-left">
                <h1 class="dash-title">Admin Dashboard</h1>
                <p class="dash-subtitle">Welcome back, {{ app.user.displayName ?: app.user.username }}</p>
            </div>

            <!-- Search -->
            <div class="dash-search">
                <i class="fas fa-search"></i>
                <input type="text" id="searchInput" placeholder="Search anything...">
            </div>

            <!-- Profile -->
            <a href="{{ path('app_admin_profile_edit') }}" class="dash-profile">
                <div class="dash-profile-avatar">
                    {% if app.user.profilePicture %}
                        <img src="{{ app.user.profilePicture|image_url('images/profiles') }}" alt="Profile">
                    {% else %}
                        <div class="dash-profile-initials">
                            {% set displayText = app.user.displayName ?: app.user.username %}
                            {% set words = displayText|split(' ') %}
                            {% if words|length > 1 %}
                                {{ words[0]|slice(0,1)|upper }}{{ words[1]|slice(0,1)|upper }}
                            {% else %}
                                {{ displayText|slice(0,2)|upper }}
                            {% endif %}
                        </div>
                    {% endif %}
                    <span class="dash-profile-status"></span>
                </div>
                <div class="dash-profile-info">
                    <span class="dash-profile-name">{{ app.user.displayName ?: app.user.username }}</span>
                    <span class="dash-profile-role">Administrator</span>
                </div>
                <i class="fas fa-chevron-right dash-profile-arrow"></i>
            </a>
        </header>

        <!-- ===== DATA BOARD — Stat Cards ===== -->
        <section class="data-board">
            <div class="stat-card stat-blue">
                <div class="stat-card-icon"><i class="fas fa-users"></i></div>
                <div class="stat-card-body">
                    <span class="stat-card-label">Total Users</span>
                    <span class="stat-card-value">{{ stats.totalUsers }}</span>
                    <span class="stat-card-sub">{{ stats.totalStaff }} staff members</span>
                </div>
                <a href="{{ path('app_admin_user_management_index') }}" class="stat-card-link">
                    Manage <i class="fas fa-arrow-right"></i>
                </a>
            </div>

            <div class="stat-card stat-purple">
                <div class="stat-card-icon"><i class="fas fa-box-open"></i></div>
                <div class="stat-card-body">
                    <span class="stat-card-label">Total Products</span>
                    <span class="stat-card-value">{{ stats.totalProducts }}</span>
                    <span class="stat-card-sub">{{ stats.lowStockProducts }} low stock</span>
                </div>
                <a href="{{ path('app_admin_product_management_index') }}" class="stat-card-link">
                    Manage <i class="fas fa-arrow-right"></i>
                </a>
            </div>

            <div class="stat-card stat-green">
                <div class="stat-card-icon"><i class="fas fa-id-badge"></i></div>
                <div class="stat-card-body">
                    <span class="stat-card-label">Characters</span>
                    <span class="stat-card-value">{{ stats.totalCharacters }}</span>
                    <span class="stat-card-sub">
                        {{ characterStats|filter(c => c.alignment == 'Good')|first.count|default(0) }} good /
                        {{ characterStats|filter(c => c.alignment == 'Evil')|first.count|default(0) }} evil
                    </span>
                </div>
                <a href="{{ path('app_admin_character_management_index') }}" class="stat-card-link">
                    Manage <i class="fas fa-arrow-right"></i>
                </a>
            </div>

            <div class="stat-card stat-orange">
                <div class="stat-card-icon"><i class="fas fa-exclamation-triangle"></i></div>
                <div class="stat-card-body">
                    <span class="stat-card-label">Low / Out of Stock</span>
                    <span class="stat-card-value">{{ stats.lowStockProducts }}</span>
                    <span class="stat-card-sub">{{ stats.outOfStockProducts }} out of stock</span>
                </div>
                <a href="{{ path('app_admin_stock_management_index') }}" class="stat-card-link">
                    View <i class="fas fa-arrow-right"></i>
                </a>
            </div>

            <div class="stat-card stat-teal">
                <div class="stat-card-icon"><i class="fas fa-shopping-bag"></i></div>
                <div class="stat-card-body">
                    <span class="stat-card-label">Total Orders</span>
                    <span class="stat-card-value">{{ stats.totalOrders ?? '—' }}</span>
                    <span class="stat-card-sub">All time orders</span>
                </div>
                <a href="{{ path('app_admin_order_index') }}" class="stat-card-link">
                    View <i class="fas fa-arrow-right"></i>
                </a>
            </div>

            <div class="stat-card stat-rose">
                <div class="stat-card-icon"><i class="fas fa-coins"></i></div>
                <div class="stat-card-body">
                    <span class="stat-card-label">Stock Value</span>
                    <span class="stat-card-value">₱{{ stats.totalStockValue|number_format(0, '.', ',') }}</span>
                    <span class="stat-card-sub">Total inventory value</span>
                </div>
                <a href="{{ path('app_admin_stock_management_index') }}" class="stat-card-link">
                    View <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </section>

        <!-- ===== MAIN CONTENT: Chart + Table ===== -->
        <div class="dash-content">

            <!-- LEFT: Charts -->
            <div class="dash-charts">

                <!-- Bar Chart — Stock Overview -->
                <div class="chart-card">
                    <div class="chart-card-header">
                        <div>
                            <h3 class="chart-title">Stock Overview</h3>
                            <p class="chart-subtitle">Products · Low Stock · Out of Stock</p>
                        </div>
                        <span class="chart-badge">Inventory</span>
                    </div>
                    <div class="chart-wrapper">
                        <canvas id="stockBarChart"></canvas>
                    </div>
                </div>

                <!-- Donut Chart — Character Alignment -->
                <div class="chart-card chart-card-sm">
                    <div class="chart-card-header">
                        <div>
                            <h3 class="chart-title">Character Alignment</h3>
                            <p class="chart-subtitle">Good vs Evil vs Neutral</p>
                        </div>
                        <span class="chart-badge">Characters</span>
                    </div>
                    <div class="chart-wrapper chart-wrapper-donut">
                        <canvas id="alignmentDonut"></canvas>
                    </div>
                    <div class="donut-legend" id="donutLegend"></div>
                </div>

            </div>

            <!-- RIGHT: Recent Activity Table -->
            <div class="dash-table-panel">
                <div class="table-panel-header">
                    <h3 class="chart-title">Recent Stats</h3>
                    <input type="text" id="tableSearch" placeholder="Filter rows..." class="table-search-input">
                </div>

                <div class="dash-table-wrapper">
                    <table class="dash-table" id="statsTable">
                        <thead>
                            <tr>
                                <th>Metric</th>
                                <th>Value</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><i class="fas fa-users text-blue-500 mr-2"></i>Total Users</td>
                                <td><strong>{{ stats.totalUsers }}</strong></td>
                                <td><span class="dash-badge badge-blue">Active</span></td>
                                <td><a href="{{ path('app_admin_user_management_index') }}" class="table-action-link">View</a></td>
                            </tr>
                            <tr>
                                <td><i class="fas fa-user-tie text-purple-500 mr-2"></i>Staff Members</td>
                                <td><strong>{{ stats.totalStaff }}</strong></td>
                                <td><span class="dash-badge badge-purple">Team</span></td>
                                <td><a href="{{ path('app_admin_user_management_index') }}" class="table-action-link">View</a></td>
                            </tr>
                            <tr>
                                <td><i class="fas fa-box-open text-green-500 mr-2"></i>Total Products</td>
                                <td><strong>{{ stats.totalProducts }}</strong></td>
                                <td><span class="dash-badge badge-green">Catalog</span></td>
                                <td><a href="{{ path('app_admin_product_management_index') }}" class="table-action-link">View</a></td>
                            </tr>
                            <tr>
                                <td><i class="fas fa-exclamation-triangle text-yellow-500 mr-2"></i>Low Stock</td>
                                <td><strong>{{ stats.lowStockProducts }}</strong></td>
                                <td><span class="dash-badge badge-yellow">Alert</span></td>
                                <td><a href="{{ path('app_admin_stock_management_index') }}" class="table-action-link">Check</a></td>
                            </tr>
                            <tr>
                                <td><i class="fas fa-times-circle text-red-500 mr-2"></i>Out of Stock</td>
                                <td><strong>{{ stats.outOfStockProducts }}</strong></td>
                                <td><span class="dash-badge badge-red">Critical</span></td>
                                <td><a href="{{ path('app_admin_stock_management_index') }}" class="table-action-link">Fix</a></td>
                            </tr>
                            <tr>
                                <td><i class="fas fa-id-badge text-pink-500 mr-2"></i>Characters</td>
                                <td><strong>{{ stats.totalCharacters }}</strong></td>
                                <td><span class="dash-badge badge-pink">Collection</span></td>
                                <td><a href="{{ path('app_admin_character_management_index') }}" class="table-action-link">View</a></td>
                            </tr>
                            <tr>
                                <td><i class="fas fa-coins text-teal-500 mr-2"></i>Stock Value</td>
                                <td><strong>₱{{ stats.totalStockValue|number_format(0, '.', ',') }}</strong></td>
                                <td><span class="dash-badge badge-teal">Inventory</span></td>
                                <td><a href="{{ path('app_admin_stock_management_index') }}" class="table-action-link">View</a></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
    <script>
        // ---- Sidebar toggle ----
        document.addEventListener('DOMContentLoaded', function () {
            const sidebarToggle = document.getElementById('sidebarToggle');
            const sidebar       = document.getElementById('sidebar');
            const overlay       = document.getElementById('sidebarOverlay');

            if (sidebarToggle && sidebar && overlay) {
                sidebarToggle.addEventListener('click', () => {
                    sidebar.classList.toggle('active');
                    overlay.classList.toggle('active');
                });
                overlay.addEventListener('click', () => {
                    sidebar.classList.remove('active');
                    overlay.classList.remove('active');
                });
            }

            // ---- Table search ----
            const tableSearch = document.getElementById('tableSearch');
            if (tableSearch) {
                tableSearch.addEventListener('input', function () {
                    const q = this.value.toLowerCase();
                    document.querySelectorAll('#statsTable tbody tr').forEach(row => {
                        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
                    });
                });
            }

            // ---- Bar Chart ----
            const barCtx = document.getElementById('stockBarChart').getContext('2d');
            new Chart(barCtx, {
                type: 'bar',
                data: {
                    labels: ['Total Products', 'Low Stock', 'Out of Stock'],
                    datasets: [{
                        label: 'Count',
                        data: [
                            {{ stats.totalProducts }},
                            {{ stats.lowStockProducts }},
                            {{ stats.outOfStockProducts }}
                        ],
                        backgroundColor: [
                            'rgba(99, 102, 241, 0.85)',
                            'rgba(245, 158, 11, 0.85)',
                            'rgba(239, 68, 68, 0.85)'
                        ],
                        borderRadius: 10,
                        borderSkipped: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: { callbacks: { label: ctx => ' ' + ctx.parsed.y + ' items' } }
                    },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { family: 'Poppins', size: 12 } } },
                        y: { grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { font: { family: 'Poppins', size: 12 }, stepSize: 1 }, beginAtZero: true }
                    }
                }
            });

            // ---- Donut Chart ----
            const goodCount    = {{ characterStats|filter(c => c.alignment == 'Good')|first.count|default(0) }};
            const evilCount    = {{ characterStats|filter(c => c.alignment == 'Evil')|first.count|default(0) }};
            const neutralCount = {{ stats.totalCharacters }} - goodCount - evilCount;

            const donutCtx = document.getElementById('alignmentDonut').getContext('2d');
            new Chart(donutCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Good', 'Evil', 'Neutral'],
                    datasets: [{
                        data: [goodCount, evilCount, neutralCount < 0 ? 0 : neutralCount],
                        backgroundColor: ['#10b981', '#ef4444', '#6366f1'],
                        borderWidth: 3,
                        borderColor: '#fff',
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '68%',
                    plugins: {
                        legend: { display: false },
                        tooltip: { callbacks: { label: ctx => ' ' + ctx.label + ': ' + ctx.parsed } }
                    }
                }
            });

            // Custom legend
            const legend = document.getElementById('donutLegend');
            const alignLabels  = ['Good', 'Evil', 'Neutral'];
            const alignColors  = ['#10b981', '#ef4444', '#6366f1'];
            const alignCounts  = [goodCount, evilCount, neutralCount < 0 ? 0 : neutralCount];
            alignLabels.forEach((label, i) => {
                const item = document.createElement('div');
                item.className = 'donut-legend-item';
                item.innerHTML = `<span class="donut-legend-dot" style="background:${alignColors[i]}"></span><span>${label}</span><strong>${alignCounts[i]}</strong>`;
                legend.appendChild(item);
            });
        });
    </script>
{% endblock %}
