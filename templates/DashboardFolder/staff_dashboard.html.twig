{% extends 'base.html.twig' %}

{% block title %}Staff Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('DashboardFolder/staff_dashboard.css') }}?v={{ random() }}">
{% endblock %}

{% block body %}
<div id="dashboard-app-wrapper" class="min-h-screen">

    <!-- App Wrapper -->
    <div id="app" class="relative w-full h-screen glass-container overflow-x-auto flex flex-col">
        
        <!-- Header -->
        <header class="relative z-50 flex items-center justify-between px-10 py-8">
            <div class="flex items-center gap-3">
                <button class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/80 hover:bg-white border border-gray-200 hover:shadow-md transition-all text-gray-700 hover:text-gray-900" id="sidebarToggle" title="Toggle Sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="text-3xl font-bold tracking-tighter text-gray-800">
                    Staff Dashboard
                </span>
            </div>

            <!-- Search bar -->
            <div class="hidden md:flex items-center bg-gray-100/50 rounded-full px-5 py-2 w-72 border border-gray-200">
                <i class="fa fa-search text-gray-400 mr-3"></i>
                <input type="text" id="searchInput" placeholder="Search metrics..." class="bg-transparent outline-none text-sm w-full">
            </div>

            <div class="flex items-center gap-6">
                <a href="{{ path('app_staff_profile_edit') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors">
                    {% if app.user.profilePicture %}
                        <img src="{{ app.user.profilePicture|image_url('images/profiles') }}" alt="Profile" class="w-10 h-10 rounded-full object-cover border-2 border-white shadow-md">
                    {% else %}
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-br from-purple-500 to-pink-600 text-white font-bold text-sm">
                            {% set displayText = app.user.displayName ?: app.user.username %}
                            {% set words = displayText|split(' ') %}
                            {% if words|length > 1 %}
                                {{ words[0]|slice(0, 1)|upper }}{{ words[1]|slice(0, 1)|upper }}
                            {% else %}
                                {{ displayText|slice(0, 2)|upper }}
                            {% endif %}
                        </div>
                    {% endif %}
                    <div class="flex flex-col items-start">
                        <span class="font-semibold text-gray-800 text-sm">{{ app.user.displayName ?: app.user.username }}</span>
                        <span class="text-xs text-gray-500">Staff</span>
                    </div>
                </a>
            </div>
        </header>

        <!-- Viewport -->
        <main class="relative flex-1 overflow-x-auto">
            
            <!-- STAT CARDS GRID -->
            <div class="grid-view absolute inset-0 flex flex-col px-12 py-8 transition-all duration-500">
                <div class="stats-grid">
                    <div class="stat-card stat-green">
                        <div class="stat-card-icon"><i class="fas fa-box-open"></i></div>
                        <div class="stat-card-body">
                            <span class="stat-card-label">Total Products</span>
                            <span class="stat-card-value">{{ stats.totalProducts }}</span>
                            <span class="stat-card-sub">{{ stats.lowStockProducts }} low stock</span>
                        </div>
                        <a href="{{ path('app_staff_product_management_index') }}" class="stat-card-link">
                            Manage <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>

                    <div class="stat-card stat-pink">
                        <div class="stat-card-icon"><i class="fas fa-id-badge"></i></div>
                        <div class="stat-card-body">
                            <span class="stat-card-label">Total Characters</span>
                            <span class="stat-card-value">{{ stats.totalCharacters }}</span>
                            <span class="stat-card-sub">Collection active</span>
                        </div>
                        <a href="{{ path('app_staff_character_management_index') }}" class="stat-card-link">
                            Manage <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>

                    <div class="stat-card stat-blue">
                        <div class="stat-card-icon"><i class="fas fa-warehouse"></i></div>
                        <div class="stat-card-body">
                            <span class="stat-card-label">Stock Items</span>
                            <span class="stat-card-value">{{ stats.totalStockItems }}</span>
                            <span class="stat-card-sub">{{ stats.restockedToday }} restocked today</span>
                        </div>
                        <a href="{{ path('app_staff_stock_management_index') }}" class="stat-card-link">
                            View <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>

                    <div class="stat-card stat-orange">
                        <div class="stat-card-icon"><i class="fas fa-exclamation-triangle"></i></div>
                        <div class="stat-card-body">
                            <span class="stat-card-label">Low Stock</span>
                            <span class="stat-card-value">{{ stats.lowStockProducts }}</span>
                            <span class="stat-card-sub">{{ stats.outOfStockProducts }} out of stock</span>
                        </div>
                        <a href="{{ path('app_staff_stock_management_index') }}" class="stat-card-link">
                            View <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Stats Table -->
                <div class="table-panel">
                    <div class="table-panel-header">
                        <h3 class="chart-title">Staff Metrics</h3>
                        <input type="text" id="tableSearch" placeholder="Filter rows..." class="table-search-input">
                    </div>

                    <div class="dash-table-wrapper">
                        <table class="dash-table" id="statsTable">
                            <thead>
                                <tr>
                                    <th>Metric</th>
                                    <th>Value</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><i class="fas fa-box-open text-green-500 mr-2"></i>Total Products</td>
                                    <td><strong>{{ stats.totalProducts }}</strong></td>
                                    <td><span class="dash-badge badge-green">Catalog</span></td>
                                    <td><a href="{{ path('app_staff_product_management_index') }}" class="table-action-link">View</a></td>
                                </tr>
                                <tr>
                                    <td><i class="fas fa-id-badge text-pink-500 mr-2"></i>Total Characters</td>
                                    <td><strong>{{ stats.totalCharacters }}</strong></td>
                                    <td><span class="dash-badge badge-pink">Collection</span></td>
                                    <td><a href="{{ path('app_staff_character_management_index') }}" class="table-action-link">View</a></td>
                                </tr>
                                <tr>
                                    <td><i class="fas fa-warehouse text-blue-500 mr-2"></i>Stock Items</td>
                                    <td><strong>{{ stats.totalStockItems }}</strong></td>
                                    <td><span class="dash-badge badge-blue">Inventory</span></td>
                                    <td><a href="{{ path('app_staff_stock_management_index') }}" class="table-action-link">View</a></td>
                                </tr>
                                <tr>
                                    <td><i class="fas fa-exclamation-triangle text-yellow-500 mr-2"></i>Low Stock</td>
                                    <td><strong>{{ stats.lowStockProducts }}</strong></td>
                                    <td><span class="dash-badge badge-yellow">Alert</span></td>
                                    <td><a href="{{ path('app_staff_stock_management_index') }}" class="table-action-link">Check</a></td>
                                </tr>
                                <tr>
                                    <td><i class="fas fa-times-circle text-red-500 mr-2"></i>Out of Stock</td>
                                    <td><strong>{{ stats.outOfStockProducts }}</strong></td>
                                    <td><span class="dash-badge badge-red">Critical</span></td>
                                    <td><a href="{{ path('app_staff_stock_management_index') }}" class="table-action-link">Fix</a></td>
                                </tr>
                                <tr>
                                    <td><i class="fas fa-sync text-teal-500 mr-2"></i>Restocked Today</td>
                                    <td><strong>{{ stats.restockedToday }}</strong></td>
                                    <td><span class="dash-badge badge-teal">Today</span></td>
                                    <td><a href="{{ path('app_staff_stock_management_index') }}" class="table-action-link">View</a></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const sidebarToggle = document.getElementById('sidebarToggle');
            const sidebar = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');
            
            if (sidebarToggle && sidebar && sidebarOverlay) {
                sidebarToggle.addEventListener('click', function() {
                    sidebar.classList.toggle('active');
                    sidebarOverlay.classList.toggle('active');
                });
                
                sidebarOverlay.addEventListener('click', function() {
                    sidebar.classList.remove('active');
                    sidebarOverlay.classList.remove('active');
                });
            }
        });
    </script>
{% endblock %}
