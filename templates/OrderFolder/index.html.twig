{% extends 'base.html.twig' %}

{% block title %}Order Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('OrderFolder/index.css') }}?v={{ random() }}">
{% endblock %}

{% block body %}
<div id="order-app-wrapper" class="min-h-screen">

    <!-- App Wrapper -->
    <div id="app" class="relative w-full h-screen glass-container overflow-x-auto flex flex-col">
        
        <!-- Header -->
        <header class="relative z-50 flex items-center justify-between px-10 py-8">
            <div class="flex items-center gap-3">
                <button class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/80 hover:bg-white border border-gray-200 hover:shadow-md transition-all text-gray-700 hover:text-gray-900" id="sidebarToggle" title="Toggle Sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="text-3xl font-bold tracking-tighter text-gray-800">
                    Order Management
                </span>
            </div>

            <!-- Search bar -->
            <div class="hidden md:flex items-center bg-gray-100/50 rounded-full px-5 py-2 w-72 border border-gray-200">
                <i class="fa fa-search text-gray-400 mr-3"></i>
                <input type="text" id="searchInput" placeholder="Search orders..." class="bg-transparent outline-none text-sm w-full">
            </div>

            <div class="flex items-center gap-6">
                <!-- Filter Dropdown -->
                <div class="relative">
                    <select id="statusFilter" class="bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all font-medium cursor-pointer">
                        <option value="all">All Orders</option>
                        <option value="pending">Pending Orders</option>
                        <option value="completed">Completed Orders</option>
                        <option value="cancelled">Cancelled Orders</option>
                    </select>
                </div>
                
                <a href="{{ is_granted('ROLE_ADMIN') ? path('app_admin_profile_edit') : path('app_staff_profile_edit') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors">
                    {% if app.user.profilePicture %}
                        <img src="{{ app.user.profilePicture|image_url('images/profiles') }}" alt="Profile" class="w-10 h-10 rounded-full object-cover border-2 border-white shadow-md">
                    {% else %}
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 text-white font-bold text-sm">
                            {% set displayText = app.user.displayName ?: app.user.username %}
                            {% set words = displayText|split(' ') %}
                            {% if words|length > 1 %}
                                {{ words[0]|slice(0, 1)|upper }}{{ words[1]|slice(0, 1)|upper }}
                            {% else %}
                                {{ displayText|slice(0, 2)|upper }}
                            {% endif %}
                        </div>
                    {% endif %}
                    <div class="flex flex-col items-start">
                        <span class="font-semibold text-gray-800 text-sm">{{ app.user.displayName ?: app.user.username }}</span>
                        <span class="text-xs text-gray-500">{{ is_granted('ROLE_ADMIN') ? 'Admin' : 'Staff' }}</span>
                    </div>
                </a>
            </div>
        </header>

        <!-- Viewport -->
        <main class="relative flex-1 overflow-x-auto">
            
            <!-- GRID VIEW (The Carousel) -->
            <div id="gridView" class="grid-view absolute inset-0 flex flex-col justify-end px-12 transition-all duration-500 pb-8">
                
                <!-- Carousel at bottom -->
                <div id="orderCarousel" class="flex gap-8 items-end h-[500px] mb-6">
                    <!-- Cards injected by JS -->
                </div>

                <!-- Footer Nav -->
                <div class="flex items-center justify-between pt-4 pb-2">
                    <div class="flex gap-6 text-sm font-medium text-gray-500">
                        <span>Total Orders: <span id="totalCount">{{ orders|length }}</span></span>
                        <span>Pending: <span class="text-amber-600 font-bold">{{ orders|filter(o => o.status == 'pending')|length }}</span></span>
                        <span>Completed: <span class="text-emerald-600 font-bold">{{ orders|filter(o => o.status == 'completed')|length }}</span></span>
                        <span>Revenue: <span class="text-blue-600 font-bold">₱{{ orders|filter(o => o.status == 'completed')|reduce((carry, o) => carry + o.totalAmount, 0)|number_format(2, '.', ',') }}</span></span>
                    </div>
                    <div class="flex gap-4">
                        <button onclick="prevSlide()" id="prevBtn" class="flex items-center gap-2 font-bold text-gray-800 hover:opacity-70 transition-opacity disabled:opacity-30 disabled:cursor-not-allowed">
                            <i class="fa fa-chevron-left text-xs"></i> Prev
                        </button>
                        <button onclick="nextSlide()" id="nextBtn" class="flex items-center gap-2 font-bold text-gray-800 hover:opacity-70 transition-opacity disabled:opacity-30 disabled:cursor-not-allowed">
                            Next <i class="fa fa-chevron-right text-xs"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- DETAIL / HERO VIEW -->
            <div id="heroView" class="hero-view absolute inset-0 z-40 bg-white">
                <div id="heroBg" class="absolute inset-0 w-1/2 rounded-r-[80px] transition-colors duration-700"></div>
                
                <button onclick="closeHero()" class="absolute top-8 right-10 z-50 flex items-center gap-2 font-bold text-gray-800 hover:scale-105 transition-transform">
                    <i class="fa fa-times text-red-500"></i> Close
                </button>

                <div class="relative z-10 h-full flex items-center px-16">
                    <!-- Left Side: Order Info Card -->
                    <div class="w-1/2 flex justify-center items-center">
                        <div class="hero-order-card">
                            <div class="order-card-header">
                                <i class="fas fa-shopping-bag text-6xl mb-4"></i>
                                <h3 id="heroOrderNumber" class="text-3xl font-bold mb-2"></h3>
                                <span id="heroStatusBadge" class="status-badge-hero"></span>
                            </div>
                            <div class="order-card-body">
                                <div class="customer-info-hero">
                                    <div class="customer-avatar-hero" id="heroCustomerAvatar"></div>
                                    <div>
                                        <h4 id="heroCustomerName" class="text-xl font-bold"></h4>
                                        <p id="heroCustomerPhone" class="text-gray-600"></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Side: Content -->
                    <div class="w-1/2 pl-12 pr-8">
                        <div class="hero-content-wrapper">
                            <h2 class="hero-title slide-in" style="animation-delay: 0.1s">Order Details</h2>
                            
                            <div class="hero-meta-section slide-in" style="animation-delay: 0.2s">
                                <div class="meta-row">
                                    <div class="meta-item">
                                        <i class="fa fa-calendar text-blue-500"></i>
                                        <span class="meta-label">Date:</span>
                                        <span id="heroDate" class="meta-value"></span>
                                    </div>
                                    <div class="meta-item">
                                        <i class="fa fa-coins text-emerald-500"></i>
                                        <span class="meta-label">Total:</span>
                                        <span id="heroTotal" class="meta-value"></span>
                                    </div>
                                </div>
                                <div class="meta-row">
                                    <div class="meta-item">
                                        <i class="fa fa-truck text-purple-500"></i>
                                        <span class="meta-label">Delivery:</span>
                                        <span id="heroDelivery" class="meta-value"></span>
                                    </div>
                                </div>
                                <div class="meta-item meta-item-address">
                                    <i class="fa fa-map-marker-alt text-amber-500"></i>
                                    <span class="meta-label">Address:</span>
                                    <span id="heroAddress" class="meta-value meta-value-address"></span>
                                </div>
                                <div class="meta-item meta-item-location">
                                    <i class="fa fa-city text-indigo-500"></i>
                                    <span class="meta-label">City / Province:</span>
                                    <span id="heroLocation" class="meta-value meta-value-address"></span>
                                </div>
                            </div>
                            
                            <div class="hero-description-section slide-in" style="animation-delay: 0.3s">
                                <h3 class="description-title">Additional Notes</h3>
                                <p id="heroNotes" class="description-text"></p>
                            </div>

                            <div class="hero-actions slide-in" style="animation-delay: 0.4s">
                                <a id="heroViewBtn" href="#" class="action-btn action-btn-primary">
                                    <i class="fa fa-eye"></i>
                                    <span>View Full Details</span>
                                </a>
                                <button id="heroDeleteBtn" class="action-btn action-btn-danger">
                                    <i class="fa fa-trash"></i>
                                    <span>Delete Order</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
    <script>
        // Load orders from Symfony
        const allOrdersData = [
            {% for order in orders %}
            {
                id: {{ order.id }},
                orderNumber: {{ order.orderNumber|json_encode|raw }},
                customerName: {{ order.customerName|json_encode|raw }},
                phoneNumber: {{ order.phoneNumber|json_encode|raw }},
                address: {{ order.customerAddress|json_encode|raw }},
                city: {{ order.city|json_encode|raw }},
                province: {{ order.province|json_encode|raw }},
                totalAmount: {{ order.totalAmount }},
                status: {{ order.status|json_encode|raw }},
                deliveryType: {{ order.deliveryType|json_encode|raw }},
                notes: '',
                createdAt: {{ order.createdAt ? order.createdAt|date('Y-m-d H:i:s')|json_encode|raw : 'null' }}
            }{% if not loop.last %},{% endif %}
            {% endfor %}
        ];
        
        const isAdmin = {{ is_granted('ROLE_ADMIN') ? 'true' : 'false' }};
        const baseUrl = '{{ app.request.schemeAndHttpHost }}';
        const csrfTokens = {
            {% for order in orders %}
            {{ order.id }}: '{{ csrf_token('delete' ~ order.id) }}'{% if not loop.last %},{% endif %}
            {% endfor %}
        };
        
        console.log('Total orders loaded:', allOrdersData.length);
        
        // Transform orders to match the expected format
        let orders = allOrdersData.map(order => ({
            id: order.id,
            orderNumber: order.orderNumber || 'N/A',
            customerName: order.customerName || 'Guest Customer',
            phoneNumber: order.phoneNumber || 'No phone',
            address: order.address || 'No address provided',
            city: order.city || 'N/A',
            province: order.province || 'N/A',
            totalAmount: order.totalAmount || 0,
            status: order.status || 'pending',
            deliveryType: order.deliveryType || 'Standard',
            notes: order.notes || 'No additional notes',
            createdAt: order.createdAt || null,
            colorCode: order.status === 'completed' ? '#10b981' : order.status === 'cancelled' ? '#ef4444' : '#f59e0b'
        }));
        
        let filteredOrders = [...orders];
        
        console.log('Processed orders:', orders);

        let currentIndex = 0;
        function getVisibleCount() {
            if (window.innerWidth < 768) return 1;
            if (window.innerWidth < 1024) return 2;
            return 3;
        }

        // Helper function to lighten/darken colors
        function adjustColor(color, amount) {
            const num = parseInt(color.replace("#",""), 16);
            const r = Math.min(255, Math.max(0, (num >> 16) + amount));
            const g = Math.min(255, Math.max(0, ((num >> 8) & 0x00FF) + amount));
            const b = Math.min(255, Math.max(0, (num & 0x0000FF) + amount));
            return "#" + ((r << 16) | (g << 8) | b).toString(16).padStart(6, '0');
        }

        function getStatusInfo(status) {
            if (status === 'completed') return { text: 'Completed', class: 'status-completed' };
            if (status === 'cancelled') return { text: 'Cancelled', class: 'status-cancelled' };
            return { text: 'Pending', class: 'status-pending' };
        }

        function formatDate(dateStr) {
            if (!dateStr) return 'N/A';
            const date = new Date(dateStr);
            return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        }

        function renderCarousel() {
            const container = document.getElementById('orderCarousel');
            container.innerHTML = '';
            
            if (!filteredOrders || filteredOrders.length === 0) {
                container.innerHTML = '<div class="w-full text-center text-gray-500 text-xl py-20">No orders found.</div>';
                updateNavigationButtons();
                return;
            }

            const displayed = filteredOrders.slice(currentIndex, currentIndex + getVisibleCount());

            displayed.forEach((order, index) => {
                const colorLight = adjustColor(order.colorCode, 30);
                const colorDark = adjustColor(order.colorCode, -30);
                const statusInfo = getStatusInfo(order.status);
                
                const card = document.createElement('div');
                card.className = `order-card relative w-1/3 h-full rounded-[40px] flex flex-col justify-end p-8 cursor-pointer group`;
                card.style.cssText = `--order-color-light: ${colorLight}; --order-color-dark: ${colorDark}; background: linear-gradient(180deg, ${colorLight} 0%, ${colorDark} 100%);`;
                card.setAttribute('data-color', order.colorCode);
                
                card.innerHTML = `
                    <div class="order-icon-wrapper">
                        <i class="fas fa-shopping-bag"></i>
                    </div>
                    <div class="relative z-10 pt-8">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="status-indicator ${statusInfo.class}">
                                ${statusInfo.text}
                            </span>
                        </div>
                        <h3 class="text-3xl font-bold text-white mb-1">${order.orderNumber}</h3>
                        <p class="text-white/70 text-sm mb-1">${order.customerName}</p>
                        <p class="text-white/90 text-lg font-semibold mb-2">₱${parseFloat(order.totalAmount).toFixed(2)}</p>
                        <p class="text-white/60 text-xs mb-4">${formatDate(order.createdAt)}</p>
                        <button class="bg-white/20 backdrop-blur-md text-white text-xs font-bold px-4 py-2 rounded-lg uppercase tracking-wider transition-all">
                            View Details >
                        </button>
                    </div>
                `;
                card.onclick = () => openHero(order);
                container.appendChild(card);
            });
            
            updateNavigationButtons();
        }
        
        function updateNavigationButtons() {
            const prevBtn = document.getElementById('prevBtn');
            const nextBtn = document.getElementById('nextBtn');
            
            if (prevBtn && nextBtn) {
                prevBtn.disabled = currentIndex === 0;
                nextBtn.disabled = currentIndex + getVisibleCount() >= filteredOrders.length;
            }
        }

        function nextSlide() {
            if (currentIndex + getVisibleCount() < filteredOrders.length) {
                currentIndex++;
                renderCarousel();
            }
        }

        function prevSlide() {
            if (currentIndex > 0) {
                currentIndex--;
                renderCarousel();
            }
        }
        
        // Filter functionality
        function applyFilters() {
            const searchTerm = document.getElementById('searchInput')?.value.toLowerCase() || '';
            const filterValue = document.getElementById('statusFilter')?.value || 'all';
            
            filteredOrders = orders.filter(order => {
                // Apply search filter
                const matchesSearch = !searchTerm || 
                    order.orderNumber.toLowerCase().includes(searchTerm) ||
                    order.customerName.toLowerCase().includes(searchTerm) ||
                    order.phoneNumber.toLowerCase().includes(searchTerm);
                
                // Apply status filter
                let matchesFilter = true;
                if (filterValue !== 'all') {
                    matchesFilter = order.status === filterValue;
                }
                
                return matchesSearch && matchesFilter;
            });
            
            currentIndex = 0;
            const totalCountEl = document.getElementById('totalCount');
            if (totalCountEl) {
                totalCountEl.textContent = filteredOrders.length;
            }
            renderCarousel();
        }
        
        // Search functionality
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.addEventListener('input', applyFilters);
        }
        
        // Status filter functionality
        const statusFilter = document.getElementById('statusFilter');
        if (statusFilter) {
            statusFilter.addEventListener('change', applyFilters);
        }

        let currentOrder = null;
        
        function openHero(order) {
            currentOrder = order;
            const app = document.getElementById('app');
            const heroBg = document.getElementById('heroBg');
            const statusInfo = getStatusInfo(order.status);

            // Set content
            const colorLight = adjustColor(order.colorCode, 30);
            const colorDark = adjustColor(order.colorCode, -30);
            heroBg.style.background = `linear-gradient(180deg, ${colorLight} 0%, ${colorDark} 100%)`;
            
            document.getElementById('heroOrderNumber').innerText = order.orderNumber;
            document.getElementById('heroCustomerName').innerText = order.customerName;
            document.getElementById('heroCustomerPhone').innerText = order.phoneNumber;
            document.getElementById('heroDate').innerText = formatDate(order.createdAt);
            document.getElementById('heroTotal').innerText = '₱' + parseFloat(order.totalAmount).toFixed(2);
            document.getElementById('heroDelivery').innerText = order.deliveryType;
            document.getElementById('heroAddress').innerText = order.address;
            document.getElementById('heroLocation').innerText = `${order.city}, ${order.province}`;
            document.getElementById('heroNotes').innerText = order.notes;
            
            // Customer avatar
            const avatar = document.getElementById('heroCustomerAvatar');
            avatar.innerText = order.customerName.charAt(0).toUpperCase();
            
            // Status badge
            const statusBadge = document.getElementById('heroStatusBadge');
            statusBadge.className = `status-badge-hero ${statusInfo.class}`;
            statusBadge.innerText = statusInfo.text;
            
            // Update action buttons
            const viewBtn = document.getElementById('heroViewBtn');
            const deleteBtn = document.getElementById('heroDeleteBtn');
            
            if (viewBtn) {
                const viewRoute = isAdmin ? 
                    `${baseUrl}/admin/orders/${order.id}` : 
                    `${baseUrl}/staff/orders/${order.id}`;
                viewBtn.href = viewRoute;
            }
            
            if (deleteBtn) {
                deleteBtn.onclick = function() {
                    if (confirm('Are you sure you want to delete this order? Stock will be restored if order is not completed.')) {
                        const form = document.createElement('form');
                        form.method = 'POST';
                        form.action = isAdmin ? 
                            `${baseUrl}/admin/orders/${order.id}/delete` : 
                            `${baseUrl}/staff/orders/${order.id}/delete`;
                        
                        const tokenInput = document.createElement('input');
                        tokenInput.type = 'hidden';
                        tokenInput.name = '_token';
                        tokenInput.value = csrfTokens[order.id] || '';
                        
                        form.appendChild(tokenInput);
                        document.body.appendChild(form);
                        form.submit();
                    }
                };
            }

            // Trigger animation
            app.classList.add('hero-active');
            
            // Reset text animations
            const animatedElements = document.querySelectorAll('.slide-in');
            animatedElements.forEach(el => {
                el.style.animation = 'none';
                el.offsetHeight; // trigger reflow
                el.style.animation = null;
            });
        }

        function closeHero() {
            document.getElementById('app').classList.remove('hero-active');
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM loaded, rendering carousel...');
            renderCarousel();
            
            window.addEventListener('resize', function() { renderCarousel(); });
            
            // Sidebar toggle functionality
            const sidebarToggle = document.getElementById('sidebarToggle');
            const sidebar = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');
            
            if (sidebarToggle && sidebar && sidebarOverlay) {
                sidebarToggle.addEventListener('click', function() {
                    sidebar.classList.toggle('active');
                    sidebarOverlay.classList.toggle('active');
                });
                
                sidebarOverlay.addEventListener('click', function() {
                    sidebar.classList.remove('active');
                    sidebarOverlay.classList.remove('active');
                });
            }
        });
    </script>
{% endblock %}
