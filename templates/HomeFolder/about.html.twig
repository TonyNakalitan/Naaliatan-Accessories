{% extends 'base.html.twig' %}

{% block title %}About Us - Naaliatan's Accessories{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('HomeFolder/about.css') }}?v={{ random() }}">
{% endblock %}

{% block body %}
    <main class="content-area">
        <header class="top-nav">
            <a href="{{ path('app_home') }}" class="nav-brand" aria-label="Naaliatan Home">
                <img src="{{ asset('images/NA.png') }}" alt="Naaliatan's Accessories" class="brand-logo">
            </a>
            
            <button class="mobile-menu-btn" id="mobileMenuBtn">
                <i class="fas fa-bars"></i>
            </button>
            
            <nav class="main-nav" id="mainNav">
                <a href="{{ path('app_home') }}" class="nav-link">
                    <i class="fas fa-home"></i>
                    <span>Home</span>
                </a>
                <a href="{{ path('app_about') }}" class="nav-link active">
                    <i class="fas fa-info-circle"></i>
                    <span>About</span>
                </a>
                <a href="{{ path('app_products') }}" class="nav-link">
                    <i class="fas fa-box-open"></i>
                    <span>Products</span>
                </a>
                <a href="{{ path('app_contact') }}" class="nav-link">
                    <i class="fas fa-envelope"></i>
                    <span>Contact</span>
                </a>
            </nav>
            
            <div class="user-widget">
                {% if app.user %}
                    <div class="avatar">
                        {% if app.user.profilePicture %}
                            <img src="{{ asset('images/profiles/' ~ app.user.profilePicture) }}" alt="{{ app.user.displayName ?: app.user.username }}">
                        {% else %}
                            {{ (app.user.displayName ?: app.user.username)|default('U')|slice(0,1)|upper }}
                        {% endif %}
                    </div>
                    <div class="user-info">
                        <p class="user-name">{{ app.user.displayName ?: app.user.username }}</p>
                        <p class="user-role">{{ app.user.roles[0] == 'ROLE_ADMIN' ? 'Admin' : 'Staff' }}</p>
                    </div>
                {% else %}
                    <a href="{{ path('app_register') }}" class="btn-register">Register</a>
                    <a href="{{ path('app_login') }}" class="btn-login">Login</a>
                {% endif %}
            </div>
        </header>

        <div class="page-container">
            {# Enhanced Hero Section #}
            <section class="hero-section">
                <div class="hero-content">
                    <div class="hero-badge">
                        <i class="fas fa-sparkles"></i>
                        <span>About Naaliatan's Accessories</span>
                    </div>
                    <h1 class="hero-title">
                        Our Story &<br>
                        <span class="gradient-text">Passion</span>
                    </h1>
                    <p class="hero-subtitle">
                        Founded with a passion for quality and creativity, Naaliatan's Accessories has been serving collectors and enthusiasts for years. 
                        We believe that every accessory tells a story, and we're here to help you find the perfect pieces for your collection.
                    </p>
                    <div class="hero-actions">
                        <a href="{{ path('app_admin_product_management_index') }}" class="btn-hero btn-primary">
                            <i class="fas fa-shopping-bag"></i>
                            Browse Products
                        </a>
                        <a href="#team" class="btn-hero btn-secondary">
                            <i class="fas fa-users"></i>
                            Meet Our Team
                        </a>
                    </div>
                </div>
                <div class="hero-visual">
                    <div class="floating-card card-1">
                        <i class="fas fa-store"></i>
                        <span>Quality Store</span>
                    </div>
                    <div class="floating-card card-2">
                        <i class="fas fa-bullseye"></i>
                        <span>Our Mission</span>
                    </div>
                    <div class="floating-card card-3">
                        <i class="fas fa-heart"></i>
                        <span>Passion Driven</span>
                    </div>
                    <div class="hero-icon-main">
                        <i class="fas fa-leaf"></i>
                    </div>
                </div>
            </section>

            {# Stats Overview Section #}
            <section class="stats-overview">
                <div class="stat-card stat-card-blue">
                    <div class="stat-icon">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Years in Business</h3>
                        <p class="value">10+</p>
                        <span class="stat-badge">Experience</span>
                    </div>
                </div>
                <div class="stat-card stat-card-purple">
                    <div class="stat-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Happy Customers</h3>
                        <p class="value">50K+</p>
                        <span class="stat-badge">Community</span>
                    </div>
                </div>
                <div class="stat-card stat-card-emerald">
                    <div class="stat-icon">
                        <i class="fas fa-box-open"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Products Sold</h3>
                        <p class="value">100K+</p>
                        <span class="stat-badge">Collection</span>
                    </div>
                </div>
                <div class="stat-card stat-card-pink">
                    <div class="stat-icon">
                        <i class="fas fa-star"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Satisfaction Rate</h3>
                        <p class="value">98%</p>
                        <span class="stat-badge">Quality</span>
                    </div>
                </div>
            </section>

            {# About Content Section #}
            <section class="about-content-section">
                <div class="section-header">
                    <h2 class="section-title">Our Journey</h2>
                    <p class="section-subtitle">From a small passion project to a leading accessories destination</p>
                </div>
                
                <div class="about-grid">
                    <div class="about-card">
                        <div class="about-icon-wrapper">
                            <div class="about-icon about-icon-blue">
                                <i class="fas fa-store"></i>
                            </div>
                        </div>
                        <h3>Our Story</h3>
                        <p>Founded with a passion for quality and creativity, Naaliatan's Accessories has been serving collectors and enthusiasts for over a decade.</p>
                        <p>We started as a small store with a big dream - to provide the best character accessories to collectors worldwide. Today, we're proud to be a trusted name in the industry.</p>
                        <ul class="about-list">
                            <li><i class="fas fa-check"></i> Founded in 2014</li>
                            <li><i class="fas fa-check"></i> Family-owned business</li>
                            <li><i class="fas fa-check"></i> Collector-focused approach</li>
                        </ul>
                    </div>

                    <div class="about-card">
                        <div class="about-icon-wrapper">
                            <div class="about-icon about-icon-green">
                                <i class="fas fa-bullseye"></i>
                            </div>
                        </div>
                        <h3>Our Mission</h3>
                        <p>To provide the highest quality character accessories while maintaining exceptional customer service and competitive pricing.</p>
                        <p>We're committed to bringing joy to collectors worldwide through carefully curated products and a shopping experience that exceeds expectations.</p>
                        <ul class="about-list">
                            <li><i class="fas fa-check"></i> Premium quality products</li>
                            <li><i class="fas fa-check"></i> Exceptional customer service</li>
                            <li><i class="fas fa-check"></i> Competitive pricing</li>
                        </ul>
                    </div>
                </div>
            </section>

            {# Features Section #}
            <section class="features-section">
                <div class="section-header">
                    <h2 class="section-title">What Makes Us Different</h2>
                    <p class="section-subtitle">We go above and beyond to serve our collector community</p>
                </div>
                
                <div class="features-grid">
                    <div class="feature-card">
                        <div class="feature-icon-wrapper">
                            <div class="feature-icon feature-icon-blue">
                                <i class="fas fa-star"></i>
                            </div>
                        </div>
                        <h3>Curated Selection</h3>
                        <p>Every product is carefully selected by our expert team to ensure the highest quality and authenticity</p>
                        <ul class="feature-list">
                            <li><i class="fas fa-check"></i> Expert curation</li>
                            <li><i class="fas fa-check"></i> Quality guaranteed</li>
                            <li><i class="fas fa-check"></i> Authentic products</li>
                        </ul>
                    </div>

                    <div class="feature-card">
                        <div class="feature-icon-wrapper">
                            <div class="feature-icon feature-icon-green">
                                <i class="fas fa-shipping-fast"></i>
                            </div>
                        </div>
                        <h3>Fast Worldwide Shipping</h3>
                        <p>Quick and reliable shipping to get your collectibles to you safely and promptly</p>
                        <ul class="feature-list">
                            <li><i class="fas fa-check"></i> Global delivery</li>
                            <li><i class="fas fa-check"></i> Secure packaging</li>
                            <li><i class="fas fa-check"></i> Tracking included</li>
                        </ul>
                    </div>

                    <div class="feature-card">
                        <div class="feature-icon-wrapper">
                            <div class="feature-icon feature-icon-red">
                                <i class="fas fa-shield-alt"></i>
                            </div>
                        </div>
                        <h3>Collector Protection</h3>
                        <p>Safe shopping experience with buyer protection and dedicated customer support</p>
                        <ul class="feature-list">
                            <li><i class="fas fa-check"></i> Secure payments</li>
                            <li><i class="fas fa-check"></i> Money-back guarantee</li>
                            <li><i class="fas fa-check"></i> 24/7 support</li>
                        </ul>
                    </div>
                </div>
            </section>

            {# Team Section #}
            <section class="team-section" id="team">
                <div class="section-header">
                    <h2 class="section-title">Meet Our Team</h2>
                    <p class="section-subtitle">The passionate people behind Naaliatan's Accessories</p>
                </div>
                
                <div class="team-grid">
                    <div class="team-card">
                        <img src="{{ asset('images/teams/Anthony.png') }}" alt="Anthony Naaliatan" class="team-avatar">
                        <h3 class="team-name">Anthony Naaliatan</h3>
                        <p class="team-role">Founder & CEO</p>
                        <p class="team-bio">Passionate about bringing quality accessories to collectors worldwide with over 10 years of experience.</p>
                        <div class="team-social">
                            <a href="#" class="social-link"><i class="fab fa-twitter"></i></a>
                            <a href="#" class="social-link"><i class="fab fa-linkedin"></i></a>
                            <a href="#" class="social-link"><i class="fas fa-envelope"></i></a>
                        </div>
                    </div>

                    <div class="team-card">
                        <img src="{{ asset('images/teams/Sarah.png') }}" alt="Sarah Chen" class="team-avatar">
                        <h3 class="team-name">Sarah Chen</h3>
                        <p class="team-role">Creative Director</p>
                        <p class="team-bio">Curates our collection with an eye for detail and a passion for character design and storytelling.</p>
                        <div class="team-social">
                            <a href="#" class="social-link"><i class="fab fa-twitter"></i></a>
                            <a href="#" class="social-link"><i class="fab fa-linkedin"></i></a>
                            <a href="#" class="social-link"><i class="fas fa-envelope"></i></a>
                        </div>
                    </div>

                    <div class="team-card">
                        <img src="{{ asset('images/teams/Mike.png') }}" alt="Mike Hawk" class="team-avatar">
                        <h3 class="team-name">Mike Hawk</h3>
                        <p class="team-role">Customer Success</p>
                        <p class="team-bio">Ensures every customer has an amazing experience from browsing to delivery and beyond.</p>
                        <div class="team-social">
                            <a href="#" class="social-link"><i class="fab fa-twitter"></i></a>
                            <a href="#" class="social-link"><i class="fab fa-linkedin"></i></a>
                            <a href="#" class="social-link"><i class="fas fa-envelope"></i></a>
                        </div>
                    </div>

                    <div class="team-card">
                        <img src="{{ asset('images/teams/Mike2.png') }}" alt="Mike William" class="team-avatar">
                        <h3 class="team-name">Mike William</h3>
                        <p class="team-role">Operations Manager</p>
                        <p class="team-bio">Manages inventory and logistics to ensure products arrive safely and on time, every time.</p>
                        <div class="team-social">
                            <a href="#" class="social-link"><i class="fab fa-twitter"></i></a>
                            <a href="#" class="social-link"><i class="fab fa-linkedin"></i></a>
                            <a href="#" class="social-link"><i class="fas fa-envelope"></i></a>
                        </div>
                    </div>
                </div>
            </section>

            {# Quick Actions Panel #}
            <section class="quick-actions-panel">
                <div class="panel-header">
                    <div class="panel-title-wrapper">
                        <div class="panel-icon">
                            <i class="fas fa-bolt"></i>
                        </div>
                        <span class="panel-title">Get Started</span>
                    </div>
                </div>
                <div class="actions-grid">
                    <a href="{{ path('app_admin_product_management_index') }}" class="action-card">
                        <div class="action-icon action-icon-blue">
                            <i class="fas fa-shopping-bag"></i>
                        </div>
                        <div class="action-content">
                            <h4>Browse Products</h4>
                            <p>Explore our collection</p>
                        </div>
                        <i class="fas fa-arrow-right action-arrow"></i>
                    </a>

                    <a href="{{ path('app_admin_character_management_index') }}" class="action-card">
                        <div class="action-icon action-icon-purple">
                            <i class="fas fa-id-badge"></i>
                        </div>
                        <div class="action-content">
                            <h4>View Characters</h4>
                            <p>Discover character profiles</p>
                        </div>
                        <i class="fas fa-arrow-right action-arrow"></i>
                    </a>

                    <a href="#" class="action-card">
                        <div class="action-icon action-icon-emerald">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div class="action-content">
                            <h4>Contact Us</h4>
                            <p>Get in touch</p>
                        </div>
                        <i class="fas fa-arrow-right action-arrow"></i>
                    </a>

                    <a href="{{ path('app_register') }}" class="action-card">
                        <div class="action-icon action-icon-amber">
                            <i class="fas fa-user-plus"></i>
                        </div>
                        <div class="action-content">
                            <h4>Join Community</h4>
                            <p>Create an account</p>
                        </div>
                        <i class="fas fa-arrow-right action-arrow"></i>
                    </a>
                </div>
            </section>

            {# CTA Section #}
            <section class="cta-section">
                <div class="cta-content">
                    <h2>Join Our Collector Community</h2>
                    <p>Become part of a thriving community of collectors and enthusiasts. Start building your dream collection today!</p>
                    <div class="cta-actions">
                        <a href="{{ path('app_admin_product_management_index') }}" class="btn-cta btn-cta-primary">
                            <i class="fas fa-shopping-bag"></i>
                            Start Shopping
                        </a>
                        <a href="{{ path('app_register') }}" class="btn-cta btn-cta-secondary">
                            <i class="fas fa-user-plus"></i>
                            Join Now
                        </a>
                    </div>
                </div>
            </section>

            {# Footer #}
            <footer class="site-footer">
                <div class="footer-content">
                    <div class="footer-brand">
                        <div class="footer-logo">
                            <i class="fas fa-leaf"></i>
                        </div>
                        <div class="footer-brand-info">
                            <h3>Naaliatan's Accessories</h3>
                            <p>Your premier destination for character collectibles and accessories</p>
                        </div>
                    </div>
                    
                    <div class="footer-links">
                        <div class="footer-column">
                            <h4>Quick Links</h4>
                            <ul>
                                <li><a href="{{ path('app_home') }}"><i class="fas fa-chevron-right"></i> Home</a></li>
                                <li><a href="{{ path('app_about') }}"><i class="fas fa-chevron-right"></i> About Us</a></li>
                                <li><a href="{{ path('app_admin_product_management_index') }}"><i class="fas fa-chevron-right"></i> Products</a></li>
                                <li><a href="{{ path('app_contact') }}"><i class="fas fa-chevron-right"></i> Contact</a></li>
                            </ul>
                        </div>
                        
                        <div class="footer-column">
                            <h4>Support</h4>
                            <ul>
                                <li><a href="#"><i class="fas fa-chevron-right"></i> Help Center</a></li>
                                <li><a href="#"><i class="fas fa-chevron-right"></i> Shipping Info</a></li>
                                <li><a href="#"><i class="fas fa-chevron-right"></i> Returns</a></li>
                                <li><a href="#"><i class="fas fa-chevron-right"></i> FAQ</a></li>
                            </ul>
                        </div>
                        
                        <div class="footer-column">
                            <h4>Connect</h4>
                            <div class="social-links">
                                <a href="https://www.facebook.com/profile.php?id=61576480294715" target="_blank" rel="noopener noreferrer" class="social-icon"><i class="fab fa-facebook-f"></i></a>
                                <a href="#" class="social-icon"><i class="fab fa-twitter"></i></a>
                                <a href="#" class="social-icon"><i class="fab fa-instagram"></i></a>
                                <a href="#" class="social-icon"><i class="fab fa-discord"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="footer-bottom">
                    <p>&copy; {{ "now"|date("Y") }} Naaliatan's Accessories. All rights reserved.</p>
                    <div class="footer-legal">
                        <a href="#">Privacy Policy</a>
                        <span>|</span>
                        <a href="#">Terms of Service</a>
                    </div>
                </div>
            </footer>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('HomeFolder/about.js') }}?v={{ random() }}"></script>
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
{% endblock %}
