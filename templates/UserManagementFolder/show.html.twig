<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View User | Naaliatan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f1f5f9; }
        .glass-panel { background: rgba(255,255,255,0.85); backdrop-filter: blur(12px); }
    </style>
</head>
<body class="min-h-screen">

    <div class="flex h-screen">
        <main class="flex-grow flex flex-col overflow-y-auto w-full bg-slate-50">
            <div class="w-full p-4 sm:p-6 lg:p-8">

                <!-- Main Container -->
                <div class="bg-gradient-to-br from-white via-indigo-50/30 to-purple-50/30 rounded-2xl sm:rounded-3xl p-4 sm:p-6 lg:p-8 shadow-xl border border-white/50">

                    <!-- Header -->
                    <div class="mb-6 sm:mb-8 flex flex-col sm:flex-row items-start justify-between gap-4">
                        <div class="flex-1">
                            <div class="flex items-center gap-3 mb-3">
                                <div class="w-10 h-10 sm:w-12 sm:h-12 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-200">
                                    <i class="fas fa-user text-white text-lg sm:text-xl"></i>
                                </div>
                                <h1 class="text-2xl sm:text-3xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
                                    User Details
                                </h1>
                            </div>
                            <p class="text-slate-600 text-sm sm:text-base">Viewing account information for <strong>{{ user.displayName ?: user.username }}</strong>.</p>
                        </div>
                        <a href="{{ path('app_admin_user_management_index') }}" class="w-full sm:w-auto px-4 sm:px-6 py-2.5 sm:py-3 bg-white/80 backdrop-blur-sm text-slate-700 font-semibold rounded-xl hover:bg-white hover:shadow-lg transition-all flex items-center justify-center gap-2 text-sm sm:text-base whitespace-nowrap border border-slate-200">
                            <i class="fas fa-arrow-left"></i>
                            <span class="hidden sm:inline">Back to User Management</span>
                            <span class="sm:hidden">Back</span>
                        </a>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-start">

                        <!-- Left: Profile Card -->
                        <div class="lg:col-span-4">
                            <div class="glass-panel rounded-2xl sm:rounded-3xl overflow-hidden border border-white/50 shadow-2xl">
                                <!-- Color Banner -->
                                <div class="h-24 w-full
                                    {% if 'ROLE_ADMIN' in user.roles %}
                                        bg-gradient-to-r from-red-400 to-pink-500
                                    {% elseif 'ROLE_STAFF' in user.roles %}
                                        bg-gradient-to-r from-purple-400 to-indigo-500
                                    {% else %}
                                        bg-gradient-to-r from-blue-400 to-cyan-500
                                    {% endif %}
                                "></div>

                                <div class="px-6 pb-6 -mt-12 flex flex-col items-center text-center">
                                    {% if user.profilePicture %}
                                        <img src="{{ asset('images/profiles/' ~ user.profilePicture) }}" alt="{{ user.displayName }}"
                                             class="w-24 h-24 rounded-full object-cover border-4 border-white shadow-xl mb-4">
                                    {% else %}
                                        <div class="w-24 h-24 rounded-full border-4 border-white shadow-xl mb-4 flex items-center justify-center text-white text-3xl font-bold
                                            {% if 'ROLE_ADMIN' in user.roles %}
                                                bg-gradient-to-br from-red-400 to-pink-500
                                            {% elseif 'ROLE_STAFF' in user.roles %}
                                                bg-gradient-to-br from-purple-400 to-indigo-500
                                            {% else %}
                                                bg-gradient-to-br from-blue-400 to-cyan-500
                                            {% endif %}
                                        ">
                                            {{ (user.displayName ?: user.username)|slice(0, 2)|upper }}
                                        </div>
                                    {% endif %}

                                    <h2 class="text-xl font-bold text-slate-900 mb-1">{{ user.displayName ?: user.username }}</h2>
                                    <p class="text-slate-500 text-sm mb-3">@{{ user.username }}</p>

                                    <!-- Role Badge -->
                                    <span class="px-3 py-1 rounded-full text-xs font-bold text-white mb-2
                                        {% if 'ROLE_ADMIN' in user.roles %}
                                            bg-gradient-to-r from-red-500 to-pink-500
                                        {% elseif 'ROLE_STAFF' in user.roles %}
                                            bg-gradient-to-r from-purple-500 to-indigo-500
                                        {% else %}
                                            bg-gradient-to-r from-blue-500 to-cyan-500
                                        {% endif %}
                                    ">
                                        {% if 'ROLE_ADMIN' in user.roles %}
                                            <i class="fas fa-crown mr-1"></i> Administrator
                                        {% elseif 'ROLE_STAFF' in user.roles %}
                                            <i class="fas fa-user-tie mr-1"></i> Staff
                                        {% else %}
                                            <i class="fas fa-user mr-1"></i> User
                                        {% endif %}
                                    </span>

                                    <!-- Status Badge -->
                                    <span class="px-3 py-1 rounded-full text-xs font-bold text-white
                                        {{ user.isActive ? 'bg-emerald-500' : 'bg-red-500' }}
                                    ">
                                        <i class="fas fa-circle text-[8px] mr-1"></i>
                                        {{ user.isActive ? 'Active' : 'Inactive' }}
                                    </span>                                    <span class="px-3 py-1 rounded-full text-xs font-bold text-white mb-2
                                        {{ user.isOnline ? 'bg-blue-500' : 'bg-gray-500' }}
                                    ">
                                        <i class="fas fa-circle text-[8px] mr-1"></i>
                                        {{ user.isOnline ? 'Online' : 'Offline' }}
                                    </span>                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="mt-4 flex flex-col gap-3">
                                <a href="{{ path('app_admin_user_management_edit', {'id': user.id}) }}"
                                   class="w-full px-5 py-3 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 transition-all flex items-center justify-center gap-2 shadow-lg shadow-indigo-200 text-sm">
                                    <i class="fas fa-edit"></i> Edit User
                                </a>
                                <form method="POST" action="{{ path('app_admin_user_management_toggle_status', {'id': user.id}) }}"
                                      onsubmit="return confirm('Are you sure you want to {{ user.isActive ? 'deactivate' : 'activate' }} this user?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                                    <button type="submit"
                                            class="w-full px-5 py-3 font-semibold rounded-xl transition-all flex items-center justify-center gap-2 text-sm
                                                {{ user.isActive
                                                    ? 'bg-amber-500 text-white hover:bg-amber-600 shadow-lg shadow-amber-200'
                                                    : 'bg-emerald-500 text-white hover:bg-emerald-600 shadow-lg shadow-emerald-200' }}">
                                        <i class="fas {{ user.isActive ? 'fa-ban' : 'fa-check-circle' }}"></i>
                                        {{ user.isActive ? 'Deactivate User' : 'Activate User' }}
                                    </button>
                                </form>
                                <form method="POST" action="{{ path('app_admin_user_management_delete', {'id': user.id}) }}"
                                      onsubmit="return confirm('Are you sure you want to delete this user?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                    <button type="submit"
                                            class="w-full px-5 py-3 bg-red-500 text-white font-semibold rounded-xl hover:bg-red-600 transition-all flex items-center justify-center gap-2 shadow-lg shadow-red-200 text-sm">
                                        <i class="fas fa-trash"></i> Delete User
                                    </button>
                                </form>
                            </div>
                        </div>

                        <!-- Right: Info Panels -->
                        <div class="lg:col-span-8 space-y-6">

                            <!-- Account Information -->
                            <div class="glass-panel rounded-2xl p-6 border border-white/50 shadow-lg">
                                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Account Information</h3>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                    <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                                        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider mb-1">User ID</p>
                                        <p class="text-slate-800 font-bold">#{{ user.id }}</p>
                                    </div>
                                    <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                                        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider mb-1">Username</p>
                                        <p class="text-slate-800 font-bold">{{ user.username }}</p>
                                    </div>
                                    <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                                        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider mb-1">Display Name</p>
                                        <p class="text-slate-800 font-bold">{{ user.displayName ?: '—' }}</p>
                                    </div>
                                    <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                                        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider mb-1">Email</p>
                                        <p class="text-slate-800 font-bold break-all">{{ user.email }}</p>
                                    </div>
                                    <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                                        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider mb-1">Email Verified</p>
                                        <p class="font-bold {{ user.isVerified ? 'text-emerald-600' : 'text-red-500' }}">
                                            <i class="fas {{ user.isVerified ? 'fa-check-circle' : 'fa-times-circle' }} mr-1"></i>
                                            {{ user.isVerified ? 'Verified' : 'Not Verified' }}
                                        </p>
                                    </div>
                                    <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                                        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider mb-1">Account Status</p>
                                        <p class="font-bold {{ user.isActive ? 'text-emerald-600' : 'text-red-500' }}">
                                            <i class="fas fa-circle text-[8px] mr-1"></i>
                                            {{ user.isActive ? 'Active' : 'Inactive' }}
                                        </p>
                                    </div>
                                    <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                                        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider mb-1">Member Since</p>
                                        <p class="text-slate-800 font-bold">{{ user.createdAt|date('F j, Y') }}</p>
                                    </div>
                                    <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                                        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider mb-1">Roles</p>
                                        <div class="flex flex-wrap gap-1 mt-1">
                                            {% for role in user.roles %}
                                                {% if role != 'ROLE_USER' %}
                                                    <span class="px-2 py-0.5 bg-indigo-100 text-indigo-700 text-xs font-semibold rounded-full">{{ role }}</span>
                                                {% endif %}
                                            {% endfor %}
                                            <span class="px-2 py-0.5 bg-slate-100 text-slate-600 text-xs font-semibold rounded-full">ROLE_USER</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Toggle Status -->
                            <div class="glass-panel rounded-2xl p-6 border border-white/50 shadow-lg">
                                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Quick Actions</h3>
                                <form method="POST" action="{{ path('app_admin_user_management_toggle_status', {'id': user.id}) }}"
                                      onsubmit="return confirm('Are you sure you want to {{ user.isActive ? 'deactivate' : 'activate' }} this user?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                                    <button type="submit"
                                            class="inline-flex items-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm transition-all shadow-md
                                                {{ user.isActive
                                                    ? 'bg-amber-100 text-amber-700 hover:bg-amber-200'
                                                    : 'bg-emerald-100 text-emerald-700 hover:bg-emerald-200' }}">
                                        <i class="fas {{ user.isActive ? 'fa-ban' : 'fa-check-circle' }}"></i>
                                        {{ user.isActive ? 'Deactivate Account' : 'Activate Account' }}
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

</body>
</html>
