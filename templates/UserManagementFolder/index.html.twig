{% extends 'base.html.twig' %}

{% block title %}User Management | Naaliatan{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('UserManagementFolder/index.css?v=' ~ random()) }}">
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css">
    <link rel="stylesheet" href="{{ asset('UserManagementFolder/user_management_modals.css?v=' ~ random()) }}">
{% endblock %}

{% block body %}
    <main class="content-area">
        <header class="top-nav">
            <div class="search-global">
                <i class="fas fa-search"></i>
                <input type="text" id="globalSearch" placeholder="Search users...">
            </div>
            <div class="user-widget">
                <button class="icon-btn"><i class="fas fa-bell"></i></button>
                <div class="avatar">
                    {% if app.user.profilePicture %}
                        <img src="{{ asset('images/profiles/' ~ app.user.profilePicture) }}" alt="{{ app.user.displayName ?: app.user.username }}">
                    {% else %}
                        {{ (app.user.displayName ?: app.user.username)|default('A')|slice(0,1)|upper }}
                    {% endif %}
                </div>
                <div class="user-info">
                    <p class="user-name">{{ app.user.displayName ?: app.user.username }}</p>
                    <p class="user-role">Admin</p>
                </div>
            </div>
        </header>

        <div class="page-container">
            <div class="page-intro">
                <div>
                    <h1 class="page-title">User Management</h1>
                    <p class="page-subtitle">Manage system users, roles, and permissions</p>
                </div>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}

            <div class="stats-grid">
                <div class="stat-card stat-card-blue">
                    <div class="stat-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Total Users</h3>
                        <p class="value">{{ users|length }}</p>
                        <span class="stat-badge">All</span>
                    </div>
                </div>

                <div class="stat-card stat-card-purple">
                    <div class="stat-icon">
                        <i class="fas fa-user-shield"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Admins</h3>
                        <p class="value">{{ users|filter(u => 'ROLE_ADMIN' in u.roles)|length }}</p>
                        <span class="stat-badge">Role</span>
                    </div>
                </div>

                <div class="stat-card stat-card-emerald">
                    <div class="stat-icon">
                        <i class="fas fa-user-check"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Active Users</h3>
                        <p class="value">{{ users|filter(u => u.isActive)|length }}</p>
                        <span class="stat-badge">Status</span>
                    </div>
                </div>

                <div class="stat-card stat-card-amber">
                    <div class="stat-icon">
                        <i class="fas fa-user-clock"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Verified</h3>
                        <p class="value">{{ users|filter(u => u.isVerified)|length }}</p>
                        <span class="stat-badge">Email</span>
                    </div>
                </div>
            </div>

            <div class="data-panel">
                <div class="panel-header">
                    <div class="panel-title-wrapper">
                        <div class="panel-icon">
                            <i class="fas fa-users"></i>
                        </div>
                        <span class="panel-title">All Users</span>
                    </div>
                    <div class="badge-group">
                        <a href="{{ path('app_admin_user_management_new') }}" class="btn-add-user">
                            <i class="fas fa-user-plus"></i>
                            Add New User
                        </a>
                        <select id="roleFilter" class="filter-select">
                            <option value="all roles">All Roles</option>
                            <option value="admin">Admin</option>
                            <option value="staff">Staff</option>
                            <option value="user">User</option>
                        </select>
                    </div>
                </div>

                <div class="table-container">
                    <table id="myTable" class="user-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Display Name</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Verified</th>
                                <th>Created</th>
                                <th class="action-column">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="userTableBody">
                            {% for user in users %}
                                <tr>
                                    <td>{{ user.id }}</td>
                                    <td>
                                        <div class="user-cell">
                                            <div class="user-avatar">
                                                {% if user.profilePicture %}
                                                    <img src="{{ asset('images/profiles/' ~ user.profilePicture) }}" alt="{{ user.username }}">
                                                {% else %}
                                                    {{ user.username|slice(0,1)|upper }}
                                                {% endif %}
                                            </div>
                                            <span>{{ user.username }}</span>
                                        </div>
                                    </td>
                                    <td>{{ user.email }}</td>
                                    <td>{{ user.displayName ?: '-' }}</td>
                                    <td>
                                        {% if 'ROLE_ADMIN' in user.roles %}
                                            <span class="badge badge-admin">
                                                <i class="fas fa-shield-alt"></i>
                                                Admin
                                            </span>
                                        {% elseif 'ROLE_STAFF' in user.roles %}
                                            <span class="badge badge-staff">
                                                <i class="fas fa-user-tie"></i>
                                                Staff
                                            </span>
                                        {% else %}
                                            <span class="badge badge-user">
                                                <i class="fas fa-user"></i>
                                                User
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if user.isActive %}
                                            <span class="status-badge status-active">
                                                <i class="fas fa-circle"></i>
                                                Active
                                            </span>
                                        {% else %}
                                            <span class="status-badge status-inactive">
                                                <i class="fas fa-circle"></i>
                                                Inactive
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if user.isVerified %}
                                            <span class="verify-badge verify-yes">
                                                <i class="fas fa-check-circle"></i>
                                                Verified
                                            </span>
                                        {% else %}
                                            <span class="verify-badge verify-no">
                                                <i class="fas fa-times-circle"></i>
                                                Unverified
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td>{{ user.createdAt|date('M d, Y') }}</td>
                                    <td>
                                        <div class="action-buttons">
                                            <a href="{{ path('app_admin_user_management_edit', {'id': user.id}) }}" class="btn-action btn-edit" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button type="button" class="btn-action btn-toggle" title="Toggle Status" onclick="openToggleModal('{{ user.id }}', '{{ user.username }}', '{% if user.isActive %}active{% else %}inactive{% endif %}', '{{ csrf_token('toggle' ~ user.id) }}')">
                                                <i class="fas fa-power-off"></i>
                                            </button>
                                            <button type="button" class="btn-action btn-delete" title="Delete" onclick="openDeleteModal('{{ user.id }}', '{{ user.username }}', '{{ csrf_token('delete' ~ user.id) }}')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="9" class="empty-state">
                                        <i class="fas fa-users"></i>
                                        <p>No users found</p>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    {# Include User Management Modals #}
    {% include 'UserManagementFolder/user_management_modals.html.twig' %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.3.7/js/dataTables.min.js"></script>
    <script src="{{ asset('UserManagementFolder/index.js') }}"></script>
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
    <script src="{{ asset('UserManagementFolder/user_management_modals.js') }}"></script>
{% endblock %}
