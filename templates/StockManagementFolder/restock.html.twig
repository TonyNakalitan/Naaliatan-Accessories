<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Restock {{ product.name }} | Naaliatan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('StockManagementFolder/restock.css?v=' ~ random()) }}">
</head>
<body class="min-h-screen">

    <div class="flex h-screen">
        <main class="flex-grow flex flex-col overflow-y-auto w-full bg-slate-50">
            <div class="w-full p-4 sm:p-6 lg:p-8">

                {% if app.flashes('success') %}
                    <div class="mb-4 sm:mb-6 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-800 shadow-sm">
                        {% for message in app.flashes('success') %}
                            <p class="text-sm sm:text-base"><i class="fas fa-check-circle mr-2"></i>{{ message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if app.flashes('error') %}
                    <div class="mb-4 sm:mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-800 shadow-sm">
                        {% for message in app.flashes('error') %}
                            <p class="text-sm sm:text-base"><i class="fas fa-exclamation-circle mr-2"></i>{{ message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}

                <!-- Main Container -->
                <div class="bg-gradient-to-br from-white via-emerald-50/30 to-teal-50/30 rounded-2xl sm:rounded-3xl p-4 sm:p-6 lg:p-8 shadow-xl border border-white/50">
                    
                    <!-- Header with Back Button -->
                    <div class="mb-6 sm:mb-8 flex flex-col sm:flex-row items-start justify-between gap-4">
                        <div class="flex-1">
                            <div class="flex items-center gap-3 mb-3">
                                <div class="w-10 h-10 sm:w-12 sm:h-12 bg-gradient-to-br from-emerald-600 to-teal-600 rounded-2xl flex items-center justify-center shadow-lg shadow-emerald-200">
                                    <i class="fas fa-box-open text-white text-lg sm:text-xl"></i>
                                </div>
                                <h1 class="text-2xl sm:text-3xl font-bold bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent">
                                    Restock Product
                                </h1>
                            </div>
                            <p class="text-slate-600 text-sm sm:text-base">Add stock quantity from available inventory to {{ product.name }}</p>
                        </div>
                        <a href="{{ role_path('stock_management_index') }}" class="w-full sm:w-auto px-4 sm:px-6 py-2.5 sm:py-3 bg-white/80 backdrop-blur-sm text-slate-700 font-semibold rounded-xl hover:bg-white hover:shadow-lg transition-all flex items-center justify-center gap-2 text-sm sm:text-base whitespace-nowrap border border-slate-200">
                            <i class="fas fa-arrow-left"></i>
                            <span class="hidden sm:inline">Back to Stock Management</span>
                            <span class="sm:hidden">Back</span>
                        </a>
                    </div>

                <!-- Content Wrapper -->
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-start">
                    
                    <!-- Left Column: Product Info -->
                    <div class="lg:col-span-4 lg:sticky lg:top-8">
                        <div class="glass-panel rounded-2xl sm:rounded-3xl overflow-hidden border border-white/50 shadow-2xl">
                            <div class="p-3 sm:p-4 border-b border-slate-100 flex items-center justify-between bg-gradient-to-r from-white/80 to-emerald-50/50 backdrop-blur-sm">
                                <div class="flex items-center gap-2">
                                    <div class="w-2 h-2 rounded-full animate-pulse
                                        {% if product.isOutOfStock %}bg-red-500
                                        {% elseif product.isLowStock %}bg-amber-500
                                        {% else %}bg-emerald-500{% endif %}"></div>
                                    <span class="text-[10px] sm:text-xs font-bold text-slate-600 uppercase tracking-widest">Product Info</span>
                                </div>
                                <span class="px-2.5 py-1 text-[9px] sm:text-[10px] font-bold rounded-full uppercase shadow-lg
                                    {% if product.isOutOfStock %}bg-gradient-to-r from-red-500 to-red-600 text-white
                                    {% elseif product.isLowStock %}bg-gradient-to-r from-amber-500 to-orange-500 text-white
                                    {% else %}bg-gradient-to-r from-emerald-500 to-teal-500 text-white{% endif %}">
                                    {% if product.isOutOfStock %}Out of Stock
                                    {% elseif product.isLowStock %}Low Stock
                                    {% else %}In Stock{% endif %}
                                </span>
                            </div>
                            
                            <div class="aspect-square bg-slate-100 relative group overflow-hidden">
                                {% if product.image %}
                                <img src="{{ asset('images/products/' ~ product.image) }}" alt="{{ product.name }}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                                {% else %}
                                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-emerald-100 to-teal-200">
                                    <i class="fas fa-box text-emerald-300 text-6xl"></i>
                                </div>
                                {% endif %}
                                
                                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
                                
                                <div class="absolute bottom-4 sm:bottom-6 left-4 sm:left-6 right-4 sm:right-6">
                                    <p class="text-emerald-300 text-[9px] sm:text-[10px] font-bold uppercase tracking-widest mb-1">#{{ product.productCode }}</p>
                                    <h2 class="text-white text-lg sm:text-2xl font-bold leading-tight mb-2 drop-shadow-lg">{{ product.name }}</h2>
                                    <div class="flex gap-2">
                                        <span class="px-2 py-0.5 backdrop-blur-md rounded-full text-white text-[9px] sm:text-[10px] font-semibold border border-emerald-400 bg-emerald-600/90 shadow-lg">{{ product.character.name }}</span>
                                    </div>
                                </div>
                            </div>

                            <div class="p-4 sm:p-6 bg-gradient-to-br from-white to-slate-50">
                                <h4 class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest mb-3 flex items-center gap-2">
                                    <i class="fas fa-warehouse text-emerald-500"></i>
                                    Current Stock
                                </h4>
                                <div class="flex items-baseline gap-2 mb-4">
                                    <p class="text-slate-900 text-3xl sm:text-4xl font-black">{{ product.stockQuantity }}</p>
                                    <span class="text-slate-500 text-sm">units</span>
                                </div>
                                
                                <div class="pt-4 border-t border-slate-200">
                                    <div class="flex justify-between items-center mb-2">
                                        <span class="text-xs text-slate-500">Price</span>
                                        <span class="text-sm font-bold text-emerald-600">{{ product.formattedPrice }}</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Available Stock Inventory -->
                    <div class="lg:col-span-8">
                        <div class="glass-panel rounded-2xl sm:rounded-3xl p-4 sm:p-6 lg:p-8 border border-white/50">
                            
                            <div class="flex items-center gap-3 mb-6">
                                <div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-xl flex items-center justify-center shadow-lg shadow-emerald-200">
                                    <i class="fas fa-layer-group text-white"></i>
                                </div>
                                <h3 class="text-lg sm:text-xl font-bold bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent">Available Stock Inventory</h3>
                            </div>
                            
                            {% if availableStocks is empty %}
                                <div class="text-center py-12 sm:py-16">
                                    <div class="w-20 h-20 bg-gradient-to-br from-slate-100 to-slate-200 rounded-2xl flex items-center justify-center mx-auto mb-4">
                                        <i class="fas fa-inbox text-slate-300 text-4xl"></i>
                                    </div>
                                    <p class="text-slate-900 font-bold text-base sm:text-lg mb-2">No stock inventory available</p>
                                    <p class="text-slate-500 text-sm">Create new stock from the Stock Management page</p>
                                </div>
                            {% else %}
                                <div class="space-y-4">
                                    {% for stock in availableStocks %}
                                        <div class="stock-card">
                                            <div class="flex flex-col sm:flex-row justify-between items-start gap-4 mb-4">
                                                <div class="flex-1">
                                                    <div class="flex items-center gap-2 mb-2">
                                                        <span class="px-2 py-1 bg-indigo-100 text-indigo-600 text-[10px] font-bold rounded uppercase">Stock #{{ stock.id }}</span>
                                                        <span class="px-2 py-1 bg-slate-100 text-slate-600 text-[10px] font-semibold rounded">
                                                            <i class="fas fa-calendar-alt"></i> {{ stock.createdAt|date('M d, Y') }}
                                                        </span>
                                                    </div>
                                                    <div class="flex items-baseline gap-2">
                                                        <p class="text-2xl sm:text-3xl font-black text-slate-900">{{ stock.quantity }}</p>
                                                        <span class="text-slate-500 text-sm font-semibold">units available</span>
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            {% if stock.notes %}
                                                <div class="mb-4 p-3 bg-amber-50 rounded-xl border border-amber-100">
                                                    <div class="flex items-center gap-2 mb-1">
                                                        <i class="fas fa-sticky-note text-amber-500 text-xs"></i>
                                                        <span class="text-[10px] font-bold text-amber-700 uppercase tracking-wider">Notes</span>
                                                    </div>
                                                    <p class="text-sm text-amber-800">{{ stock.notes }}</p>
                                                </div>
                                            {% endif %}
                                            
                                            <form method="post" action="{{ role_path('stock_management_restock_from_stock', {'productId': product.id, 'stockId': stock.id}) }}" class="flex flex-col sm:flex-row gap-3">
                                                <input type="hidden" name="_token" value="{{ csrf_token('restock_' ~ stock.id) }}">
                                                
                                                <div class="flex-1">
                                                    <label class="block text-xs font-bold text-slate-700 mb-2">
                                                        <i class="fas fa-sort-numeric-up text-emerald-500"></i> Quantity to Restock
                                                    </label>
                                                    <input type="number" name="quantity" value="{{ stock.quantity }}" min="1" max="{{ stock.quantity }}" 
                                                           class="form-input-styled" required>
                                                </div>
                                                
                                                <div class="flex items-end">
                                                    <button type="submit" class="w-full sm:w-auto px-6 py-3 bg-gradient-to-r from-emerald-600 to-teal-600 text-white font-bold rounded-xl hover:shadow-2xl transition-all flex items-center justify-center gap-2 shadow-lg">
                                                        <i class="fas fa-plus"></i> Restock
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <!-- PRO TIP Box -->
                        <div class="mt-6 p-3 sm:p-4 bg-amber-50 rounded-2xl border border-amber-100 flex gap-3 sm:gap-4">
                            <div class="text-amber-500 mt-1 text-sm sm:text-base"><i class="fas fa-lightbulb"></i></div>
                            <p class="text-[10px] sm:text-xs text-amber-800 leading-relaxed">
                                <span class="font-bold block mb-1">PRO TIP</span>
                                Restock from available inventory to maintain accurate stock levels. Each restock operation is tracked for audit purposes.
                            </p>
                        </div>
                    </div>
                </div>
                </div>
                <!-- End Main Container -->
            </div>
        </main>
    </div>

 <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
</body>
</html>
