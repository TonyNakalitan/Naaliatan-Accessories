<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Stock Entry | Naaliatan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('StockManagementFolder/create.css') }}">
</head>
<body class="min-h-screen">

    <div class="flex h-screen">
        <main class="flex-grow flex flex-col overflow-y-auto w-full bg-slate-50">
            <div class="w-full p-4 sm:p-6 lg:p-8">

                {% if app.flashes('error') %}
                    <div class="mb-4 sm:mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-800 shadow-sm">
                        {% for message in app.flashes('error') %}
                            <p class="text-sm sm:text-base"><i class="fas fa-exclamation-circle mr-2"></i>{{ message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}

                <!-- Main Container -->
                <div class="bg-gradient-to-br from-white via-indigo-50/30 to-purple-50/30 rounded-2xl sm:rounded-3xl p-4 sm:p-6 lg:p-8 shadow-xl border border-white/50">
                    
                    <!-- Header with Back Button Inside Container -->
                    <div class="mb-6 sm:mb-8 flex flex-col sm:flex-row items-start justify-between gap-4">
                        <div class="flex-1">
                            <div class="flex items-center gap-3 mb-3">
                                <div class="w-10 h-10 sm:w-12 sm:h-12 bg-gradient-to-br from-emerald-600 to-teal-600 rounded-2xl flex items-center justify-center shadow-lg shadow-emerald-200">
                                    <i class="fas fa-plus-circle text-white text-lg sm:text-xl"></i>
                                </div>
                                <h1 class="text-2xl sm:text-3xl font-bold bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent">
                                    Create Stock Entry
                                </h1>
                            </div>
                            <p class="text-slate-600 text-sm sm:text-base">Add new stock for your products.</p>
                        </div>
                        <a href="{{ path('app_admin_stock_management_index') }}" class="w-full sm:w-auto px-4 sm:px-6 py-2.5 sm:py-3 bg-white/80 backdrop-blur-sm text-slate-700 font-semibold rounded-xl hover:bg-white hover:shadow-lg transition-all flex items-center justify-center gap-2 text-sm sm:text-base whitespace-nowrap border border-slate-200">
                            <i class="fas fa-arrow-left"></i>
                            <span class="hidden sm:inline">Back to Stock Management</span>
                            <span class="sm:hidden">Back</span>
                        </a>
                    </div>

                    {{ form_start(form, {'attr': {'id': 'stockForm', 'novalidate': 'novalidate'}}) }}

                <!-- Wizard Wrapper -->
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-start">
                    
                    <div class="lg:col-span-8">
                        <div class="glass-panel rounded-2xl sm:rounded-3xl p-4 sm:p-6 lg:p-8 mb-6 border border-white/50">
                            
                            <div class="flex gap-2 sm:gap-4 mb-8 sm:mb-10 overflow-x-auto pb-2 scrollbar-hide">
                                <div class="step-pill active min-w-[120px] sm:min-w-0" id="pill-1">
                                    <div class="step-number">1</div>
                                    <div>
                                        <span class="text-[10px] sm:text-xs font-bold uppercase tracking-wider">Step 1</span>
                                        <p class="text-xs sm:text-sm font-semibold">Select Product</p>
                                    </div>
                                </div>
                                <div class="step-pill min-w-[120px] sm:min-w-0" id="pill-2">
                                    <div class="step-number">2</div>
                                    <div>
                                        <span class="text-[10px] sm:text-xs font-bold uppercase tracking-wider">Step 2</span>
                                        <p class="text-xs sm:text-sm font-semibold">Quantity & Notes</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 1: Product Selection -->
                            <div class="step-content active fade-in" data-step="1">
                                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-4 sm:mb-6 gap-3">
                                    <h3 class="text-base sm:text-lg font-bold text-slate-900">Choose a Product</h3>
                                    <div class="relative w-full sm:w-64">
                                        <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs sm:text-sm"></i>
                                        <input type="text" id="productSearch" class="w-full pl-9 pr-4 py-2 bg-slate-100 border-none rounded-full text-xs sm:text-sm focus:ring-2 focus:ring-indigo-200" placeholder="Filter products..." onkeyup="filterProducts()">
                                    </div>
                                </div>
                                
                                <div style="display: none;">
                                    {{ form_widget(form.product) }}
                                </div>
                                {{ form_errors(form.product) }}
                                
                                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4" id="productGrid">
                                    {% for product in products %}
                                    <div class="product-card group product-item" data-product-id="{{ product.id }}" data-product-name="{{ product.name|lower }}" onclick="selectProduct(this, {{ product.id }}, '{{ product.name|e('js') }}', '{{ product.productCode|e('js') }}')">
                                        <div class="check-badge"><i class="fas fa-check text-[10px]"></i></div>
                                        <div class="aspect-square bg-slate-100 relative overflow-hidden">
                                            {% if product.image %}
                                            <img src="{{ asset('images/products/' ~ product.image) }}" class="w-full h-full object-cover">
                                            {% else %}
                                            <div class="w-full h-full bg-gradient-to-br from-slate-200 to-slate-300 flex items-center justify-center">
                                                <i class="fas fa-box text-4xl text-slate-400"></i>
                                            </div>
                                            {% endif %}
                                        </div>
                                        <div class="p-3">
                                            <p class="text-sm font-bold text-slate-900 truncate">{{ product.name }}</p>
                                            <p class="text-xs text-slate-500">#{{ product.productCode }}</p>
                                            <p class="text-xs text-slate-600 mt-1">Current: <span class="font-semibold">{{ product.stockQuantity }}</span></p>
                                        </div>
                                    </div>
                                    {% endfor %}
                                </div>
                                
                                <!-- Pagination Controls -->
                                {% if totalPages > 1 %}
                                <div class="mt-6 flex flex-col sm:flex-row items-center justify-between gap-4 p-4 bg-slate-50 rounded-xl border border-slate-200">
                                    <div class="text-sm text-slate-600">
                                        Showing <span class="font-semibold">{{ products|length }}</span> of <span class="font-semibold">{{ totalProducts }}</span> products
                                    </div>
                                    <div class="flex items-center gap-2">
                                        {% if currentPage > 1 %}
                                            <a href="?page={{ currentPage - 1 }}" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors">
                                                <i class="fas fa-chevron-left"></i>
                                            </a>
                                        {% endif %}
                                        
                                        {% for page in 1..totalPages %}
                                            {% if page == currentPage %}
                                                <span class="px-3 py-2 bg-indigo-600 text-white rounded-lg text-sm font-medium">{{ page }}</span>
                                            {% elseif page <= 3 or page >= totalPages - 2 or (page >= currentPage - 1 and page <= currentPage + 1) %}
                                                <a href="?page={{ page }}" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors">{{ page }}</a>
                                            {% elseif page == 4 or page == totalPages - 3 %}
                                                <span class="px-2 text-slate-400">...</span>
                                            {% endif %}
                                        {% endfor %}
                                        
                                        {% if currentPage < totalPages %}
                                            <a href="?page={{ currentPage + 1 }}" class="px-3 py-2 bg-white border border-slate-300 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors">
                                                <i class="fas fa-chevron-right"></i>
                                            </a>
                                        {% endif %}
                                    </div>
                                </div>
                                {% endif %}
                                
                                <!-- PRO TIP for Step 1 -->
                                <div class="mt-6 p-3 sm:p-4 bg-amber-50 rounded-2xl border border-amber-100 flex gap-3 sm:gap-4">
                                    <div class="text-amber-500 mt-1 text-sm sm:text-base"><i class="fas fa-lightbulb"></i></div>
                                    <p class="text-[10px] sm:text-xs text-amber-800 leading-relaxed">
                                        <span class="font-bold block mb-1">PRO TIP</span>
                                        Check the current stock quantity before adding new stock to avoid overstocking.
                                    </p>
                                </div>
                            </div>

                            <!-- Step 2: Quantity & Notes -->
                            <div class="step-content fade-in" data-step="2">
                                <div class="space-y-6 sm:space-y-8">
                                    <div>
                                        <label class="block text-xs sm:text-sm font-bold text-slate-700 mb-2">Quantity to Add</label>
                                        <div class="relative max-w-full sm:max-w-xs">
                                            {{ form_widget(form.quantity, {'attr': {'class': 'form-input-styled text-lg sm:text-xl font-bold tracking-tight', 'placeholder': '0', 'oninput': 'syncPreview("quantity", this.value)'}}) }}
                                        </div>
                                        {{ form_errors(form.quantity) }}
                                        <p class="text-xs text-slate-500 mt-2">Enter the number of units to add to stock</p>
                                    </div>

                                    <div>
                                        <label class="block text-xs sm:text-sm font-bold text-slate-700 mb-2">Notes (Optional)</label>
                                        {{ form_widget(form.notes, {'attr': {'class': 'form-input-styled text-sm sm:text-base', 'rows': '4', 'placeholder': 'Add any notes about this stock entry...', 'oninput': 'syncPreview("notes", this.value)'}}) }}
                                        {{ form_errors(form.notes) }}
                                    </div>
                                </div>
                                
                                <!-- PRO TIP for Step 2 -->
                                <div class="mt-6 p-3 sm:p-4 bg-amber-50 rounded-2xl border border-amber-100 flex gap-3 sm:gap-4">
                                    <div class="text-amber-500 mt-1 text-sm sm:text-base"><i class="fas fa-lightbulb"></i></div>
                                    <p class="text-[10px] sm:text-xs text-amber-800 leading-relaxed">
                                        <span class="font-bold block mb-1">PRO TIP</span>
                                        Add detailed notes to track the source and reason for stock additions for better inventory management.
                                    </p>
                                </div>
                            </div>

                            <div class="mt-8 sm:mt-12 flex flex-col sm:flex-row items-center justify-between gap-3 sm:gap-0">
                                <button type="button" id="prevBtn" onclick="moveStep(-1)" class="w-full sm:w-auto px-6 py-3 text-slate-600 font-bold hover:bg-slate-100 rounded-xl transition-all opacity-0 pointer-events-none text-sm sm:text-base">
                                    <i class="fas fa-arrow-left mr-2"></i> Previous
                                </button>
                                <button type="button" id="nextBtn" onclick="moveStep(1)" class="w-full sm:w-auto px-8 py-3 bg-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-200 hover:bg-indigo-700 hover:-translate-y-0.5 transition-all text-sm sm:text-base">
                                    Next Step <i class="fas fa-arrow-right ml-2"></i>
                                </button>
                                <button type="submit" id="submitBtn" class="w-full sm:w-auto px-8 py-3 bg-emerald-600 text-white font-bold rounded-xl shadow-lg shadow-emerald-200 hover:bg-emerald-700 hover:-translate-y-0.5 transition-all hidden text-sm sm:text-base">
                                    <span id="submitBtnText">Create Stock Entry <i class="fas fa-check ml-2"></i></span>
                                    <span id="submitBtnLoading" class="hidden">
                                        <i class="fas fa-spinner fa-spin mr-2"></i>Creating Entry...
                                    </span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Live Preview Card -->
                    <div class="lg:col-span-4 lg:sticky lg:top-8">
                        <div class="glass-panel rounded-2xl sm:rounded-3xl overflow-hidden border border-white/50 shadow-2xl">
                            <div class="p-3 sm:p-4 border-b border-slate-100 flex items-center justify-between bg-gradient-to-r from-white/80 to-emerald-50/50 backdrop-blur-sm">
                                <div class="flex items-center gap-2">
                                    <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
                                    <span class="text-[10px] sm:text-xs font-bold text-slate-600 uppercase tracking-widest">Stock Entry Preview</span>
                                </div>
                                <span class="px-2.5 py-1 bg-gradient-to-r from-emerald-500 to-teal-500 text-white text-[9px] sm:text-[10px] font-bold rounded-full uppercase shadow-lg">Draft</span>
                            </div>
                            
                            <div class="p-4 sm:p-6 bg-white space-y-4">
                                <div>
                                    <h4 class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Product</h4>
                                    <p id="previewProductName" class="text-slate-900 text-sm sm:text-base font-bold">No product selected</p>
                                    <p id="previewProductCode" class="text-slate-500 text-xs sm:text-sm">#PENDING</p>
                                </div>

                                <div class="border-t border-slate-100 pt-4">
                                    <h4 class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Quantity</h4>
                                    <div class="flex items-baseline gap-2">
                                        <span class="text-slate-400 text-sm">+</span>
                                        <p id="previewQuantity" class="text-emerald-600 text-2xl sm:text-3xl font-black">0</p>
                                        <span class="text-slate-500 text-sm">units</span>
                                    </div>
                                </div>

                                <div class="border-t border-slate-100 pt-4">
                                    <h4 class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Notes</h4>
                                    <p id="previewNotes" class="text-slate-600 text-xs sm:text-sm leading-relaxed italic">
                                        No notes added yet...
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                {{ form_rest(form) }}
                {{ form_end(form) }}
                </div>
                <!-- End Main Container -->
            </div>
        </main>
    </div>

    <script src="{{ asset('StockManagementFolder/create.js') }}"></script>
     <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
</body>
</html>
