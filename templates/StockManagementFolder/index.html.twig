{% extends 'base.html.twig' %}

{% block title %}Stock Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('StockManagementFolder/index.css') }}?v={{ random() }}">
{% endblock %}

{% block body %}
<div id="stock-app-wrapper" class="min-h-screen">

    <!-- App Wrapper -->
    <div id="app" class="relative w-full h-screen glass-container overflow-x-auto flex flex-col">
        
        <!-- Header -->
        <header class="relative z-50 flex items-center justify-between px-10 py-8">
            <div class="flex items-center gap-3">
                <button class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/80 hover:bg-white border border-gray-200 hover:shadow-md transition-all text-gray-700 hover:text-gray-900" id="sidebarToggle" title="Toggle Sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="text-3xl font-bold tracking-tighter text-gray-800">
                    Stock Management
                </span>
            </div>

            <!-- Search bar -->
            <div class="hidden md:flex items-center bg-gray-100/50 rounded-full px-5 py-2 w-72 border border-gray-200">
                <i class="fa fa-search text-gray-400 mr-3"></i>
                <input type="text" id="searchInput" placeholder="Search products..." class="bg-transparent outline-none text-sm w-full">
            </div>

            <div class="flex items-center gap-6">
                <!-- Tab Buttons -->
                <div class="flex items-center gap-2">
                    <button class="tab-btn active px-4 py-2 rounded-lg font-medium text-sm transition-all" data-tab="stock-inventory" id="tab-btn-stock-inventory">
                        <i class="fa fa-warehouse mr-1"></i> Stock Inventory
                    </button>
                    <button class="tab-btn px-4 py-2 rounded-lg font-medium text-sm transition-all" data-tab="products-view" id="tab-btn-products-view">
                        <i class="fa fa-boxes mr-1"></i> Products
                    </button>
                </div>

                <!-- Filter Dropdown (for products view) -->
                <div class="relative" id="stockFilterWrapper">
                    <select id="stockFilter" class="bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all font-medium cursor-pointer">
                        <option value="all">All Products</option>
                        <option value="in-use">Product In Use</option>
                        <option value="low-stock">Low Stock Product</option>
                        <option value="out-stock">No Stock Product</option>
                    </select>
                </div>
                
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ role_path('stock_management_create') }}" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors font-medium">
                        <i class="fa fa-plus mr-2"></i>Add Stock
                    </a>
                {% endif %}
                <a href="{{ is_granted('ROLE_ADMIN') ? path('app_admin_profile_edit') : path('app_staff_profile_edit') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors">
                    {% if app.user.profilePicture %}
                        <img src="{{ app.user.profilePicture|image_url('images/profiles') }}" alt="Profile" class="w-10 h-10 rounded-full object-cover border-2 border-white shadow-md">
                    {% else %}
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 text-white font-bold text-sm">
                            {% set displayText = app.user.displayName ?: app.user.username %}
                            {% set words = displayText|split(' ') %}
                            {% if words|length > 1 %}
                                {{ words[0]|slice(0, 1)|upper }}{{ words[1]|slice(0, 1)|upper }}
                            {% else %}
                                {{ displayText|slice(0, 2)|upper }}
                            {% endif %}
                        </div>
                    {% endif %}
                    <div class="flex flex-col items-start">
                        <span class="font-semibold text-gray-800 text-sm">{{ app.user.displayName ?: app.user.username }}</span>
                        <span class="text-xs text-gray-500">{{ is_granted('ROLE_ADMIN') ? 'Admin' : 'Staff' }}</span>
                    </div>
                </a>
            </div>
        </header>

        <!-- Viewport -->
        <main class="relative flex-1 overflow-x-auto">

            <!-- STOCK INVENTORY TAB -->
            <div id="stock-inventory" class="si-panel absolute inset-0 overflow-y-auto" style="display:none;">

                <!-- Flash Messages -->
                {% if app.flashes('success') %}
                    <div class="si-flash si-flash-success">
                        {% for msg in app.flashes('success') %}
                            <i class="fas fa-check-circle"></i> {{ msg }}
                        {% endfor %}
                    </div>
                {% endif %}
                {% if app.flashes('error') %}
                    <div class="si-flash si-flash-error">
                        {% for msg in app.flashes('error') %}
                            <i class="fas fa-exclamation-circle"></i> {{ msg }}
                        {% endfor %}
                    </div>
                {% endif %}

                <!-- Page Header -->
                <div class="si-page-header">
                    <div class="si-header-left">
                        <div class="si-header-icon">
                            <i class="fas fa-warehouse"></i>
                        </div>
                        <div>
                            <h1 class="si-header-title">Stock Inventory</h1>
                            <p class="si-header-sub">All available stock entries ready for restocking</p>
                        </div>
                    </div>
                    <div class="si-stats-row">
                        <div class="si-stat-pill">
                            <span class="si-stat-num">{{ stocks|length }}</span>
                            <span class="si-stat-label">Total Entries</span>
                        </div>
                        <div class="si-stat-pill si-stat-green">
                            <span class="si-stat-num">{{ stocks|reduce((sum, s) => sum + s.quantity, 0) }}</span>
                            <span class="si-stat-label">Total Units</span>
                        </div>
                        <div class="si-stat-pill si-stat-blue">
                            {% set uniqueProducts = [] %}
                            {% for stock in stocks %}{% if stock.product.id not in uniqueProducts %}{% set uniqueProducts = uniqueProducts|merge([stock.product.id]) %}{% endif %}{% endfor %}
                            <span class="si-stat-num">{{ uniqueProducts|length }}</span>
                            <span class="si-stat-label">Products</span>
                        </div>
                    </div>
                </div>



                <!-- Cards Grid -->
                {% if stocks is empty %}
                    <div class="si-empty">
                        <div class="si-empty-icon"><i class="fas fa-box-open"></i></div>
                        <h3>No Stock Entries Yet</h3>
                        <p>Create your first stock entry to get started.</p>
                    </div>
                {% else %}
                    <div class="si-grid" id="siGrid">
                        {% for stock in stocks %}
                            <div class="si-card" data-name="{{ stock.product.name|lower }}" data-code="{{ stock.product.productCode|lower }}">

                                <!-- Card Top: Image + Badge -->
                                <div class="si-card-top">
                                    {% if stock.product.image %}
                                        <img src="{{ stock.product.image|image_url('images/products') }}" alt="{{ stock.product.name }}" class="si-card-img">
                                    {% else %}
                                        <div class="si-card-img-placeholder">
                                            <i class="fas fa-box"></i>
                                        </div>
                                    {% endif %}
                                    <span class="si-entry-badge">#{{ stock.id }}</span>
                                    {% set qty = stock.quantity %}
                                    {% if qty == 0 %}
                                        <span class="si-qty-badge si-qty-out">Out</span>
                                    {% elseif qty < 10 %}
                                        <span class="si-qty-badge si-qty-low">Low</span>
                                    {% else %}
                                        <span class="si-qty-badge si-qty-ok">Ready</span>
                                    {% endif %}
                                </div>

                                <!-- Card Body -->
                                <div class="si-card-body">
                                    <div class="si-card-product">
                                        <h3 class="si-product-name">{{ stock.product.name }}</h3>
                                        <span class="si-product-code">#{{ stock.product.productCode }}</span>
                                    </div>

                                    <div class="si-quantity-display">
                                        <span class="si-qty-number">{{ stock.quantity }}</span>
                                        <span class="si-qty-unit">units</span>
                                    </div>

                                    {% if stock.notes %}
                                        <div class="si-notes">
                                            <i class="fas fa-sticky-note"></i>
                                            <span>{{ stock.notes|length > 60 ? stock.notes|slice(0, 60) ~ '…' : stock.notes }}</span>
                                        </div>
                                    {% endif %}

                                    <div class="si-meta">
                                        <span class="si-meta-item">
                                            <i class="fas fa-calendar-alt"></i>
                                            {{ stock.createdAt|date('M d, Y') }}
                                        </span>
                                        {% if stock.createdBy %}
                                            <span class="si-meta-item">
                                                <i class="fas fa-user"></i>
                                                {{ stock.createdBy.displayName ?: stock.createdBy.username }}
                                            </span>
                                        {% endif %}
                                    </div>

                                    <div class="si-card-actions">
                                        <a href="{{ role_path('stock_management_restock', {'id': stock.product.id}) }}" class="si-btn-restock">
                                            <i class="fas fa-arrow-up"></i> Restock
                                        </a>
                                        {% if is_granted('ROLE_ADMIN') %}
                                            <form method="post" action="{{ role_path('stock_management_delete_stock', {'id': stock.id}) }}" onsubmit="return confirm('Delete this stock entry?')">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_stock_' ~ stock.id) }}">
                                                <button type="submit" class="si-btn-delete">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    <div class="si-no-results" id="siNoResults" style="display:none;">
                        <i class="fas fa-search"></i>
                        <p>No entries match your search.</p>
                    </div>
                {% endif %}
            </div>

            <!-- PRODUCTS TAB (Carousel) -->
            <div id="products-view" class="tab-content absolute inset-0 flex flex-col justify-end px-12 transition-all duration-500 pb-8">
            
            <!-- GRID VIEW (The Carousel) -->
            <div id="gridView" class="grid-view flex flex-col justify-end h-full transition-all duration-500">
                
                <!-- Carousel at bottom -->
                <div id="productCarousel" class="flex gap-8 items-end h-[500px] mb-6">
                    <!-- Cards injected by JS -->
                </div>

                <!-- Footer Nav -->
                <div class="flex items-center justify-between pt-4 pb-2">
                    <div class="flex gap-6 text-sm font-medium text-gray-500">
                        <span>Total Products: <span id="totalCount">{{ products|length }}</span></span>
                        <span>Low Stock: <span class="text-amber-600 font-bold">{{ lowStockProducts|length }}</span></span>
                        <span>In Stock: <span class="text-emerald-600 font-bold">{{ products|filter(p => p.stockQuantity > 0)|length }}</span></span>
                    </div>
                    <div class="flex gap-4">
                        <button onclick="prevSlide()" id="prevBtn" class="flex items-center gap-2 font-bold text-gray-800 hover:opacity-70 transition-opacity disabled:opacity-30 disabled:cursor-not-allowed">
                            <i class="fa fa-chevron-left text-xs"></i> Prev
                        </button>
                        <button onclick="nextSlide()" id="nextBtn" class="flex items-center gap-2 font-bold text-gray-800 hover:opacity-70 transition-opacity disabled:opacity-30 disabled:cursor-not-allowed">
                            Next <i class="fa fa-chevron-right text-xs"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- DETAIL / HERO VIEW -->
            <div id="heroView" class="hero-view absolute inset-0 z-40 bg-white">
                <div id="heroBg" class="absolute inset-0 w-1/2 rounded-r-[80px] transition-colors duration-700"></div>
                
                <button onclick="closeHero()" class="absolute top-8 right-10 z-50 flex items-center gap-2 font-bold text-gray-800 hover:scale-105 transition-transform">
                    <i class="fa fa-times text-red-500"></i> Close
                </button>

                <div class="relative z-10 h-full flex items-center px-16">
                    <!-- Left Side: Large Image with Frame -->
                    <div class="w-1/2 flex justify-center items-center">
                        <div class="hero-image-frame">
                            <img id="heroImage" src="" alt="" class="hero-image">
                        </div>
                    </div>

                    <!-- Right Side: Content -->
                    <div class="w-1/2 pl-12 pr-8">
                        <div class="hero-content-wrapper">
                            <h2 id="heroName" class="hero-title slide-in" style="animation-delay: 0.1s"></h2>
                            
                            <div class="hero-meta-section slide-in" style="animation-delay: 0.2s">
                                <div class="meta-item">
                                    <i class="fa fa-tag text-blue-500"></i>
                                    <span class="meta-label">Price:</span>
                                    <span id="heroPrice" class="meta-value"></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fa fa-boxes text-purple-500"></i>
                                    <span class="meta-label">Stock:</span>
                                    <span id="heroStock" class="stock-badge"></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fa fa-user-ninja text-emerald-500"></i>
                                    <span class="meta-label">Character:</span>
                                    <span id="heroCharacter" class="meta-value"></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fa fa-barcode text-amber-500"></i>
                                    <span class="meta-label">Code:</span>
                                    <span id="heroCode" class="meta-value"></span>
                                </div>
                            </div>
                            
                            <div class="hero-description-section slide-in" style="animation-delay: 0.3s">
                                <h3 class="description-title">Description</h3>
                                <p id="heroDesc" class="description-text"></p>
                            </div>

                            <div class="hero-actions slide-in" style="animation-delay: 0.4s">
                                <a id="heroRestockBtn" href="#" class="action-btn action-btn-primary">
                                    <i class="fa fa-plus"></i>
                                    <span>Restock</span>
                                </a>
                                <a id="heroStoreBtn" href="#" class="action-btn action-btn-store">
                                    <i class="fa fa-archive"></i>
                                    <span>Store</span>
                                </a>
                                <a id="heroViewBtn" href="#" class="action-btn action-btn-secondary">
                                    <i class="fa fa-eye"></i>
                                    <span>View Details</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            </div><!-- end gridView -->
            </div><!-- end products-view -->
        </main>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
    <script>
        // Load products from Symfony
        const allProductsData = [
            {% for product in products %}
            {
                id: {{ product.id }},
                name: {{ product.name|json_encode|raw }},
                price: {{ product.price }},
                stockQuantity: {{ product.stockQuantity }},
                productCode: {{ product.productCode|json_encode|raw }},
                image: {{ product.image|json_encode|raw }},
                description: {{ product.description|json_encode|raw }},
                character: {{ product.character.name|json_encode|raw }},
                colorCode: {{ product.character.colorCode|json_encode|raw }}
            }{% if not loop.last %},{% endif %}
            {% endfor %}
        ];
        
        const isAdmin = {{ is_granted('ROLE_ADMIN') ? 'true' : 'false' }};
        const baseUrl = '{{ app.request.schemeAndHttpHost }}';
        const imageBasePath = '{{ asset('images/products/') }}';
        const restockBasePath = isAdmin ? '/admin/stock-management/restock/' : '/staff/stock-management/restock/';
        const storeBasePath = isAdmin ? '/admin/stock-management/store/' : '/staff/stock-management/store/';
        const viewBasePath = isAdmin ? '/admin/products/' : '/staff/products/';
        
        console.log('Total products loaded:', allProductsData.length);
        
        // Transform products to match the expected format
        let products = allProductsData.map(prod => ({
            id: prod.id,
            name: prod.name || 'Unknown',
            price: prod.price || 0,
            stockQuantity: prod.stockQuantity || 0,
            productCode: prod.productCode || 'N/A',
            image: prod.image ? imageBasePath + prod.image : 'https://via.placeholder.com/400x600?text=' + encodeURIComponent(prod.name || 'Product'),
            description: prod.description || 'No description available.',
            character: prod.character || 'Unknown',
            colorCode: prod.colorCode || '#6c757d'
        }));
        
        let filteredProducts = [...products];
        
        console.log('Processed products:', products);

        let currentIndex = 0;
        function getVisibleCount() {
            if (window.innerWidth < 768) return 1;
            if (window.innerWidth < 1024) return 2;
            return 3;
        }

        // Helper function to lighten/darken colors
        function adjustColor(color, amount) {
            const num = parseInt(color.replace("#",""), 16);
            const r = Math.min(255, Math.max(0, (num >> 16) + amount));
            const g = Math.min(255, Math.max(0, ((num >> 8) & 0x00FF) + amount));
            const b = Math.min(255, Math.max(0, (num & 0x0000FF) + amount));
            return "#" + ((r << 16) | (g << 8) | b).toString(16).padStart(6, '0');
        }

        function getStockStatus(quantity) {
            if (quantity === 0) return { text: 'Out of Stock', class: 'stock-critical' };
            if (quantity < 10) return { text: 'Low Stock', class: 'stock-low' };
            return { text: 'In Stock', class: 'stock-good' };
        }

        function renderCarousel() {
            const container = document.getElementById('productCarousel');
            container.innerHTML = '';
            
            if (!filteredProducts || filteredProducts.length === 0) {
                container.innerHTML = '<div class="w-full text-center text-gray-500 text-xl py-20">No products found.</div>';
                updateNavigationButtons();
                return;
            }

            const displayed = filteredProducts.slice(currentIndex, currentIndex + getVisibleCount());

            displayed.forEach((prod, index) => {
                const colorLight = adjustColor(prod.colorCode, 30);
                const colorDark = adjustColor(prod.colorCode, -30);
                const stockStatus = getStockStatus(prod.stockQuantity);
                
                const card = document.createElement('div');
                card.className = `product-card relative w-1/3 h-full rounded-[40px] flex flex-col justify-end p-8 cursor-pointer group`;
                card.style.cssText = `--prod-color-light: ${colorLight}; --prod-color-dark: ${colorDark}; background: linear-gradient(180deg, ${colorLight} 0%, ${colorDark} 100%);`;
                card.setAttribute('data-color', prod.colorCode);
                
                card.innerHTML = `
                    <div class="product-image-wrapper">
                        <img src="${prod.image}" alt="${prod.name}" onerror="this.src='https://via.placeholder.com/300x400?text=${encodeURIComponent(prod.name)}'">
                    </div>
                    <div class="relative z-10 pt-8">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="stock-indicator ${stockStatus.class}">${stockStatus.text}</span>
                            <span class="text-white/70 text-xs">• ${prod.stockQuantity} units</span>
                        </div>
                        <h3 class="text-4xl font-bold text-white mb-1">${prod.name}</h3>
                        <p class="text-white/70 text-sm mb-2">₱${parseFloat(prod.price).toFixed(2)}</p>
                        <p class="text-white/60 text-xs mb-4">${prod.character}</p>
                        <button class="bg-white/20 backdrop-blur-md text-white text-xs font-bold px-4 py-2 rounded-lg uppercase tracking-wider transition-all">
                            View Details >
                        </button>
                    </div>
                `;
                card.onclick = () => openHero(prod);
                container.appendChild(card);
            });
            
            updateNavigationButtons();
        }
        
        function updateNavigationButtons() {
            const prevBtn = document.getElementById('prevBtn');
            const nextBtn = document.getElementById('nextBtn');
            
            if (prevBtn && nextBtn) {
                prevBtn.disabled = currentIndex === 0;
                nextBtn.disabled = currentIndex + getVisibleCount() >= filteredProducts.length;
            }
        }

        function nextSlide() {
            if (currentIndex + getVisibleCount() < filteredProducts.length) {
                currentIndex++;
                renderCarousel();
            }
        }

        function prevSlide() {
            if (currentIndex > 0) {
                currentIndex--;
                renderCarousel();
            }
        }
        
        // Filter functionality
        function applyFilters() {
            const searchTerm = document.getElementById('searchInput')?.value.toLowerCase() || '';
            const filterValue = document.getElementById('stockFilter')?.value || 'all';
            
            filteredProducts = products.filter(prod => {
                // Apply search filter
                const matchesSearch = !searchTerm || 
                    prod.name.toLowerCase().includes(searchTerm) ||
                    prod.character.toLowerCase().includes(searchTerm) ||
                    prod.productCode.toLowerCase().includes(searchTerm);
                
                // Apply stock filter
                let matchesFilter = true;
                if (filterValue === 'in-use') {
                    matchesFilter = prod.stockQuantity > 0;
                } else if (filterValue === 'low-stock') {
                    matchesFilter = prod.stockQuantity > 0 && prod.stockQuantity < 10;
                } else if (filterValue === 'out-stock') {
                    matchesFilter = prod.stockQuantity === 0;
                }
                
                return matchesSearch && matchesFilter;
            });
            
            currentIndex = 0;
            const totalCountEl = document.getElementById('totalCount');
            if (totalCountEl) {
                totalCountEl.textContent = filteredProducts.length;
            }
            renderCarousel();
        }
        
        // Search functionality
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.addEventListener('input', applyFilters);
        }
        
        // Stock filter functionality
        const stockFilter = document.getElementById('stockFilter');
        if (stockFilter) {
            stockFilter.addEventListener('change', applyFilters);
        }

        let currentProduct = null;
        
        function openHero(prod) {
            currentProduct = prod;
            const app = document.getElementById('app');
            const heroBg = document.getElementById('heroBg');
            const heroImage = document.getElementById('heroImage');
            const heroName = document.getElementById('heroName');
            const heroPrice = document.getElementById('heroPrice');
            const heroStock = document.getElementById('heroStock');
            const heroCharacter = document.getElementById('heroCharacter');
            const heroCode = document.getElementById('heroCode');
            const heroDesc = document.getElementById('heroDesc');

            // Set content
            const colorLight = adjustColor(prod.colorCode, 30);
            const colorDark = adjustColor(prod.colorCode, -30);
            heroBg.style.background = `linear-gradient(180deg, ${colorLight} 0%, ${colorDark} 100%)`;
            
            heroImage.src = prod.image;
            heroImage.onerror = function() {
                this.src = 'https://via.placeholder.com/400x600?text=' + encodeURIComponent(prod.name);
            };
            
            heroName.innerText = prod.name;
            heroPrice.innerText = '₱' + parseFloat(prod.price).toFixed(2);
            
            const stockStatus = getStockStatus(prod.stockQuantity);
            heroStock.innerText = `${prod.stockQuantity} units`;
            heroStock.className = `stock-badge ${stockStatus.class}`;
            
            heroCharacter.innerText = prod.character;
            heroCode.innerText = prod.productCode;
            heroDesc.innerText = prod.description;
            
            // Update action buttons
            const restockBtn = document.getElementById('heroRestockBtn');
            const storeBtn = document.getElementById('heroStoreBtn');
            const viewBtn = document.getElementById('heroViewBtn');
            
            if (restockBtn) {
                restockBtn.href = restockBasePath + prod.id;
            }
            
            if (storeBtn) {
                storeBtn.href = storeBasePath + prod.id;
            }
            
            if (viewBtn) {
                viewBtn.href = viewBasePath + prod.id;
            }

            // Trigger animation
            app.classList.add('hero-active');
            
            // Reset text animations
            const animatedElements = document.querySelectorAll('.slide-in');
            animatedElements.forEach(el => {
                el.style.animation = 'none';
                el.offsetHeight; // trigger reflow
                el.style.animation = null;
            });
        }

        function closeHero() {
            document.getElementById('app').classList.remove('hero-active');
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM loaded, rendering carousel...');
            
            // Tab switching
            const tabBtns = document.querySelectorAll('.tab-btn[data-tab]');
            const stockInventoryTab = document.getElementById('stock-inventory');
            const productsViewTab = document.getElementById('products-view');
            const stockFilterWrapper = document.getElementById('stockFilterWrapper');

            function activateTab(tabId) {
                tabBtns.forEach(b => {
                    b.classList.remove('active', 'bg-blue-600', 'text-white');
                    b.classList.add('bg-gray-100', 'text-gray-600');
                });
                const activeBtn = document.querySelector(`.tab-btn[data-tab="${tabId}"]`);
                if (activeBtn) {
                    activeBtn.classList.add('active', 'bg-blue-600', 'text-white');
                    activeBtn.classList.remove('bg-gray-100', 'text-gray-600');
                }

                if (tabId === 'stock-inventory') {
                    stockInventoryTab.style.display = 'block';
                    productsViewTab.style.display = 'none';
                    if (stockFilterWrapper) stockFilterWrapper.style.display = 'none';
                } else {
                    stockInventoryTab.style.display = 'none';
                    productsViewTab.style.display = 'flex';
                    if (stockFilterWrapper) stockFilterWrapper.style.display = '';
                    renderCarousel();
                }
            }

            tabBtns.forEach(btn => {
                btn.addEventListener('click', () => activateTab(btn.getAttribute('data-tab')));
            });

            // Stock inventory live search
            const siSearch = document.getElementById('siSearch');
            if (siSearch) {
                siSearch.addEventListener('input', function() {
                    const term = this.value.toLowerCase().trim();
                    const cards = document.querySelectorAll('.si-card');
                    let visible = 0;
                    cards.forEach(card => {
                        const name = card.dataset.name || '';
                        const code = card.dataset.code || '';
                        const match = !term || name.includes(term) || code.includes(term);
                        card.style.display = match ? '' : 'none';
                        if (match) visible++;
                    });
                    const noResults = document.getElementById('siNoResults');
                    if (noResults) noResults.style.display = visible === 0 ? 'flex' : 'none';
                });
            }

            // Check URL param to auto-activate tab
            const urlParams = new URLSearchParams(window.location.search);
            const tabParam = urlParams.get('tab');
            if (tabParam === 'stock-inventory') {
                activateTab('stock-inventory');
            } else {
                activateTab('products-view');
            }
            
            window.addEventListener('resize', function() { renderCarousel(); });
            
            // Sidebar toggle functionality
            const sidebarToggle = document.getElementById('sidebarToggle');
            const sidebar = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');
            
            if (sidebarToggle && sidebar && sidebarOverlay) {
                sidebarToggle.addEventListener('click', function() {
                    sidebar.classList.toggle('active');
                    sidebarOverlay.classList.toggle('active');
                });
                
                sidebarOverlay.addEventListener('click', function() {
                    sidebar.classList.remove('active');
                    sidebarOverlay.classList.remove('active');
                });
            }
        });
    </script>
{% endblock %}
