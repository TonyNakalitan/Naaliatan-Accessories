{% extends 'base.html.twig' %}

{% block title %}Stock Management | Naaliatan{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('StockManagementFolder/index.css?v=' ~ random()) }}">
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css">
{% endblock %}

{% block body %}
    <main class="content-area">
        <header class="top-nav">
            <div class="search-global">
                <i class="fas fa-search"></i>
                <input type="text" id="globalSearch" placeholder="Search stock inventory...">
            </div>
            <div class="user-widget">
                <button class="icon-btn"><i class="fas fa-bell"></i></button>
                <div class="avatar">
                    {% if app.user.profilePicture %}
                        <img src="{{ asset('images/profiles/' ~ app.user.profilePicture) }}" alt="{{ app.user.displayName ?: app.user.username }}">
                    {% else %}
                        {{ (app.user.displayName ?: app.user.username)|default('A')|slice(0,1)|upper }}
                    {% endif %}
                </div>
                <div class="user-info">
                    <p class="user-name">{{ app.user.displayName ?: app.user.username }}</p>
                    <p class="user-role">{{ is_granted('ROLE_ADMIN') ? 'Admin' : 'Staff' }}</p>
                </div>
            </div>
        </header>

        <div class="page-container">
            <div class="page-intro">
                <div>
                    <h1 class="page-title">Stock Management</h1>
                    <p class="page-subtitle">Real-time oversight of inventory, stock levels, and tracking</p>
                </div>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}

            <div class="stats-grid">
                <div class="stat-card stat-card-blue">
                    <div class="stat-icon">
                        <i class="fas fa-warehouse"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Stock Entries</h3>
                        <p class="value">{{ stocks|length }}</p>
                        <span class="stat-badge">Records</span>
                    </div>
                </div>

                <div class="stat-card stat-card-purple">
                    <div class="stat-icon">
                        <i class="fas fa-box"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Tracked Products</h3>
                        <p class="value">{{ products|length }}</p>
                        <span class="stat-badge">Catalog</span>
                    </div>
                </div>

                <div class="stat-card stat-card-emerald">
                    <div class="stat-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="stat-info">
                        <h3>In Stock</h3>
                        <p class="value">{{ products|filter(p => p.stockQuantity > 0)|length }}</p>
                        <span class="stat-badge">Available</span>
                    </div>
                </div>

                <div class="stat-card stat-card-amber">
                    <div class="stat-icon">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Low Stock</h3>
                        <p class="value">{{ lowStockProducts|length }}</p>
                        <span class="stat-badge">Alert</span>
                    </div>
                </div>
            </div>

            <div class="data-panel">
                <div class="panel-header">
                    <div class="panel-title-wrapper">
                        <div class="panel-icon">
                            <i class="fas fa-warehouse"></i>
                        </div>
                        <span class="panel-title">Stock Inventory</span>
                    </div>
                    <div class="badge-group">
                        {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ role_path('stock_management_create') }}" class="btn-add-stock">
                            <i class="fas fa-plus"></i>
                            New Stock Entry
                        </a>
                        {% endif %}
                        <button class="tab-btn active" data-tab="stock-inventory">
                            <i class="fas fa-warehouse"></i>
                            Stock Entries
                        </button>
                        <button class="tab-btn" data-tab="low-stock">
                            <i class="fas fa-exclamation-triangle"></i>
                            Low Stock
                        </button>
                    </div>
                </div>

                <div class="tab-content active" id="stock-inventory">
                    <div class="table-container">
                        <table id="stockInventoryTable" class="stock-table">
                            <thead>
                                <tr>
                                    <th>Stock ID</th>
                                    <th>Product</th>
                                    <th>Character</th>
                                    <th>Quantity</th>
                                    <th>Notes</th>
                                    <th>Created Date</th>
                                    <th>Created By</th>
                                    <th class="action-column">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="stockTableBody">
                                {% for stock in stocks %}
                                    <tr>
                                        <td><strong>#{{ stock.id }}</strong></td>
                                        <td>
                                            <div class="product-cell">
                                                <div class="product-image">
                                                    {% if stock.product.image %}
                                                        <img src="{{ asset('images/products/' ~ stock.product.image) }}" alt="{{ stock.product.name }}">
                                                    {% else %}
                                                        <i class="fas fa-box"></i>
                                                    {% endif %}
                                                </div>
                                                <div class="product-details">
                                                    <span class="product-name">{{ stock.product.name }}</span>
                                                    <span class="product-code">#{{ stock.product.productCode }}</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="character-badge">
                                                <i class="fas fa-user-ninja"></i>
                                                {{ stock.product.character.name }}
                                            </span>
                                        </td>
                                        <td><strong class="quantity-text">{{ stock.quantity }} units</strong></td>
                                        <td><span class="notes-text">{{ stock.notes ?: 'No notes' }}</span></td>
                                        <td>{{ stock.createdAt|date('M d, Y H:i') }}</td>
                                        <td>{{ stock.createdBy ? stock.createdBy.username : 'System' }}</td>
                                        <td>
                                            <div class="action-buttons">
                                                {% if isAdmin %}
                                                    <form method="post" action="{{ role_path('stock_management_delete_stock', {'id': stock.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this stock entry?');">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_stock_' ~ stock.id) }}">
                                                        <button type="submit" class="btn-action btn-delete" title="Delete">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                {% endif %}
                                            </div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="8" class="empty-state">
                                            <i class="fas fa-warehouse"></i>
                                            <p>No stock entries found</p>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-content" id="low-stock">
                    <div class="table-container">
                        <table id="lowStockTable" class="stock-table">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Character</th>
                                    <th>Price</th>
                                    <th>Current Stock</th>
                                    <th>Status</th>
                                    <th>Priority</th>
                                    <th class="action-column">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="lowStockTableBody">
                                {% for product in lowStockProducts %}
                                    <tr>
                                        <td>
                                            <div class="product-cell">
                                                <div class="product-image">
                                                    {% if product.image %}
                                                        <img src="{{ asset('images/products/' ~ product.image) }}" alt="{{ product.name }}">
                                                    {% else %}
                                                        <i class="fas fa-box"></i>
                                                    {% endif %}
                                                </div>
                                                <div class="product-details">
                                                    <span class="product-name">{{ product.name }}</span>
                                                    <span class="product-code">#{{ product.productCode }}</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="character-badge">
                                                <i class="fas fa-user-ninja"></i>
                                                {{ product.character.name }}
                                            </span>
                                        </td>
                                        <td><strong class="price-text">₱{{ product.price|number_format(2, '.', ',') }}</strong></td>
                                        <td>
                                            <strong class="stock-qty {% if product.stockQuantity == 0 %}stock-critical{% else %}stock-low{% endif %}">
                                                {{ product.stockQuantity }} units
                                            </strong>
                                        </td>
                                        <td>
                                            {% if product.stockQuantity == 0 %}
                                                <span class="status-badge status-out-stock">
                                                    <i class="fas fa-circle"></i>
                                                    Out of Stock
                                                </span>
                                            {% else %}
                                                <span class="status-badge status-low-stock">
                                                    <i class="fas fa-circle"></i>
                                                    Low Stock
                                                </span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if product.stockQuantity == 0 %}
                                                <span class="priority-badge priority-critical">
                                                    <i class="fas fa-exclamation-circle"></i>
                                                    Critical
                                                </span>
                                            {% elseif product.stockQuantity < 5 %}
                                                <span class="priority-badge priority-high">
                                                    <i class="fas fa-arrow-up"></i>
                                                    High
                                                </span>
                                            {% else %}
                                                <span class="priority-badge priority-medium">
                                                    <i class="fas fa-minus"></i>
                                                    Medium
                                                </span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <div class="action-buttons">
                                                <a href="{{ role_path('stock_management_restock', {'id': product.id}) }}" class="btn-action btn-restock" title="Restock">
                                                    <i class="fas fa-plus"></i>
                                                </a>
                                                <a href="{{ role_path('product_management_show', {'id': product.id}) }}" class="btn-action btn-view" title="View">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="7" class="empty-state">
                                            <i class="fas fa-check-circle"></i>
                                            <p>No low stock products</p>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.3.7/js/dataTables.min.js"></script>
    <script src="{{ asset('StockManagementFolder/index.js') }}"></script>
     <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
{% endblock %}
