<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Store {{ product.name }} | Naaliatan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('StockManagementFolder/store.css?v=' ~ random()) }}">
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
</head>
<body class="min-h-screen">

    <div class="flex h-screen">
        <main class="flex-grow flex flex-col overflow-y-auto w-full bg-slate-50">
            <div class="w-full p-4 sm:p-6 lg:p-8">

                {% if app.flashes('success') %}
                    <div class="mb-4 sm:mb-6 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-800 shadow-sm">
                        {% for message in app.flashes('success') %}
                            <p class="text-sm sm:text-base"><i class="fas fa-check-circle mr-2"></i>{{ message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if app.flashes('error') %}
                    <div class="mb-4 sm:mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-800 shadow-sm">
                        {% for message in app.flashes('error') %}
                            <p class="text-sm sm:text-base"><i class="fas fa-exclamation-circle mr-2"></i>{{ message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}

                <!-- Main Container -->
                <div class="main-container fade-in">
                    
                    <!-- Header with Back Button -->
                    <div class="header-section">
                        <div class="header-content">
                            <div class="header-title">
                                <div class="header-icon">
                                    <i class="fas fa-archive"></i>
                                </div>
                                <h1>Store Stock</h1>
                            </div>
                            <p class="header-subtitle">Restore stock from inventory to {{ product.name }}</p>
                        </div>
                        <a href="{{ role_path('stock_management_index') }}" class="back-btn">
                            <i class="fas fa-arrow-left"></i>
                            <span class="hidden sm:inline">Back to Stock Management</span>
                            <span class="sm:hidden">Back</span>
                        </a>
                    </div>

                <!-- Content Grid -->
                <div class="content-grid">
                    
                    <!-- Left Column: Product Info -->
                    <div class="product-info-panel">
                        <div class="glass-panel">
                            <div class="product-panel-header">
                                <div class="product-panel-title">
                                    <div class="status-indicator
                                        {% if product.isOutOfStock %}out-stock
                                        {% elseif product.isLowStock %}low-stock
                                        {% else %}in-stock{% endif %}"></div>
                                    <span class="panel-title-text">Product Info</span>
                                </div>
                                <span class="status-badge
                                    {% if product.isOutOfStock %}out-stock
                                    {% elseif product.isLowStock %}low-stock
                                    {% else %}in-stock{% endif %}">
                                    {% if product.isOutOfStock %}Out of Stock
                                    {% elseif product.isLowStock %}Low Stock
                                    {% else %}In Stock{% endif %}
                                </span>
                            </div>
                            
                            <div class="product-image-section">
                                {% if product.image %}
                                <img src="{{ asset('images/products/' ~ product.image) }}" alt="{{ product.name }}">
                                {% else %}
                                <div class="product-image-placeholder">
                                    <i class="fas fa-box"></i>
                                </div>
                                {% endif %}
                                
                                <div class="product-image-overlay"></div>
                                
                                <div class="product-image-info">
                                    <p class="product-code">#{{ product.productCode }}</p>
                                    <h2 class="product-name">{{ product.name }}</h2>
                                    <div class="product-character">{{ product.character.name }}</div>
                                </div>
                            </div>

                            <div class="product-details">
                                <h4 class="flex items-center gap-2">
                                    <i class="fas fa-warehouse text-emerald-500"></i>
                                    Current Stock
                                </h4>
                                <div class="stock-quantity">
                                    <p class="value">{{ product.stockQuantity }}</p>
                                    <span class="unit">units</span>
                                </div>
                                
                                <div class="product-meta">
                                    <div class="meta-item">
                                        <span class="meta-label">Price</span>
                                        <span class="meta-value">{{ product.formattedPrice }}</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Store Form -->
                    <div class="store-form-panel glass-panel">
                        
                        <div class="form-header">
                            <div class="form-icon">
                                <i class="fas fa-archive"></i>
                            </div>
                            <h3 class="form-title">Restore Stock Details</h3>
                        </div>
                        
                        <!-- Info Box -->
                        <div class="info-box">
                            <div class="info-icon">
                                <i class="fas fa-info-circle"></i>
                            </div>
                            <div class="info-content">
                                <h4>Stock Information</h4>
                                <p>This will restore stock from the stock inventory back to the main product inventory. Available stock: {{ totalAvailableStock }} units.</p>
                            </div>
                        </div>
                        
                        <!-- Store Form -->
                        <form method="post" class="store-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('store_stock') }}">
                            
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-sort-numeric-down"></i> Quantity to Restore
                                </label>
                                <input type="number" name="quantity" 
                                       class="form-input"
                                       placeholder="Enter quantity" 
                                       min="1" 
                                       max="{{ totalAvailableStock }}" 
                                       required>
                                <small class="form-hint">
                                    <i class="fas fa-info-circle"></i> Maximum: {{ totalAvailableStock }} units available from stock inventory
                                </small>
                            </div>

                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-sticky-note"></i> Notes (Optional)
                                </label>
                                <textarea name="notes" 
                                          class="form-textarea"
                                          placeholder="Add any notes about restoring this stock..."></textarea>
                                <small class="form-hint">
                                    <i class="fas fa-info-circle"></i> Provide any additional information about this stock restoration
                                </small>
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary" onclick="return confirm('Are you sure you want to restore this stock?')">
                                    <i class="fas fa-undo"></i> Restore Stock
                                </button>
                                <a href="{{ role_path('stock_management_index') }}" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                            </div>
                        </form>

                        <!-- Available Stock Information -->
                        <div class="info-section">
                            <div class="info-section-header">
                                <div class="info-section-icon">
                                    <i class="fas fa-warehouse"></i>
                                </div>
                                <h3>Available Stock Entries</h3>
                            </div>
                            {% if availableStocks|length > 0 %}
                                <div class="stock-entries-list">
                                    {% for stock in availableStocks %}
                                        <div class="stock-entry-item">
                                            <div class="stock-entry-info">
                                                <span class="stock-id">#{{ stock.id }}</span>
                                                <span class="stock-quantity">{{ stock.quantity }} units</span>
                                            </div>
                                            <div class="stock-entry-details">
                                                <span class="stock-date">{{ stock.createdAt|date('M d, Y') }}</span>
                                                {% if stock.notes %}
                                                    <span class="stock-notes">{{ stock.notes }}</span>
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="no-stock-entries">
                                    <i class="fas fa-inbox"></i>
                                    <p>No stock entries available for this product</p>
                                </div>
                            {% endif %}
                        </div>
                        
                        <!-- Product Information -->
                        <div class="info-section">
                            <div class="info-section-header">
                                <div class="info-section-icon">
                                    <i class="fas fa-info-circle"></i>
                                </div>
                                <h3>Product Information</h3>
                            </div>
                            <div class="info-grid">
                                <div class="info-item">
                                    <div class="info-item-label">
                                        <i class="fas fa-tag"></i> Product Name
                                    </div>
                                    <div class="info-item-value">{{ product.name }}</div>
                                </div>
                                <div class="info-item">
                                    <div class="info-item-label">
                                        <i class="fas fa-barcode"></i> Product Code
                                    </div>
                                    <div class="info-item-value">{{ product.productCode }}</div>
                                </div>
                                <div class="info-item">
                                    <div class="info-item-label">
                                        <i class="fas fa-dollar-sign"></i> Price
                                    </div>
                                    <div class="info-item-value">{{ product.formattedPrice }}</div>
                                </div>
                                <div class="info-item">
                                    <div class="info-item-label">
                                        <i class="fas fa-user-ninja"></i> Character
                                    </div>
                                    <div class="info-item-value">{{ product.character.name }}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                </div>
                <!-- End Main Container -->
            </div>
        </main>
    </div>

 <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
</body>
</html>
