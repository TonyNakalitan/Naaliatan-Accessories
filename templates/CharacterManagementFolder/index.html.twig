{% extends 'base.html.twig' %}

{% block title %}Character Management | Naaliatan{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('CharacterManagementFolder/index.css?v=' ~ random()) }}">
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css">
{% endblock %}

{% block body %}
    <main class="content-area">
        <header class="top-nav">
            <div class="search-global">
                <i class="fas fa-search"></i>
                <input type="text" id="globalSearch" placeholder="Search characters...">
            </div>
            <div class="user-widget">
                <button class="icon-btn"><i class="fas fa-bell"></i></button>
                <div class="avatar">
                    {% if app.user.profilePicture %}
                        <img src="{{ asset('images/profiles/' ~ app.user.profilePicture) }}" alt="{{ app.user.displayName ?: app.user.username }}">
                    {% else %}
                        {{ (app.user.displayName ?: app.user.username)|default('A')|slice(0,1)|upper }}
                    {% endif %}
                </div>
                <div class="user-info">
                    <p class="user-name">{{ app.user.displayName ?: app.user.username }}</p>
                    <p class="user-role">{{ is_granted('ROLE_ADMIN') ? 'Admin' : 'Staff' }}</p>
                </div>
            </div>
        </header>

        <div class="page-container">
            <div class="page-intro">
                <div>
                    <h1 class="page-title">Character Management</h1>
                    <p class="page-subtitle">Manage hero characters, alignments, and product associations</p>
                </div>
            </div>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}

            <div class="stats-grid">
                <div class="stat-card stat-card-blue">
                    <div class="stat-icon">
                        <i class="fas fa-user-ninja"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Total Characters</h3>
                        <p class="value">{{ characters|length }}</p>
                        <span class="stat-badge">Collection</span>
                    </div>
                </div>

                <div class="stat-card stat-card-emerald">
                    <div class="stat-icon">
                        <i class="fas fa-heart"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Good</h3>
                        <p class="value">{{ characters|filter(c => c.alignment == 'Good')|length }}</p>
                        <span class="stat-badge">Alignment</span>
                    </div>
                </div>

                <div class="stat-card stat-card-purple">
                    <div class="stat-icon">
                        <i class="fas fa-balance-scale"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Neutral</h3>
                        <p class="value">{{ characters|filter(c => c.alignment == 'Neutral')|length }}</p>
                        <span class="stat-badge">Alignment</span>
                    </div>
                </div>

                <div class="stat-card stat-card-amber">
                    <div class="stat-icon">
                        <i class="fas fa-skull"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Evil</h3>
                        <p class="value">{{ characters|filter(c => c.alignment == 'Evil')|length }}</p>
                        <span class="stat-badge">Alignment</span>
                    </div>
                </div>
            </div>

            <div class="data-panel">
                <div class="panel-header">
                    <div class="panel-title-wrapper">
                        <div class="panel-icon">
                            <i class="fas fa-id-badge"></i>
                        </div>
                        <span class="panel-title">All Characters</span>
                    </div>
                    <div class="badge-group">
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ role_path('character_management_new') }}" class="btn-add-character">
                                <i class="fas fa-plus"></i>
                                Add Character
                            </a>
                        {% endif %}
                        <select id="alignmentFilter" class="filter-select">
                            <option value="all">All Alignments</option>
                            <option value="good">Good</option>
                            <option value="neutral">Neutral</option>
                            <option value="evil">Evil</option>
                        </select>
                    </div>
                </div>

                <div class="table-container">
                    <table id="myTable" class="character-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Character</th>
                                <th>Creator</th>
                                <th>Alignment</th>
                                <th>Products</th>
                                <th>Created</th>
                                <th class="action-column">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="characterTableBody">
                            {% for character in characters %}
                                <tr>
                                    <td>{{ character.id }}</td>
                                    <td>
                                        <div class="character-cell">
                                            <div class="character-image">
                                                {% if character.image %}
                                                    <img src="{{ asset('images/characters/' ~ character.image) }}" alt="{{ character.name }}">
                                                {% else %}
                                                    <i class="fas fa-user-astronaut"></i>
                                                {% endif %}
                                            </div>
                                            <span class="character-name">{{ character.name }}</span>
                                        </div>
                                    </td>
                                    <td><span class="creator-text">{{ character.creator ?: 'Unknown' }}</span></td>
                                    <td>
                                        {% if character.alignment == 'Good' %}
                                            <span class="alignment-badge alignment-good">
                                                <i class="fas fa-heart"></i>
                                                Good
                                            </span>
                                        {% elseif character.alignment == 'Evil' %}
                                            <span class="alignment-badge alignment-evil">
                                                <i class="fas fa-skull"></i>
                                                Evil
                                            </span>
                                        {% else %}
                                            <span class="alignment-badge alignment-neutral">
                                                <i class="fas fa-balance-scale"></i>
                                                Neutral
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td><span class="product-count">{{ character.products|length }} products</span></td>
                                    <td>{{ character.createdAt|date('M d, Y') }}</td>
                                    <td>
                                        <div class="action-buttons">
                                            <a href="{{ role_path('character_management_show', {'id': character.id}) }}" class="btn-action btn-view" title="View">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            {% if is_granted('ROLE_ADMIN') %}
                                                <a href="{{ role_path('character_management_edit', {'id': character.id}) }}" class="btn-action btn-edit" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <form method="post" action="{{ role_path('character_management_delete', {'id': character.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this character?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ character.id) }}">
                                                    <button type="submit" class="btn-action btn-delete" title="Delete">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="7" class="empty-state">
                                        <i class="fas fa-user-astronaut"></i>
                                        <p>No characters found</p>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.3.7/js/dataTables.min.js"></script>
    <script src="{{ asset('CharacterManagementFolder/index.js') }}"></script>
{% endblock %}
