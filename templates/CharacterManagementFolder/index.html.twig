{% extends 'base.html.twig' %}

{% block title %}Character Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('CharacterManagementFolder/index.css') }}?v={{ random() }}">
{% endblock %}

{% block body %}
<div id="character-app-wrapper" class="min-h-screen">

    <!-- App Wrapper -->
    <div id="app" class="relative w-full h-screen glass-container overflow-x-auto flex flex-col">

        <!-- Header -->
        <header class="relative z-50 flex items-center justify-between px-10 py-8">
            <div class="flex items-center gap-3">
                <button class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/80 hover:bg-white border border-gray-200 hover:shadow-md transition-all text-gray-700 hover:text-gray-900" id="sidebarToggle" title="Toggle Sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="text-3xl font-bold tracking-tighter text-gray-800">
                    Character Management
                </span>
            </div>

            <!-- Search bar -->
            <div class="hidden md:flex items-center bg-gray-100/50 rounded-full px-5 py-2 w-72 border border-gray-200">
                <i class="fa fa-search text-gray-400 mr-3"></i>
                <input type="text" id="searchInput" placeholder="Search characters..." class="bg-transparent outline-none text-sm w-full">
            </div>

            <div class="flex items-center gap-6">
                {% if isAdmin %}
                    <a href="{{ path('app_admin_character_management_new') }}" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors font-medium">
                        <i class="fa fa-plus mr-2"></i>Add Character
                    </a>
                {% endif %}
                <a href="{{ isAdmin ? path('app_admin_profile_edit') : path('app_staff_profile_edit') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors">
                    {% if app.user.profilePicture %}
                        <img src="{{ app.user.profilePicture|image_url('images/profiles') }}" alt="Profile" class="w-10 h-10 rounded-full object-cover border-2 border-white shadow-md">
                    {% else %}
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 text-white font-bold text-sm">
                            {% set displayText = app.user.displayName ?: app.user.username %}
                            {% set words = displayText|split(' ') %}
                            {% if words|length > 1 %}
                                {{ words[0]|slice(0, 1)|upper }}{{ words[1]|slice(0, 1)|upper }}
                            {% else %}
                                {{ displayText|slice(0, 2)|upper }}
                            {% endif %}
                        </div>
                    {% endif %}
                    <div class="flex flex-col items-start">
                        <span class="font-semibold text-gray-800 text-sm">{{ app.user.displayName ?: app.user.username }}</span>
                        <span class="text-xs text-gray-500">{{ isAdmin ? 'Admin' : 'Staff' }}</span>
                    </div>
                </a>
            </div>
        </header>

        <!-- Viewport -->
        <main class="relative flex-1 overflow-x-auto">

            <!-- TABLE VIEW -->
            <div id="gridView" class="grid-view absolute inset-0 flex flex-col px-12 py-8 transition-all duration-500">
                <div class="flex-1 overflow-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Character</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Creator</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Alignment</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Color</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="characterTableBody">
                            <!-- Table rows injected by JS -->
                        </tbody>
                    </table>
                </div>

                <!-- Footer Stats -->
                <div class="flex items-center gap-6 pt-4 pb-2 text-sm font-medium text-gray-500">
                    <span>Total Characters: <span id="totalCount">{{ totalCharacters }}</span></span>
                </div>
            </div>

            <!-- DETAIL / HERO VIEW -->
            <div id="heroView" class="hero-view absolute inset-0 z-40 bg-white">
                <div id="heroBg" class="absolute inset-0 w-1/2 rounded-r-[80px] transition-colors duration-700"></div>

                <button onclick="closeHero()" class="absolute top-8 right-10 z-50 flex items-center gap-2 font-bold text-gray-800 hover:scale-105 transition-transform">
                    <i class="fa fa-times text-red-500"></i> Close
                </button>

                <div class="relative z-10 h-full flex items-center px-16">
                    <!-- Left Side: Large Image with Frame -->
                    <div class="w-1/2 flex justify-center items-center">
                        <div class="hero-image-frame">
                            <img id="heroImage" src="" alt="" class="hero-image">
                        </div>
                    </div>

                    <!-- Right Side: Content -->
                    <div class="w-1/2 pl-12 pr-8">
                        <div class="hero-content-wrapper">
                            <h2 id="heroName" class="hero-title slide-in" style="animation-delay: 0.1s"></h2>

                            <div class="hero-meta-section slide-in" style="animation-delay: 0.2s">
                                <div class="meta-item">
                                    <i class="fa fa-user-circle text-blue-500"></i>
                                    <span class="meta-label">Creator:</span>
                                    <span id="heroCreator" class="meta-value"></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fa fa-balance-scale text-purple-500"></i>
                                    <span class="meta-label">Alignment:</span>
                                    <span id="heroAlignment" class="alignment-badge"></span>
                                </div>
                            </div>

                            <div class="hero-description-section slide-in" style="animation-delay: 0.3s">
                                <h3 class="description-title">About</h3>
                                <p id="heroDesc" class="description-text"></p>
                            </div>

                            <div class="hero-actions slide-in" style="animation-delay: 0.4s">
                                {% if isAdmin %}
                                    <a id="heroViewBtn" href="#" class="action-btn action-btn-view">
                                        <i class="fa fa-eye"></i>
                                        <span>View Character</span>
                                    </a>
                                    <a id="heroEditBtn" href="#" class="action-btn action-btn-primary">
                                        <i class="fa fa-edit"></i>
                                        <span>Edit Character</span>
                                    </a>
                                    <button id="heroDeleteBtn" onclick="deleteCharacter()" class="action-btn action-btn-danger">
                                        <i class="fa fa-trash"></i>
                                        <span>Delete</span>
                                    </button>
                                {% elseif isStaff %}
                                    <a id="heroViewBtn" href="#" class="action-btn action-btn-view">
                                        <i class="fa fa-eye"></i>
                                        <span>View Character</span>
                                    </a>
                                    <a id="heroEditBtn" href="#" class="action-btn action-btn-primary">
                                        <i class="fa fa-edit"></i>
                                        <span>Edit Character</span>
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Delete Form (hidden) -->
    <form id="deleteForm" method="POST" style="display: none;">
        <input type="hidden" name="_token" value="">
    </form>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
    <script>
        const allCharactersData = [
            {% for char in allCharacters %}
            {
                id: {{ char.id }},
                name: {{ char.name|json_encode|raw }},
                creator: {{ char.creator|json_encode|raw }},
                alignment: {{ char.alignment|json_encode|raw }},
                colorCode: {{ char.colorCode|json_encode|raw }},
                image: {{ char.image|json_encode|raw }},
                description: {{ char.description|json_encode|raw }},
                csrfToken: {{ csrf_token('delete' ~ char.id)|json_encode|raw }}
            }{% if not loop.last %},{% endif %}
            {% endfor %}
        ];

        const isAdmin = {{ isAdmin ? 'true' : 'false' }};
        const isStaff = {{ isStaff ? 'true' : 'false' }};
        const baseUrl = '{{ app.request.schemeAndHttpHost }}';
        const imageBasePath = '{{ asset('images/characters/') }}';
        const showAdminBase = '{{ path('app_admin_character_management_show', {'id': 0}) }}'.replace('/0/show', '');
        const showStaffBase = '{{ path('app_staff_character_management_show', {'id': 0}) }}'.replace('/0/show', '');
        const editAdminBase = '{{ path('app_admin_character_management_edit', {'id': 0}) }}'.replace('/0/edit', '');
        const editStaffBase = '{{ path('app_staff_character_management_edit', {'id': 0}) }}'.replace('/0/edit', '');

        let characters = allCharactersData.map(char => ({
            id: char.id,
            name: char.name || 'Unknown',
            creator: char.creator || 'Unknown',
            alignment: char.alignment || 'Neutral',
            colorCode: char.colorCode || '#6c757d',
            image: char.image ? imageBasePath + char.image : null,
            description: char.description || 'No description available.',
            csrfToken: char.csrfToken
        }));

        let filteredCharacters = [...characters];

        function adjustColor(color, amount) {
            const num = parseInt(color.replace('#', ''), 16);
            const r = Math.min(255, Math.max(0, (num >> 16) + amount));
            const g = Math.min(255, Math.max(0, ((num >> 8) & 0x00FF) + amount));
            const b = Math.min(255, Math.max(0, (num & 0x0000FF) + amount));
            return '#' + ((r << 16) | (g << 8) | b).toString(16).padStart(6, '0');
        }

        function getAlignmentInfo(alignment) {
            const a = (alignment || '').toLowerCase();
            if (a === 'good')  return { cls: 'alignment-good',    color: '#10b981', icon: 'fa-heart' };
            if (a === 'evil')  return { cls: 'alignment-evil',    color: '#ef4444', icon: 'fa-skull' };
            return               { cls: 'alignment-neutral', color: '#3b82f6', icon: 'fa-balance-scale' };
        }

        function renderTable() {
            const tbody = document.getElementById('characterTableBody');
            tbody.innerHTML = '';

            if (!filteredCharacters.length) {
                tbody.innerHTML = `<tr><td colspan="4" class="text-center text-gray-500 text-xl py-20">
                    No characters found.${isAdmin ? ' <a href="${baseUrl}/admin/characters/new" class="text-blue-600 hover:underline">Add one now!</a>' : ''}
                </td></tr>`;
                return;
            }

            filteredCharacters.forEach(char => {
                const ai  = getAlignmentInfo(char.alignment);
                const row = document.createElement('tr');

                const imgSrc   = char.image || '';
                const initials = char.name.charAt(0).toUpperCase();

                let actionBtns = '';
                if (isAdmin) {
                    actionBtns = `
                        <a href="${showAdminBase}/${char.id}/show" class="table-action-btn table-action-view" title="View">
                            <i class="fa fa-eye"></i>
                        </a>
                        <a href="${editAdminBase}/${char.id}/edit" class="table-action-btn table-action-edit" title="Edit">
                            <i class="fa fa-edit"></i>
                        </a>
                        <button onclick="event.stopPropagation(); deleteCharacterById(${char.id})" class="table-action-btn table-action-delete" title="Delete">
                            <i class="fa fa-trash"></i>
                        </button>`;
                } else if (isStaff) {
                    actionBtns = `
                        <a href="${showStaffBase}/${char.id}/show" class="table-action-btn table-action-view" title="View">
                            <i class="fa fa-eye"></i>
                        </a>
                        <a href="${editStaffBase}/${char.id}/edit" class="table-action-btn table-action-edit" title="Edit">
                            <i class="fa fa-edit"></i>
                        </a>`;
                }

                row.innerHTML = `
                    <td>
                        <div class="character-info">
                            ${imgSrc
                                ? `<img src="${imgSrc}" alt="${char.name}" class="character-table-avatar"
                                       onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
                                   <div class="character-table-fallback" style="background:linear-gradient(135deg,${adjustColor(char.colorCode,20)},${char.colorCode});display:none;">${initials}</div>`
                                : `<div class="character-table-fallback" style="background:linear-gradient(135deg,${adjustColor(char.colorCode,20)},${char.colorCode});">${initials}</div>`
                            }
                            <div>
                                <div class="character-name">${char.name}</div>
                            </div>
                        </div>
                    </td>
                    <td class="text-gray-700">${char.creator}</td>
                    <td>
                        <span class="table-alignment-badge ${ai.cls}">
                            <i class="fas ${ai.icon} mr-1"></i>${char.alignment}
                        </span>
                    </td>
                    <td>
                        <div class="color-cell">
                            <div class="color-swatch" style="background-color:${char.colorCode};"></div>
                            <span class="color-hex">${char.colorCode}</span>
                        </div>
                    </td>
                    <td>
                        <div class="table-actions">${actionBtns}</div>
                    </td>
                `;
                row.style.cursor = 'pointer';
                row.addEventListener('click', function(e) {
                    if (!e.target.closest('a') && !e.target.closest('button')) openHero(char);
                });
                tbody.appendChild(row);
            });
        }

        document.getElementById('searchInput')?.addEventListener('input', function(e) {
            const q = e.target.value.toLowerCase();
            filteredCharacters = characters.filter(c =>
                c.name.toLowerCase().includes(q) ||
                c.creator.toLowerCase().includes(q) ||
                c.alignment.toLowerCase().includes(q)
            );
            document.getElementById('totalCount').textContent = filteredCharacters.length;
            renderTable();
        });

        let currentCharacter = null;

        function openHero(char) {
            currentCharacter = char;
            const app    = document.getElementById('app');
            const heroBg = document.getElementById('heroBg');
            const ai     = getAlignmentInfo(char.alignment);

            heroBg.style.background = `linear-gradient(180deg,${adjustColor(char.colorCode,30)} 0%,${adjustColor(char.colorCode,-30)} 100%)`;

            const heroImage = document.getElementById('heroImage');
            heroImage.src = char.image || 'https://via.placeholder.com/400x400?text=' + encodeURIComponent(char.name);
            heroImage.onerror = function() {
                this.src = 'https://via.placeholder.com/400x400?text=' + encodeURIComponent(char.name);
            };

            document.getElementById('heroName').innerText    = char.name;
            document.getElementById('heroCreator').innerText = char.creator;
            document.getElementById('heroDesc').innerText    = char.description;

            const heroAlignment = document.getElementById('heroAlignment');
            heroAlignment.innerHTML = `<i class="fas ${ai.icon}"></i> ${char.alignment}`;
            heroAlignment.className = `alignment-badge ${ai.cls}`;

            const viewBtn = document.getElementById('heroViewBtn');
            if (viewBtn) viewBtn.href = isAdmin
                ? `${showAdminBase}/${char.id}/show`
                : `${showStaffBase}/${char.id}/show`;

            const editBtn = document.getElementById('heroEditBtn');
            if (editBtn) {
                editBtn.href = isAdmin
                    ? `${editAdminBase}/${char.id}/edit`
                    : `${editStaffBase}/${char.id}/edit`;
            }

            app.classList.add('hero-active');

            document.querySelectorAll('.slide-in').forEach(el => {
                el.style.animation = 'none';
                el.offsetHeight;
                el.style.animation = null;
            });
        }

        function deleteCharacter() {
            if (currentCharacter) deleteCharacterById(currentCharacter.id);
        }

        function deleteCharacterById(charId) {
            const char = characters.find(c => c.id === charId);
            if (!char || !isAdmin) return;
            if (!confirm(`Are you sure you want to delete "${char.name}"?`)) return;

            const form = document.createElement('form');
            form.method = 'POST';
            form.action = `${editAdminBase}/${char.id}`;

            const token = document.createElement('input');
            token.type  = 'hidden';
            token.name  = '_token';
            token.value = char.csrfToken;

            form.appendChild(token);
            document.body.appendChild(form);
            form.submit();
        }

        function closeHero() {
            document.getElementById('app').classList.remove('hero-active');
        }

        document.addEventListener('DOMContentLoaded', function() {
            renderTable();

            const sidebarToggle  = document.getElementById('sidebarToggle');
            const sidebar        = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');

            sidebarToggle?.addEventListener('click', () => {
                sidebar?.classList.toggle('active');
                sidebarOverlay?.classList.toggle('active');
            });
            sidebarOverlay?.addEventListener('click', () => {
                sidebar?.classList.remove('active');
                sidebarOverlay?.classList.remove('active');
            });
        });
    </script>
{% endblock %}
