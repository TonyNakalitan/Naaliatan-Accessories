{% extends 'base.html.twig' %}

{% block title %}Items Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('ItemsFolder/index.css') }}?v={{ random() }}">
{% endblock %}

{% block body %}
<div id="items-app-wrapper" class="min-h-screen">

    <!-- App Wrapper -->
    <div id="app" class="relative w-full h-screen glass-container overflow-x-auto flex flex-col">

        <!-- Header -->
        <header class="relative z-50 flex items-center justify-between px-10 py-8">
            <div class="flex items-center gap-3">
                <button class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/80 hover:bg-white border border-gray-200 hover:shadow-md transition-all text-gray-700 hover:text-gray-900" id="sidebarToggle" title="Toggle Sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="text-3xl font-bold tracking-tighter text-gray-800">
                    Items Management
                </span>
            </div>

            <!-- Search bar -->
            <div class="hidden md:flex items-center bg-gray-100/50 rounded-full px-5 py-2 w-72 border border-gray-200">
                <i class="fa fa-search text-gray-400 mr-3"></i>
                <input type="text" id="searchInput" placeholder="Search characters..." class="bg-transparent outline-none text-sm w-full">
            </div>

            <div class="flex items-center gap-6">
                <a href="{{ is_granted('ROLE_ADMIN') ? path('app_admin_profile_edit') : path('app_staff_profile_edit') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors">
                    {% if app.user.profilePicture %}
                        <img src="{{ app.user.profilePicture|image_url('images/profiles') }}" alt="Profile" class="w-10 h-10 rounded-full object-cover border-2 border-white shadow-md">
                    {% else %}
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 text-white font-bold text-sm">
                            {% set displayText = app.user.displayName ?: app.user.username %}
                            {% set words = displayText|split(' ') %}
                            {% if words|length > 1 %}
                                {{ words[0]|slice(0, 1)|upper }}{{ words[1]|slice(0, 1)|upper }}
                            {% else %}
                                {{ displayText|slice(0, 2)|upper }}
                            {% endif %}
                        </div>
                    {% endif %}
                    <div class="flex flex-col items-start">
                        <span class="font-semibold text-gray-800 text-sm">{{ app.user.displayName ?: app.user.username }}</span>
                        <span class="text-xs text-gray-500">{{ is_granted('ROLE_ADMIN') ? 'Admin' : 'Staff' }}</span>
                    </div>
                </a>
            </div>
        </header>

        <!-- Viewport -->
        <main class="relative flex-1 overflow-x-auto">

            <!-- TABLE VIEW -->
            <div id="gridView" class="grid-view absolute inset-0 flex flex-col px-12 py-8 transition-all duration-500">
                <div class="flex-1 overflow-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Character</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Creator</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Alignment</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Products</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="characterTableBody">
                            <!-- Table rows injected by JS -->
                        </tbody>
                    </table>
                </div>

                <!-- Footer Stats -->
                <div class="flex items-center gap-6 pt-4 pb-2 text-sm font-medium text-gray-500">
                    <span>Total Characters: <span id="totalCount">{{ characters|length }}</span></span>
                    <span>Good: <span class="text-emerald-600 font-bold">{{ goodCount }}</span></span>
                    <span>Neutral: <span class="text-blue-600 font-bold">{{ neutralCount }}</span></span>
                    <span>Evil: <span class="text-red-600 font-bold">{{ evilCount }}</span></span>
                </div>
            </div>

            <!-- DETAIL / HERO VIEW -->
            <div id="heroView" class="hero-view absolute inset-0 z-40 bg-white">
                <div id="heroBg" class="absolute inset-0 w-1/2 rounded-r-[80px] transition-colors duration-700"></div>

                <button onclick="closeHero()" class="absolute top-8 right-10 z-50 flex items-center gap-2 font-bold text-gray-800 hover:scale-105 transition-transform">
                    <i class="fa fa-times text-red-500"></i> Close
                </button>

                <div class="relative z-10 h-full flex items-center px-16">
                    <!-- Left Side: Large Image with Frame -->
                    <div class="w-1/2 flex justify-center items-center">
                        <div class="hero-image-frame">
                            <img id="heroImage" src="" alt="" class="hero-image">
                        </div>
                    </div>

                    <!-- Right Side: Content -->
                    <div class="w-1/2 pl-12 pr-8">
                        <div class="hero-content-wrapper">
                            <h2 id="heroName" class="hero-title slide-in" style="animation-delay: 0.1s"></h2>

                            <div class="hero-meta-section slide-in" style="animation-delay: 0.2s">
                                <div class="meta-item">
                                    <i class="fa fa-shield-alt text-purple-500"></i>
                                    <span class="meta-label">Alignment:</span>
                                    <span id="heroAlignment" class="alignment-badge-hero"></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fa fa-user text-blue-500"></i>
                                    <span class="meta-label">Creator:</span>
                                    <span id="heroCreator" class="meta-value"></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fa fa-boxes text-green-500"></i>
                                    <span class="meta-label">Products:</span>
                                    <span id="heroProductCount" class="meta-value"></span>
                                </div>
                            </div>

                            <div class="hero-description-section slide-in" style="animation-delay: 0.3s">
                                <h3 class="description-title">Description</h3>
                                <p id="heroDesc" class="description-text"></p>
                            </div>

                            <div class="hero-actions slide-in" style="animation-delay: 0.4s">
                                <a id="heroViewBtn" href="#" class="action-btn action-btn-primary">
                                    <i class="fa fa-eye"></i>
                                    <span>View Products</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
    <script>
        const allCharactersData = [
            {% for character in characters %}
            {
                id: {{ character.id }},
                name: {{ character.name|json_encode|raw }},
                alignment: {{ character.alignment|json_encode|raw }},
                creator: {{ character.creator|json_encode|raw }},
                image: {{ character.image|json_encode|raw }},
                description: {{ character.description|json_encode|raw }},
                productCount: {{ character.products|length }},
                colorCode: {{ character.colorCode|json_encode|raw }}
            }{% if not loop.last %},{% endif %}
            {% endfor %}
        ];

        const isAdmin = {{ is_granted('ROLE_ADMIN') ? 'true' : 'false' }};
        const isStaff = {{ is_granted('ROLE_STAFF') ? 'true' : 'false' }};
        const baseUrl = '{{ app.request.schemeAndHttpHost }}';
        const imageBasePath = '{{ asset('images/characters/') }}';

        let characters = allCharactersData.map(char => ({
            id: char.id,
            name: char.name || 'Unknown Character',
            alignment: char.alignment || 'Neutral',
            creator: char.creator || 'Unknown',
            productCount: char.productCount || 0,
            colorCode: char.colorCode || '#6c757d',
            image: char.image ? imageBasePath + char.image : 'https://via.placeholder.com/400x400?text=' + encodeURIComponent(char.name || 'Character'),
            description: char.description || 'No description available.'
        }));

        let filteredCharacters = [...characters];

        function adjustColor(color, amount) {
            const num = parseInt(color.replace('#', ''), 16);
            const r = Math.min(255, Math.max(0, (num >> 16) + amount));
            const g = Math.min(255, Math.max(0, ((num >> 8) & 0x00FF) + amount));
            const b = Math.min(255, Math.max(0, (num & 0x0000FF) + amount));
            return '#' + ((r << 16) | (g << 8) | b).toString(16).padStart(6, '0');
        }

        function getAlignmentInfo(alignment) {
            const a = (alignment || '').toLowerCase();
            if (a === 'good')    return { icon: 'fa-heart',         cls: 'alignment-good',    color: '#10b981' };
            if (a === 'evil')    return { icon: 'fa-skull',          cls: 'alignment-evil',    color: '#ef4444' };
            return                      { icon: 'fa-balance-scale',  cls: 'alignment-neutral', color: '#3b82f6' };
        }

        function renderTable() {
            const tbody = document.getElementById('characterTableBody');
            tbody.innerHTML = '';

            if (!filteredCharacters.length) {
                tbody.innerHTML = '<tr><td colspan="5" class="text-center text-gray-500 text-xl py-20">No characters found.</td></tr>';
                return;
            }

            filteredCharacters.forEach(char => {
                const ai = getAlignmentInfo(char.alignment);
                const row = document.createElement('tr');

                row.innerHTML = `
                    <td>
                        <div class="character-info">
                            <img src="${char.image}"
                                 alt="${char.name}"
                                 class="character-table-avatar"
                                 onerror="this.onerror=null;this.style.display='none';this.nextElementSibling.style.display='flex';">
                            <div class="character-table-avatar-fallback" style="background:linear-gradient(135deg,${adjustColor(char.colorCode,20)},${char.colorCode});display:none;">
                                ${char.name.charAt(0).toUpperCase()}
                            </div>
                            <div>
                                <div class="character-name">${char.name}</div>
                                <div class="character-sub">by ${char.creator}</div>
                            </div>
                        </div>
                    </td>
                    <td class="text-gray-700">${char.creator}</td>
                    <td>
                        <span class="table-alignment-badge ${ai.cls}">
                            <i class="fas ${ai.icon} mr-1"></i>${char.alignment}
                        </span>
                    </td>
                    <td class="text-gray-700 font-semibold">${char.productCount}</td>
                    <td>
                        <div class="table-actions">
                            <a href="${baseUrl}/${isAdmin ? 'admin' : 'staff'}/items/character/${char.id}"
                               class="table-action-btn table-action-view" title="View Products">
                                <i class="fa fa-eye"></i>
                            </a>
                        </div>
                    </td>
                `;
                row.style.cursor = 'pointer';
                row.addEventListener('click', function(e) {
                    if (!e.target.closest('a') && !e.target.closest('button')) {
                        openHero(char);
                    }
                });
                tbody.appendChild(row);
            });
        }

        document.getElementById('searchInput')?.addEventListener('input', function(e) {
            const q = e.target.value.toLowerCase();
            filteredCharacters = characters.filter(char =>
                char.name.toLowerCase().includes(q) ||
                char.creator.toLowerCase().includes(q) ||
                char.alignment.toLowerCase().includes(q)
            );
            const el = document.getElementById('totalCount');
            if (el) el.textContent = filteredCharacters.length;
            renderTable();
        });

        function openHero(char) {
            const app    = document.getElementById('app');
            const heroBg = document.getElementById('heroBg');
            const ai     = getAlignmentInfo(char.alignment);

            heroBg.style.background = `linear-gradient(180deg,${adjustColor(char.colorCode,30)} 0%,${adjustColor(char.colorCode,-30)} 100%)`;

            const heroImage = document.getElementById('heroImage');
            heroImage.src = char.image;
            heroImage.onerror = function() {
                this.src = 'https://via.placeholder.com/400x400?text=' + encodeURIComponent(char.name);
            };

            document.getElementById('heroName').innerText        = char.name;
            document.getElementById('heroCreator').innerText     = char.creator;
            document.getElementById('heroProductCount').innerText = char.productCount + ' products';
            document.getElementById('heroDesc').innerText        = char.description;

            const heroAlignment = document.getElementById('heroAlignment');
            heroAlignment.innerHTML   = `<i class="fas ${ai.icon}"></i> ${char.alignment}`;
            heroAlignment.className   = `alignment-badge-hero ${ai.cls}`;

            const viewBtn = document.getElementById('heroViewBtn');
            if (viewBtn) {
                viewBtn.href = `${baseUrl}/${isAdmin ? 'admin' : 'staff'}/items/character/${char.id}`;
            }

            app.classList.add('hero-active');

            document.querySelectorAll('.slide-in').forEach(el => {
                el.style.animation = 'none';
                el.offsetHeight;
                el.style.animation = null;
            });
        }

        function closeHero() {
            document.getElementById('app').classList.remove('hero-active');
        }

        document.addEventListener('DOMContentLoaded', function() {
            renderTable();

            const sidebarToggle  = document.getElementById('sidebarToggle');
            const sidebar        = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');

            sidebarToggle?.addEventListener('click', () => {
                sidebar?.classList.toggle('active');
                sidebarOverlay?.classList.toggle('active');
            });
            sidebarOverlay?.addEventListener('click', () => {
                sidebar?.classList.remove('active');
                sidebarOverlay?.classList.remove('active');
            });
        });
    </script>
{% endblock %}
