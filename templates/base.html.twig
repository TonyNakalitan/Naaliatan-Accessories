<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
        <title>{% block title %}Naaliatan's Accessories{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
        {% block stylesheets %}
            <link href="{{ asset('CSSFolder/base.css') }}?v={{ random() }}" rel="stylesheet">
            <link href="{{ asset('CSSFolder/app.css') }}?v={{ random() }}" rel="stylesheet">
            <link href="{{ asset('CSSFolder/management-responsive.css') }}?v={{ random() }}" rel="stylesheet">
        {% endblock %}
        
        {# Inline Modal Styles (Fallback) #}
        <style>
            .modal {
                display: none;
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                z-index: 9999;
            }
            .modal.show {
                display: flex !important;
                align-items: center;
                justify-content: center;
            }
            .modal-overlay {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.5);
                backdrop-filter: blur(4px);
            }
            .modal-content {
                position: relative;
                background: white;
                border-radius: 16px;
                box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
                max-width: 450px;
                width: 90%;
                overflow: hidden;
            }
        </style>
    </head>
    <body>
        {% if app.user %}
        {# Sidebar Overlay Backdrop #}
        <div class="sidebar-overlay" id="sidebarOverlay"></div>
        
        {# Sidebar for authenticated users #}
        <aside class="sidebar sidebar-overlay" id="sidebar">
            <div class="sidebar-header">
                <img src="{{ asset('images/NA.png') }}" alt="Naaliatan's Accessories" class="sidebar-logo">
            </div>
            <nav class="sidebar-nav">
                <a href="{{ role_path('dashboard') }}" class="nav-item {% if app.request.get('_route') starts with 'app_admin_dashboard' or app.request.get('_route') starts with 'app_staff_dashboard' %}active{% endif %}">
                    <i class="fas fa-chart-line"></i>
                    <span>Dashboard</span>
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin_user_management_index') }}" class="nav-item {% if app.request.get('_route') starts with 'app_admin_user_management' %}active{% endif %}">
                    <i class="fas fa-users"></i>
                    <span>User Management</span>
                </a>
                {% endif %}
                <a href="{{ role_path('product_management_index') }}" class="nav-item {% if app.request.get('_route') starts with 'app_admin_product_management' or app.request.get('_route') starts with 'app_staff_product_management' %}active{% endif %}">
                    <i class="fas fa-box-open"></i>
                    <span>Products</span>
                </a>
                <a href="{{ role_path('stock_management_index') }}" class="nav-item {% if app.request.get('_route') starts with 'app_admin_stock_management' or app.request.get('_route') starts with 'app_staff_stock_management' %}active{% endif %}">
                    <i class="fas fa-warehouse"></i>
                    <span>Stock Control</span>
                </a>
                <a href="{{ role_path('order_index') }}" class="nav-item {% if app.request.get('_route') starts with 'app_admin_order' or app.request.get('_route') starts with 'app_staff_order' %}active{% endif %}">
                    <i class="fas fa-shopping-bag"></i>
                    <span>Orders</span>
                </a>
                <a href="{{ role_path('item_management_index') }}" class="nav-item {% if app.request.get('_route') starts with 'app_admin_item_management' or app.request.get('_route') starts with 'app_staff_item_management' %}active{% endif %}">
                    <i class="fas fa-boxes"></i>
                    <span>Items</span>
                </a>
                <a href="{{ role_path('cart_index') }}" class="nav-item {% if app.request.get('_route') starts with 'app_admin_cart' or app.request.get('_route') starts with 'app_staff_cart' %}active{% endif %}">
                    <i class="fas fa-shopping-cart"></i>
                    <span>Cart</span>
                </a>
                <a href="{{ role_path('character_management_index') }}" class="nav-item {% if app.request.get('_route') starts with 'app_admin_character_management' or app.request.get('_route') starts with 'app_staff_character_management' %}active{% endif %}">
                    <i class="fas fa-id-badge"></i>
                    <span>Characters</span>
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin_activity_logs_index') }}" class="nav-item {% if app.request.get('_route') starts with 'app_admin_activity_logs' %}active{% endif %}">
                    <i class="fas fa-history"></i>
                    <span>Activity Logs</span>
                </a>
                {% endif %}
            </nav>
            <div class="sidebar-footer">
                <a href="{{ role_path('profile_show') }}" class="nav-item {% if app.request.get('_route') == 'app_admin_profile_show' or app.request.get('_route') == 'app_staff_profile_show' %}active{% endif %}">
                    <i class="fas fa-user-circle"></i>
                    <span>My Profile</span>
                </a>
                <a href="{{ role_path('settings_index') }}" class="nav-item {% if app.request.get('_route') == 'app_admin_settings_index' or app.request.get('_route') == 'app_staff_settings_index' %}active{% endif %}">
                    <i class="fas fa-cog"></i>
                    <span>Settings</span>
                </a>
                <a href="#" class="nav-item" id="logoutBtn">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Logout</span>
                </a>
            </div>
        </aside>
        
        {# Enhanced Logout Confirmation Modal #}
        <div id="logoutModal" class="modal modal-logout">
            <div class="modal-overlay"></div>
            <div class="modal-content">
                <div class="modal-header modal-header-danger">
                    <div class="modal-title-wrapper">
                        <div class="modal-icon-danger">
                            <i class="fas fa-sign-out-alt"></i>
                        </div>
                        <h2 class="modal-title">
                            Ready to Leave?
                        </h2>
                    </div>
                    <button class="modal-close" onclick="closeLogoutModal()" aria-label="Close modal">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                
                <div class="modal-body">
                    <div class="logout-user-info">
                        <div class="user-preview">
                            <div class="user-preview-avatar">
                                {% if app.user.profilePicture %}
                                    <img src="{{ asset('images/profiles/' ~ app.user.profilePicture) }}" alt="{{ app.user.displayName ?: app.user.username }}">
                                {% else %}
                                    <i class="fas fa-user"></i>
                                {% endif %}
                            </div>
                            <div class="user-preview-details">
                                <span class="user-preview-label">Current User</span>
                                <span class="user-preview-name">{{ app.user.displayName ?: app.user.username }}</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="warning-box">
                        <div class="warning-icon">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                        <div class="warning-content">
                            <h4>Warning: Session Will End</h4>
                            <p>You will be logged out and any unsaved work will be lost. Make sure to save your progress before continuing.</p>
                        </div>
                    </div>
                    
                    <div class="confirmation-check">
                        <label class="confirmation-checkbox">
                            <input type="checkbox" id="logoutConfirmation" onchange="toggleLogoutButton()">
                            <span class="checkmark"></span>
                            <span class="confirmation-label">I understand that I will be logged out and any unsaved changes will be lost.</span>
                        </label>
                    </div>
                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn-secondary" onclick="closeLogoutModal()">
                        <i class="fas fa-times"></i>
                        Cancel
                    </button>
                    <form method="post" action="{{ path('app_logout') }}" style="display: inline;">
                        <button type="submit" class="btn-danger" id="logoutSubmitBtn" disabled>
                            <i class="fas fa-sign-out-alt"></i>
                            Logout Now
                        </button>
                    </form>
                </div>
            </div>
        </div>
        {% endif %}
        
        {% block body %}{% endblock %}
        
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}
            <script src="{{ asset('JSFolder/app.js') }}?v={{ random() }}"></script>
        {% endblock %}
        
        {# Enhanced Modal Script #}
        <script>
            // Enhanced modal functions
            window.openLogoutModal = function() {
                const modal = document.getElementById('logoutModal');
                if (modal) {
                    modal.classList.add('show');
                    document.body.style.overflow = 'hidden';
                    
                    // Focus on close button for accessibility
                    setTimeout(() => {
                        modal.querySelector('.modal-close').focus();
                    }, 100);
                }
            };
            
            window.closeLogoutModal = function() {
                const modal = document.getElementById('logoutModal');
                if (modal) {
                    modal.classList.remove('show');
                    document.body.style.overflow = '';
                    
                    // Reset confirmation state
                    const checkbox = document.getElementById('logoutConfirmation');
                    const submitBtn = document.getElementById('logoutSubmitBtn');
                    if (checkbox) checkbox.checked = false;
                    if (submitBtn) submitBtn.disabled = true;
                }
            };
            
            window.toggleLogoutButton = function() {
                const checkbox = document.getElementById('logoutConfirmation');
                const submitBtn = document.getElementById('logoutSubmitBtn');
                
                if (checkbox && submitBtn) {
                    submitBtn.disabled = !checkbox.checked;
                }
            };
            
            // Enhanced logout button handler
            document.addEventListener('DOMContentLoaded', function() {
                const logoutBtn = document.getElementById('logoutBtn');
                if (logoutBtn) {
                    logoutBtn.addEventListener('click', function(e) {
                        e.preventDefault();
                        console.log('Logout clicked - enhanced handler');
                        window.openLogoutModal();
                    });
                }
            });
        </script>
        {% block extra_js %}{% endblock %}
    </body>
</html>
