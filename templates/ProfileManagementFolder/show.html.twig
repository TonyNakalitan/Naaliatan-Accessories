{% extends 'base.html.twig' %}

{% block title %}My Profile | Naaliatan{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('ProfileManagementFolder/show.css') }}?v={{ random() }}">
{% endblock %}

{% block body %}
<div id="profile-app-wrapper" class="min-h-screen">

    <!-- App Wrapper -->
    <div id="app" class="relative w-full h-screen glass-container overflow-hidden flex flex-col">
        
        <!-- Header -->
        <header class="relative z-50 flex items-center justify-between px-10 py-8">
            <div class="flex items-center gap-3">
                <button class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/80 hover:bg-white border border-gray-200 hover:shadow-md transition-all text-gray-700 hover:text-gray-900" id="sidebarToggle" title="Toggle Sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="text-3xl font-bold tracking-tighter text-gray-800">
                    My Profile
                </span>
            </div>

            <!-- Search bar -->
            <div class="hidden md:flex items-center bg-gray-100/50 rounded-full px-5 py-2 w-72 border border-gray-200">
                <i class="fa fa-search text-gray-400 mr-3"></i>
                <input type="text" id="searchInput" placeholder="Search profile..." class="bg-transparent outline-none text-sm w-full">
            </div>

            <div class="flex items-center gap-6">
                <a href="{{ role_path("profile_edit") }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors">
                    {% if user.profilePicture %}
                        <img src="{{ user.profilePicture|image_url('images/profiles') }}" alt="Profile" class="w-10 h-10 rounded-full object-cover border-2 border-white shadow-md">
                    {% else %}
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 text-white font-bold text-sm">
                            {% set displayText = user.displayName ?: user.username %}
                            {% set words = displayText|split(' ') %}
                            {% if words|length > 1 %}
                                {{ words[0]|slice(0, 1)|upper }}{{ words[1]|slice(0, 1)|upper }}
                            {% else %}
                                {{ displayText|slice(0, 2)|upper }}
                            {% endif %}
                        </div>
                    {% endif %}
                    <div class="flex flex-col items-start">
                        <span class="font-semibold text-gray-800 text-sm">{{ user.displayName ?: user.username }}</span>
                        <span class="text-xs text-gray-500">{{ user.isAdmin() ? 'Admin' : 'Staff' }}</span>
                    </div>
                </a>
            </div>
        </header>

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="mx-10 mb-4 p-4 bg-green-50 border border-green-200 rounded-lg flex items-center gap-3 text-green-800">
                <i class="fas fa-check-circle text-xl"></i>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="mx-10 mb-4 p-4 bg-red-50 border border-red-200 rounded-lg flex items-center gap-3 text-red-800">
                <i class="fas fa-exclamation-circle text-xl"></i>
                <span>{{ message }}</span>
            </div>
        {% endfor %}

        <!-- Viewport -->
        <main class="relative flex-1 overflow-x-auto px-12 py-8">
            
            <!-- User Info Bar -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-8">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-4">
                        {% if user.profilePicture %}
                            <img src="{{ user.profilePicture|image_url('images/profiles') }}" alt="Profile" class="w-16 h-16 rounded-xl object-cover border-2 border-gray-100 shadow-sm">
                        {% else %}
                            <div class="flex items-center justify-center w-16 h-16 rounded-xl bg-gradient-to-br from-blue-500 to-purple-600 text-white font-bold text-xl">
                                {% set displayText = user.displayName ?: user.username %}
                                {% set words = displayText|split(' ') %}
                                {% if words|length > 1 %}
                                    {{ words[0]|slice(0, 1)|upper }}{{ words[1]|slice(0, 1)|upper }}
                                {% else %}
                                    {{ displayText|slice(0, 2)|upper }}
                                {% endif %}
                            </div>
                        {% endif %}
                        <div>
                            <h2 class="text-xl font-bold text-gray-800">{{ user.displayName ?: user.username }}</h2>
                            <p class="text-gray-500 text-sm">{{ user.email }}</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="px-4 py-2 rounded-full text-sm font-medium bg-blue-50 text-blue-600 border border-blue-100">
                            <i class="fas fa-shield-alt mr-2"></i>{{ user.isAdmin() ? 'Administrator' : (user.isStaff() ? 'Staff Member' : 'User') }}
                        </span>
                    </div>
                </div>
            </div>

            <!-- Profile Stats Grid -->
            <div id="profileGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Cards injected by JS -->
            </div>
        </main>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
    <script>
        const profileData = [
            {
                id: 'account',
                title: 'Account Info',
                value: '{{ user.username }}',
                badge: 'Profile',
                icon: 'fa-user-circle',
                colorCode: '#3b82f6',
                description: 'Your account information including username, email, and display name',
                meta: [
                    { icon: 'fa-user', label: 'Username', value: '{{ user.username }}' },
                    { icon: 'fa-envelope', label: 'Email', value: '{{ user.email }}' },
                    { icon: 'fa-signature', label: 'Display Name', value: '{{ user.displayName ?: "Not set" }}' }
                ],
                actions: [
                    { label: 'Edit Profile', url: '{{ role_path("profile_edit") }}', class: 'primary' }
                ]
            },
            {
                id: 'role',
                title: 'User Role',
                value: '{{ user.isAdmin() ? "Admin" : (user.isStaff() ? "Staff" : "User") }}',
                badge: 'Access',
                icon: '{{ user.isAdmin() ? "fa-crown" : (user.isStaff() ? "fa-id-badge" : "fa-user") }}',
                colorCode: '{{ user.isAdmin() ? "#8b5cf6" : (user.isStaff() ? "#10b981" : "#6b7280") }}',
                description: 'Your role determines your access level and permissions within the system',
                meta: [
                    { icon: 'fa-shield-alt', label: 'Role', value: '{{ user.isAdmin() ? "Administrator" : (user.isStaff() ? "Staff Member" : "User") }}' },
                    { icon: 'fa-check-circle', label: 'Status', value: '{{ user.isActive ? "Active" : "Inactive" }}' },
                    { icon: 'fa-calendar', label: 'Member Since', value: '{{ user.createdAt ? user.createdAt|date("M Y") : "Unknown" }}' }
                ],
                actions: []
            },
            {
                id: 'activity',
                title: 'Activity Logs',
                value: '{{ user.activityLogs|length }}',
                badge: 'History',
                icon: 'fa-history',
                colorCode: '#ec4899',
                description: 'Your recent activity and actions within the system',
                meta: [
                    { icon: 'fa-list', label: 'Total Activities', value: '{{ user.activityLogs|length }}' },
                    { icon: 'fa-clock', label: 'Last Activity', value: '{{ user.activityLogs|first ? user.activityLogs|first.createdAt|date("M d, Y") : "No activity" }}' },
                    { icon: 'fa-calendar-check', label: 'This Month', value: 'N/A' }
                ],
                actions: [
                    {% if is_granted('ROLE_ADMIN') %}
                        { label: 'View All Logs', url: '{{ path("app_admin_activity_logs_index") }}', class: 'primary' }
                    {% endif %}
                ]
            }
            {% if user.zodiacSign or user.bio %},
            {
                id: 'personal',
                title: 'Personal Details',
                value: '{{ user.zodiacSign ?: "Custom" }}',
                badge: 'Info',
                icon: 'fa-star',
                colorCode: '#f59e0b',
                description: '{{ user.bio ? user.bio|e('js') : "Your personal information and preferences" }}',
                meta: [
                    {% if user.zodiacSign %}
                        { icon: 'fa-moon', label: 'Zodiac Sign', value: '{{ user.zodiacSign }}' },
                    {% endif %}
                    { icon: 'fa-align-left', label: 'Bio', value: '{{ user.bio ? "Set" : "Not set" }}' },
                    { icon: 'fa-info-circle', label: 'Profile', value: '{{ user.profilePicture ? "Has Picture" : "No Picture" }}' }
                ],
                actions: [
                    { label: 'Update Details', url: '{{ role_path("profile_edit") }}', class: 'primary' }
                ]
            }
            {% endif %}
        ];

        function adjustColor(color, amount) {
            const num = parseInt(color.replace("#",""), 16);
            const r = Math.min(255, Math.max(0, (num >> 16) + amount));
            const g = Math.min(255, Math.max(0, ((num >> 8) & 0x00FF) + amount));
            const b = Math.min(255, Math.max(0, (num & 0x0000FF) + amount));
            return "#" + ((r << 16) | (g << 8) | b).toString(16).padStart(6, '0');
        }

        function renderProfileGrid() {
            const container = document.getElementById('profileGrid');
            container.innerHTML = '';

            profileData.forEach((stat) => {
                const card = document.createElement('div');
                card.className = 'profile-card bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-lg hover:border-gray-200 transition-all duration-300 cursor-pointer group';
                
                card.innerHTML = `
                    <div class="flex items-start justify-between mb-4">
                        <div class="profile-icon-wrapper" style="background: linear-gradient(135deg, ${stat.colorCode}20, ${stat.colorCode}10);">
                            <i class="fas ${stat.icon}" style="color: ${stat.colorCode};"></i>
                        </div>
                        <span class="profile-badge" style="background: ${stat.colorCode}15; color: ${stat.colorCode};">${stat.badge}</span>
                    </div>
                    <h3 class="profile-title">${stat.title}</h3>
                    <p class="profile-description">${stat.description}</p>
                    <div class="profile-meta">
                        ${stat.meta.map(meta => `
                            <div class="meta-row">
                                <i class="fas ${meta.icon}" style="color: ${stat.colorCode};"></i>
                                <span class="meta-label">${meta.label}:</span>
                                <span class="meta-value">${meta.value}</span>
                            </div>
                        `).join('')}
                    </div>
                    <div class="profile-actions">
                        ${stat.actions.map(action => `
                            <a href="${action.url}" class="profile-action-btn ${action.class}">
                                <i class="fas fa-arrow-right"></i>
                                ${action.label}
                            </a>
                        `).join('')}
                    </div>
                `;
                container.appendChild(card);
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            renderProfileGrid();
            
            const sidebarToggle = document.getElementById('sidebarToggle');
            const sidebar = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');
            
            if (sidebarToggle && sidebar && sidebarOverlay) {
                sidebarToggle.addEventListener('click', function() {
                    sidebar.classList.toggle('active');
                    sidebarOverlay.classList.toggle('active');
                });
                
                sidebarOverlay.addEventListener('click', function() {
                    sidebar.classList.remove('active');
                    sidebarOverlay.classList.remove('active');
                });
            }
        });
    </script>
{% endblock %}
