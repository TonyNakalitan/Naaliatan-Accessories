{% extends 'base.html.twig' %}

{% block title %}Settings - Edit Profile{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('ProfileManagementFolder/edit.css') }}?v={{ random() }}">
{% endblock %}

{% block body %}
<div id="settings-app-wrapper" class="min-h-screen">

    <!-- Sidebar Overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <img src="{{ asset('images/NA.png') }}" alt="Naaliatan's Accessories" class="sidebar-logo">
        </div>
        <nav class="sidebar-nav">
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin_dashboard') }}" class="nav-item">
                    <i class="fas fa-chart-line"></i>
                    <span>Dashboard</span>
                </a>
                <a href="{{ path('app_admin_user_management_index') }}" class="nav-item">
                    <i class="fas fa-users"></i>
                    <span>User Management</span>
                </a>
                <a href="{{ path('app_admin_product_management_index') }}" class="nav-item">
                    <i class="fas fa-box-open"></i>
                    <span>Products</span>
                </a>
                <a href="{{ path('app_admin_stock_management_index') }}" class="nav-item">
                    <i class="fas fa-warehouse"></i>
                    <span>Stock Control</span>
                </a>
                <a href="{{ path('app_admin_order_index') }}" class="nav-item">
                    <i class="fas fa-shopping-bag"></i>
                    <span>Orders</span>
                </a>
                <a href="{{ path('app_admin_item_management_index') }}" class="nav-item">
                    <i class="fas fa-boxes"></i>
                    <span>Items</span>
                </a>
                <a href="{{ path('app_admin_cart_index') }}" class="nav-item">
                    <i class="fas fa-shopping-cart"></i>
                    <span>Cart</span>
                </a>
                <a href="{{ path('app_admin_character_management_index') }}" class="nav-item">
                    <i class="fas fa-id-badge"></i>
                    <span>Characters</span>
                </a>
                <a href="{{ path('app_admin_activity_logs_index') }}" class="nav-item">
                    <i class="fas fa-history"></i>
                    <span>Activity Logs</span>
                </a>
            {% elseif is_granted('ROLE_STAFF') %}
                <a href="{{ path('app_staff_dashboard') }}" class="nav-item">
                    <i class="fas fa-chart-line"></i>
                    <span>Dashboard</span>
                </a>
            {% endif %}
        </nav>
        <div class="sidebar-footer">
            <a href="{{ role_path('profile_edit') }}" class="nav-item active">
                <i class="fas fa-user-circle"></i>
                <span>Settings</span>
            </a>
            <a href="{{ path('app_logout') }}" class="nav-item" onclick="return confirm('Are you sure you want to logout?')">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- App Wrapper -->
    <div id="app" class="relative w-full min-h-screen glass-container">
        
        <!-- Header -->
        <header class="relative z-50 flex items-center justify-between px-10 py-8">
            <div class="flex items-center gap-3">
                <button class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/80 hover:bg-white border border-gray-200 hover:shadow-md transition-all text-gray-700 hover:text-gray-900" id="sidebarToggle" title="Toggle Sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="text-3xl font-bold tracking-tighter text-gray-800">
                    Settings
                </span>
            </div>

            <div class="flex items-center gap-6">
                <a href="{{ role_path('profile_show') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors">
                    {% if app.user.profilePicture %}
                        <img src="{{ asset('images/profiles/' ~ app.user.profilePicture) }}" alt="Profile" class="w-10 h-10 rounded-full object-cover border-2 border-white shadow-md">
                    {% else %}
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 text-white font-bold text-sm">
                            {% set displayText = app.user.displayName ?: app.user.username %}
                            {% set words = displayText|split(' ') %}
                            {% if words|length > 1 %}
                                {{ words[0]|slice(0, 1)|upper }}{{ words[1]|slice(0, 1)|upper }}
                            {% else %}
                                {{ displayText|slice(0, 2)|upper }}
                            {% endif %}
                        </div>
                    {% endif %}
                    <div class="flex flex-col items-start">
                        <span class="font-semibold text-gray-800 text-sm">{{ app.user.displayName ?: app.user.username }}</span>
                        <span class="text-xs text-gray-500">
                            {% if app.user.isAdmin() %}Admin{% elseif app.user.isStaff() %}Staff{% else %}User{% endif %}
                        </span>
                    </div>
                </a>
            </div>
        </header>

        <!-- Main Content -->
        <main class="relative px-12 pb-12">
            
            {% if app.flashes('success') %}
                <div class="mb-6 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-800 shadow-sm">
                    {% for message in app.flashes('success') %}
                        <p class="text-sm"><i class="fas fa-check-circle mr-2"></i>{{ message }}</p>
                    {% endfor %}
                </div>
            {% endif %}

            {% if app.flashes('error') %}
                <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-800 shadow-sm">
                    {% for message in app.flashes('error') %}
                        <p class="text-sm"><i class="fas fa-exclamation-circle mr-2"></i>{{ message }}</p>
                    {% endfor %}
                </div>
            {% endif %}

            {{ form_start(form, {'attr': {'id': 'profileForm', 'novalidate': 'novalidate'}}) }}

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                
                <!-- Left Column: Settings Cards -->
                <div class="lg:col-span-2 space-y-6">
                    
                    <!-- Basic Information Card -->
                    <div class="settings-card">
                        <div class="card-header">
                            <div class="flex items-center gap-3">
                                <div class="icon-wrapper bg-gradient-to-br from-blue-500 to-blue-600">
                                    <i class="fas fa-user"></i>
                                </div>
                                <div>
                                    <h3 class="card-title">Basic Information</h3>
                                    <p class="card-subtitle">Update your personal details</p>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="form-label">Display Name</label>
                                    {{ form_widget(form.displayName, {'attr': {'class': 'form-input', 'placeholder': 'e.g. John Doe', 'oninput': 'syncPreview("displayName", this.value)'}}) }}
                                    {{ form_errors(form.displayName) }}
                                </div>
                                <div>
                                    <label class="form-label">Email Address</label>
                                    {{ form_widget(form.email, {'attr': {'class': 'form-input', 'placeholder': 'your@email.com', 'oninput': 'syncPreview("email", this.value)'}}) }}
                                    {{ form_errors(form.email) }}
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Profile Picture Card -->
                    <div class="settings-card">
                        <div class="card-header">
                            <div class="flex items-center gap-3">
                                <div class="icon-wrapper bg-gradient-to-br from-purple-500 to-purple-600">
                                    <i class="fas fa-image"></i>
                                </div>
                                <div>
                                    <h3 class="card-title">Profile Picture</h3>
                                    <p class="card-subtitle">Upload your profile photo</p>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="drop-zone" id="dropZone">
                                <div style="display: none;">
                                    {{ form_widget(form.profilePicture, {'attr': {'class': 'file-input-hidden', 'onchange': 'handleFile(this)', 'accept': 'image/*'}}) }}
                                </div>
                                <div id="dropZoneUI" {% if user.profilePicture %}class="hidden"{% endif %}>
                                    <div class="upload-icon">
                                        <i class="fas fa-cloud-arrow-up"></i>
                                    </div>
                                    <p class="upload-title">Upload Profile Photo</p>
                                    <p class="upload-subtitle">Drag and drop your file here, or <span class="text-blue-600 cursor-pointer hover:underline">browse</span></p>
                                    <p class="upload-info">Supports: JPG, PNG (Max 10MB)</p>
                                </div>
                                <div id="previewContainer" {% if not user.profilePicture %}class="hidden"{% endif %}>
                                    <div class="relative inline-block group">
                                        <img src="{% if user.profilePicture %}{{ asset('images/profiles/' ~ user.profilePicture) }}{% endif %}" id="imgResult" class="preview-image">
                                        <button type="button" onclick="resetFile(event)" class="remove-image-btn">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            {{ form_errors(form.profilePicture) }}
                        </div>
                    </div>

                    <!-- Personal Details Card -->
                    <div class="settings-card">
                        <div class="card-header">
                            <div class="flex items-center gap-3">
                                <div class="icon-wrapper bg-gradient-to-br from-green-500 to-green-600">
                                    <i class="fas fa-id-card"></i>
                                </div>
                                <div>
                                    <h3 class="card-title">Personal Details</h3>
                                    <p class="card-subtitle">Tell us more about yourself</p>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="space-y-6">
                                <div>
                                    <label class="form-label">Bio</label>
                                    {{ form_widget(form.bio, {'attr': {'class': 'form-input', 'rows': '4', 'placeholder': 'Tell us about yourself...', 'oninput': 'syncPreview("bio", this.value)'}}) }}
                                    {{ form_errors(form.bio) }}
                                </div>

                                <div>
                                    <label class="form-label">Zodiac Sign</label>
                                    <div style="display: none;">
                                        {{ form_widget(form.zodiacSign) }}
                                    </div>
                                    {{ form_errors(form.zodiacSign) }}
                                    
                                    <div class="zodiac-grid" id="zodiacGrid">
                                        {% set zodiacSigns = ['Aries', 'Taurus', 'Gemini', 'Cancer', 'Leo', 'Virgo', 'Libra', 'Scorpio', 'Sagittarius', 'Capricorn', 'Aquarius', 'Pisces'] %}
                                        {% set zodiacSymbols = {'Aries': '♈', 'Taurus': '♉', 'Gemini': '♊', 'Cancer': '♋', 'Leo': '♌', 'Virgo': '♍', 'Libra': '♎', 'Scorpio': '♏', 'Sagittarius': '♐', 'Capricorn': '♑', 'Aquarius': '♒', 'Pisces': '♓'} %}
                                        {% for sign in zodiacSigns %}
                                        <div class="zodiac-card {% if user.zodiacSign == sign %}selected{% endif %}" onclick="selectZodiac(this, '{{ sign }}')">
                                            <div class="zodiac-check"><i class="fas fa-check"></i></div>
                                            <div class="zodiac-symbol">{{ zodiacSymbols[sign] }}</div>
                                            <p class="zodiac-name">{{ sign }}</p>
                                        </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Security Card -->
                    <div class="settings-card">
                        <div class="card-header">
                            <div class="flex items-center gap-3">
                                <div class="icon-wrapper bg-gradient-to-br from-red-500 to-red-600">
                                    <i class="fas fa-lock"></i>
                                </div>
                                <div>
                                    <h3 class="card-title">Security</h3>
                                    <p class="card-subtitle">Update your password</p>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="info-box mb-6">
                                <i class="fas fa-info-circle"></i>
                                <div>
                                    <p class="font-semibold">Password Update</p>
                                    <p class="text-sm">Leave the password field empty to keep your current password.</p>
                                </div>
                            </div>

                            <div>
                                <label class="form-label">New Password (Optional)</label>
                                <div class="relative">
                                    {{ form_widget(form.plainPassword, {'attr': {'class': 'form-input pr-12', 'placeholder': 'Leave empty to keep current password', 'id': 'passwordInput'}}) }}
                                    <button type="button" onclick="togglePassword()" class="password-toggle">
                                        <i class="fas fa-eye" id="toggleIcon"></i>
                                    </button>
                                </div>
                                {{ form_errors(form.plainPassword) }}
                                
                                <div class="mt-3" id="passwordStrengthContainer" style="display: none;">
                                    <div class="strength-bars">
                                        <div class="strength-bar" data-level="1"></div>
                                        <div class="strength-bar" data-level="2"></div>
                                        <div class="strength-bar" data-level="3"></div>
                                        <div class="strength-bar" data-level="4"></div>
                                    </div>
                                    <p class="text-xs text-gray-500 mt-2" id="strengthText">Password strength: <span class="font-semibold">Not set</span></p>
                                </div>
                            </div>

                            <div class="password-requirements">
                                <h4 class="requirements-title">Password Requirements</h4>
                                <ul class="requirements-list">
                                    <li id="req-length"><i class="fas fa-check-circle"></i> At least 8 characters</li>
                                    <li id="req-uppercase"><i class="fas fa-check-circle"></i> One uppercase letter</li>
                                    <li id="req-lowercase"><i class="fas fa-check-circle"></i> One lowercase letter</li>
                                    <li id="req-number"><i class="fas fa-check-circle"></i> One number</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex items-center justify-between gap-4">
                        <a href="{{ role_path('profile_show') }}" class="btn-secondary">
                            <i class="fas fa-arrow-left mr-2"></i> Cancel
                        </a>
                        <button type="submit" class="btn-primary" id="submitBtn">
                            <span id="submitBtnText">
                                <i class="fas fa-save mr-2"></i> Save Changes
                            </span>
                            <span id="submitBtnLoading" class="hidden">
                                <i class="fas fa-spinner fa-spin mr-2"></i> Saving...
                            </span>
                        </button>
                    </div>
                </div>

                <!-- Right Column: Live Preview -->
                <div class="lg:col-span-1">
                    <div class="preview-card sticky top-8">
                        <div class="preview-header">
                            <div class="flex items-center gap-2">
                                <div class="preview-indicator"></div>
                                <span class="preview-label">Live Preview</span>
                            </div>
                            <span class="preview-badge">Editing</span>
                        </div>
                        
                        <div class="preview-body">
                            <div class="preview-avatar-container">
                                {% if user.profilePicture %}
                                    <img src="{{ asset('images/profiles/' ~ user.profilePicture) }}" id="previewAvatar" class="preview-avatar-img">
                                {% else %}
                                    <div class="preview-avatar-placeholder">
                                        <span id="previewInitial">{{ user.displayName|default(user.username)|slice(0,1)|upper }}</span>
                                    </div>
                                {% endif %}
                            </div>
                            <h2 id="previewDisplayName" class="preview-name">{{ user.displayName ?: user.username }}</h2>
                            <p id="previewEmail" class="preview-email">{{ user.email }}</p>
                            
                            <div class="preview-role">
                                {% if user.isAdmin() %}
                                    <span class="role-badge role-admin">
                                        <i class="fas fa-crown"></i> Admin
                                    </span>
                                {% elseif user.isStaff() %}
                                    <span class="role-badge role-staff">
                                        <i class="fas fa-id-badge"></i> Staff
                                    </span>
                                {% else %}
                                    <span class="role-badge role-user">
                                        <i class="fas fa-user"></i> User
                                    </span>
                                {% endif %}
                            </div>
                        </div>

                        <div class="preview-footer">
                            <div class="preview-section">
                                <h4 class="preview-section-title">About</h4>
                                <p id="previewBio" class="preview-bio">{{ user.bio ?: 'No bio added yet.' }}</p>
                            </div>
                            
                            <div class="preview-section">
                                <h4 class="preview-section-title">Zodiac Sign</h4>
                                <div class="flex items-center gap-2">
                                    <p id="previewZodiacSymbol" class="text-2xl">
                                        {% set zodiacSymbols = {'Aries': '♈', 'Taurus': '♉', 'Gemini': '♊', 'Cancer': '♋', 'Leo': '♌', 'Virgo': '♍', 'Libra': '♎', 'Scorpio': '♏', 'Sagittarius': '♐', 'Capricorn': '♑', 'Aquarius': '♒', 'Pisces': '♓'} %}
                                        {% if user.zodiacSign %}
                                            {{ zodiacSymbols[user.zodiacSign] }}
                                        {% else %}
                                            <span class="text-sm text-gray-400">—</span>
                                        {% endif %}
                                    </p>
                                    <p id="previewZodiacName" class="text-sm font-bold text-gray-700">{{ user.zodiacSign ?: 'None' }}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {{ form_rest(form) }}
            {{ form_end(form) }}
        </main>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('ProfileManagementFolder/edit.js') }}"></script>
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
    <script>
        // Sidebar Toggle
        document.addEventListener('DOMContentLoaded', function() {
            const sidebarToggle = document.getElementById('sidebarToggle');
            const sidebar = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');
            
            if (sidebarToggle && sidebar && sidebarOverlay) {
                sidebarToggle.addEventListener('click', function() {
                    sidebar.classList.toggle('active');
                    sidebarOverlay.classList.toggle('active');
                });
                
                sidebarOverlay.addEventListener('click', function() {
                    sidebar.classList.remove('active');
                    sidebarOverlay.classList.remove('active');
                });
            }
        });
    </script>
{% endblock %}
