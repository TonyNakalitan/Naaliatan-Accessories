<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile | Naaliatan</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="{{ asset('ProfileManagementFolder/edit.css?v=' ~ random()) }}">
</head>
<body class="min-h-screen">

    <div class="flex h-screen">
        <main class="flex-grow flex flex-col overflow-y-auto w-full bg-slate-50">
            <div class="w-full p-4 sm:p-6 lg:p-8">

                {% if app.flashes('success') %}
                    <div class="mb-4 sm:mb-6 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-800 shadow-sm">
                        {% for message in app.flashes('success') %}
                            <p class="text-sm sm:text-base"><i class="fas fa-check-circle mr-2"></i>{{ message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if app.flashes('error') %}
                    <div class="mb-4 sm:mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-800 shadow-sm">
                        {% for message in app.flashes('error') %}
                            <p class="text-sm sm:text-base"><i class="fas fa-exclamation-circle mr-2"></i>{{ message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}

                <!-- Main Container -->
                <div class="bg-gradient-to-br from-white via-indigo-50/30 to-purple-50/30 rounded-2xl sm:rounded-3xl p-4 sm:p-6 lg:p-8 shadow-xl border border-white/50">
                    
                    <!-- Header with Back Button Inside Container -->
                    <div class="mb-6 sm:mb-8 flex flex-col sm:flex-row items-start justify-between gap-4">
                        <div class="flex-1">
                            <div class="flex items-center gap-3 mb-3">
                                <div class="w-10 h-10 sm:w-12 sm:h-12 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-200">
                                    <i class="fas fa-user-edit text-white text-lg sm:text-xl"></i>
                                </div>
                                <h1 class="text-2xl sm:text-3xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
                                    Edit Profile
                                </h1>
                            </div>
                            <p class="text-slate-600 text-sm sm:text-base">Update your personal information and preferences.</p>
                        </div>
                        <a href="{{ role_path('profile_show') }}" class="w-full sm:w-auto px-4 sm:px-6 py-2.5 sm:py-3 bg-white/80 backdrop-blur-sm text-slate-700 font-semibold rounded-xl hover:bg-white hover:shadow-lg transition-all flex items-center justify-center gap-2 text-sm sm:text-base whitespace-nowrap border border-slate-200">
                            <i class="fas fa-arrow-left"></i>
                            <span class="hidden sm:inline">Back to Profile</span>
                            <span class="sm:hidden">Back</span>
                        </a>
                    </div>

                    {{ form_start(form, {'attr': {'id': 'profileForm', 'novalidate': 'novalidate'}}) }}

                <!-- Wizard Wrapper -->
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-start">
                    
                    <div class="lg:col-span-8">
                        <div class="glass-panel rounded-2xl sm:rounded-3xl p-4 sm:p-6 lg:p-8 mb-6 border border-white/50">
                            
                            <div class="flex gap-2 sm:gap-4 mb-8 sm:mb-10 overflow-x-auto pb-2 scrollbar-hide">
                                <div class="step-pill active min-w-[80px] sm:min-w-0" id="pill-1">
                                    <div class="step-number">1</div>
                                    <div>
                                        <span class="text-[10px] sm:text-xs font-bold uppercase tracking-wider">Step 1</span>
                                        <p class="text-xs sm:text-sm font-semibold">Basic Info</p>
                                    </div>
                                </div>
                                <div class="step-pill min-w-[80px] sm:min-w-0" id="pill-2">
                                    <div class="step-number">2</div>
                                    <div>
                                        <span class="text-[10px] sm:text-xs font-bold uppercase tracking-wider">Step 2</span>
                                        <p class="text-xs sm:text-sm font-semibold">Personal</p>
                                    </div>
                                </div>
                                <div class="step-pill min-w-[80px] sm:min-w-0" id="pill-3">
                                    <div class="step-number">3</div>
                                    <div>
                                        <span class="text-[10px] sm:text-xs font-bold uppercase tracking-wider">Step 3</span>
                                        <p class="text-xs sm:text-sm font-semibold">Security</p>
                                    </div>
                                </div>
                                <div class="step-pill min-w-[80px] sm:min-w-0" id="pill-4">
                                    <div class="step-number">4</div>
                                    <div>
                                        <span class="text-[10px] sm:text-xs font-bold uppercase tracking-wider">Step 4</span>
                                        <p class="text-xs sm:text-sm font-semibold">Review</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 1: Basic Info -->
                            <div class="step-content active fade-in" data-step="1">
                                <div class="space-y-4 sm:space-y-6">
                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
                                        <div class="col-span-1">
                                            <label class="block text-xs sm:text-sm font-bold text-slate-700 mb-2">Display Name</label>
                                            {{ form_widget(form.displayName, {'attr': {'class': 'form-input-styled text-sm sm:text-base', 'placeholder': 'e.g. John Doe', 'oninput': 'syncPreview("displayName", this.value)'}}) }}
                                            {{ form_errors(form.displayName) }}
                                        </div>
                                        <div class="col-span-1">
                                            <label class="block text-xs sm:text-sm font-bold text-slate-700 mb-2">Email Address</label>
                                            {{ form_widget(form.email, {'attr': {'class': 'form-input-styled text-sm sm:text-base', 'placeholder': 'your@email.com', 'oninput': 'syncPreview("email", this.value)'}}) }}
                                            {{ form_errors(form.email) }}
                                        </div>
                                    </div>
                                    <div>
                                        <label class="block text-xs sm:text-sm font-bold text-slate-700 mb-2">Profile Picture</label>
                                        <div class="drop-zone rounded-2xl p-6 sm:p-10 text-center relative" id="dropZone">
                                            <div style="display: none;">
                                                {{ form_widget(form.profilePicture, {'attr': {'class': 'file-input-hidden', 'onchange': 'handleFile(this)', 'accept': 'image/*'}}) }}
                                            </div>
                                            <div id="dropZoneUI" {% if user.profilePicture %}class="hidden"{% endif %}>
                                                <div class="w-12 h-12 sm:w-16 sm:h-16 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mx-auto mb-3 sm:mb-4 text-xl sm:text-2xl">
                                                    <i class="fas fa-cloud-arrow-up"></i>
                                                </div>
                                                <p class="text-slate-900 font-bold text-sm sm:text-base">Upload Profile Photo</p>
                                                <p class="text-slate-500 text-xs sm:text-sm mt-1">Drag and drop your file here, or <span class="text-indigo-600 cursor-pointer hover:underline">browse</span></p>
                                                <p class="text-slate-400 text-[10px] sm:text-xs mt-3 sm:mt-4 uppercase tracking-widest font-semibold">Supports: JPG, PNG (Max 10MB)</p>
                                            </div>
                                            <div id="previewContainer" {% if not user.profilePicture %}class="hidden"{% endif %}>
                                                <div class="relative inline-block group">
                                                    <img src="{% if user.profilePicture %}{{ asset('images/profiles/' ~ user.profilePicture) }}{% endif %}" id="imgResult" class="max-h-32 sm:max-h-48 rounded-xl shadow-lg border-4 border-white">
                                                    <button type="button" onclick="resetFile(event)" class="absolute -top-2 -right-2 sm:-top-3 sm:-right-3 w-7 h-7 sm:w-8 sm:h-8 bg-red-500 text-white rounded-full flex items-center justify-center shadow-lg transition-transform hover:scale-110 text-xs sm:text-sm">
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        {{ form_errors(form.profilePicture) }}
                                    </div>
                                </div>
                                
                                <!-- PRO TIP for Step 1 -->
                                <div class="mt-6 p-3 sm:p-4 bg-amber-50 rounded-2xl border border-amber-100 flex gap-3 sm:gap-4">
                                    <div class="text-amber-500 mt-1 text-sm sm:text-base"><i class="fas fa-lightbulb"></i></div>
                                    <p class="text-[10px] sm:text-xs text-amber-800 leading-relaxed">
                                        <span class="font-bold block mb-1">PRO TIP</span>
                                        Use a clear profile picture to help your colleagues recognize you easily in the system.
                                    </p>
                                </div>
                            </div>

                            <!-- Step 2: Personal Details -->
                            <div class="step-content fade-in" data-step="2">
                                <div class="space-y-6 sm:space-y-8">
                                    <div>
                                        <label class="block text-xs sm:text-sm font-bold text-slate-700 mb-2">Bio</label>
                                        {{ form_widget(form.bio, {'attr': {'class': 'form-input-styled text-sm sm:text-base', 'rows': '4', 'placeholder': 'Tell us about yourself...', 'oninput': 'syncPreview("bio", this.value)'}}) }}
                                        {{ form_errors(form.bio) }}
                                    </div>

                                    <div>
                                        <label class="block text-xs sm:text-sm font-bold text-slate-700 mb-4">Zodiac Sign</label>
                                        <div style="display: none;">
                                            {{ form_widget(form.zodiacSign) }}
                                        </div>
                                        {{ form_errors(form.zodiacSign) }}
                                        
                                        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-4" id="zodiacGrid">
                                            {% set zodiacSigns = ['Aries', 'Taurus', 'Gemini', 'Cancer', 'Leo', 'Virgo', 'Libra', 'Scorpio', 'Sagittarius', 'Capricorn', 'Aquarius', 'Pisces'] %}
                                            {% set zodiacSymbols = {'Aries': '♈', 'Taurus': '♉', 'Gemini': '♊', 'Cancer': '♋', 'Leo': '♌', 'Virgo': '♍', 'Libra': '♎', 'Scorpio': '♏', 'Sagittarius': '♐', 'Capricorn': '♑', 'Aquarius': '♒', 'Pisces': '♓'} %}
                                            {% for sign in zodiacSigns %}
                                            <div class="zodiac-card bg-slate-100 group {% if user.zodiacSign == sign %}selected{% endif %}" onclick="selectZodiac(this, '{{ sign }}')">
                                                <div class="check-badge"><i class="fas fa-check text-[10px]"></i></div>
                                                <div class="text-3xl mb-2">{{ zodiacSymbols[sign] }}</div>
                                                <p class="text-xs sm:text-sm font-bold text-slate-700">{{ sign }}</p>
                                            </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- PRO TIP for Step 2 -->
                                <div class="mt-6 p-3 sm:p-4 bg-amber-50 rounded-2xl border border-amber-100 flex gap-3 sm:gap-4">
                                    <div class="text-amber-500 mt-1 text-sm sm:text-base"><i class="fas fa-lightbulb"></i></div>
                                    <p class="text-[10px] sm:text-xs text-amber-800 leading-relaxed">
                                        <span class="font-bold block mb-1">PRO TIP</span>
                                        Adding a bio and zodiac sign helps personalize your profile and makes it easier for team members to connect with you.
                                    </p>
                                </div>
                            </div>

                            <!-- Step 3: Security -->
                            <div class="step-content fade-in" data-step="3">
                                <div class="space-y-6 sm:space-y-8">
                                    <div class="bg-blue-50 rounded-2xl p-4 sm:p-6 border border-blue-100 flex gap-3 sm:gap-4 mb-6">
                                        <div class="text-blue-500 mt-1 text-sm sm:text-base"><i class="fas fa-info-circle"></i></div>
                                        <p class="text-[10px] sm:text-xs text-blue-800 leading-relaxed">
                                            <span class="font-bold block mb-1">PASSWORD UPDATE</span>
                                            Leave the password field empty to keep your current password. Only enter a new password if you want to change it.
                                        </p>
                                    </div>

                                    <div>
                                        <label class="block text-xs sm:text-sm font-bold text-slate-700 mb-2">New Password (Optional)</label>
                                        <div class="relative">
                                            {{ form_widget(form.plainPassword, {'attr': {'class': 'form-input-styled text-sm sm:text-base pr-12', 'placeholder': 'Leave empty to keep current password', 'id': 'passwordInput'}}) }}
                                            <button type="button" onclick="togglePassword()" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors">
                                                <i class="fas fa-eye" id="toggleIcon"></i>
                                            </button>
                                        </div>
                                        {{ form_errors(form.plainPassword) }}
                                        
                                        <!-- Password Strength Indicator -->
                                        <div class="mt-3" id="passwordStrengthContainer" style="display: none;">
                                            <div class="flex gap-1 mb-2">
                                                <div class="h-1.5 flex-1 bg-slate-200 rounded-full strength-bar" data-level="1"></div>
                                                <div class="h-1.5 flex-1 bg-slate-200 rounded-full strength-bar" data-level="2"></div>
                                                <div class="h-1.5 flex-1 bg-slate-200 rounded-full strength-bar" data-level="3"></div>
                                                <div class="h-1.5 flex-1 bg-slate-200 rounded-full strength-bar" data-level="4"></div>
                                            </div>
                                            <p class="text-xs text-slate-500" id="strengthText">Password strength: <span class="font-semibold">Not set</span></p>
                                        </div>
                                    </div>

                                    <div class="bg-slate-50 rounded-2xl p-4 sm:p-6 border border-slate-200">
                                        <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Password Requirements</h4>
                                        <ul class="space-y-2">
                                            <li class="flex items-center gap-2 text-xs sm:text-sm text-slate-600">
                                                <i class="fas fa-check-circle text-slate-300" id="req-length"></i>
                                                At least 8 characters
                                            </li>
                                            <li class="flex items-center gap-2 text-xs sm:text-sm text-slate-600">
                                                <i class="fas fa-check-circle text-slate-300" id="req-uppercase"></i>
                                                One uppercase letter
                                            </li>
                                            <li class="flex items-center gap-2 text-xs sm:text-sm text-slate-600">
                                                <i class="fas fa-check-circle text-slate-300" id="req-lowercase"></i>
                                                One lowercase letter
                                            </li>
                                            <li class="flex items-center gap-2 text-xs sm:text-sm text-slate-600">
                                                <i class="fas fa-check-circle text-slate-300" id="req-number"></i>
                                                One number
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                                
                                <!-- PRO TIP for Step 3 -->
                                <div class="mt-6 p-3 sm:p-4 bg-amber-50 rounded-2xl border border-amber-100 flex gap-3 sm:gap-4">
                                    <div class="text-amber-500 mt-1 text-sm sm:text-base"><i class="fas fa-lightbulb"></i></div>
                                    <p class="text-[10px] sm:text-xs text-amber-800 leading-relaxed">
                                        <span class="font-bold block mb-1">PRO TIP</span>
                                        Use a strong, unique password that you don't use on other websites. Consider using a password manager to keep track of your passwords securely.
                                    </p>
                                </div>
                            </div>

                            <!-- Step 4: Review -->
                            <div class="step-content fade-in" data-step="4">
                                <div class="bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-600 rounded-2xl p-6 text-white mb-8 flex items-center gap-6 shadow-xl shadow-indigo-200 relative overflow-hidden">
                                    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-30"></div>
                                    <div class="w-14 h-14 bg-white/20 backdrop-blur-sm rounded-2xl flex items-center justify-center text-2xl relative z-10 animate-bounce-slow">
                                        <i class="fas fa-save"></i>
                                    </div>
                                    <div class="relative z-10">
                                        <h3 class="text-lg font-bold">Ready to Update!</h3>
                                        <p class="text-white/90 text-sm">Please verify your changes on the right before saving.</p>
                                    </div>
                                </div>

                                <div class="space-y-6">
                                    <div class="bg-slate-50 rounded-2xl p-6 border border-slate-200">
                                        <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">Checklist</h4>
                                        <ul class="space-y-3">
                                            <li class="flex items-center gap-3 text-sm font-medium text-slate-700">
                                                <i class="fas fa-check-circle text-emerald-500"></i> Profile information updated
                                            </li>
                                            <li class="flex items-center gap-3 text-sm font-medium text-slate-700">
                                                <i class="fas fa-check-circle text-emerald-500"></i> Personal details verified
                                            </li>
                                            <li class="flex items-center gap-3 text-sm font-medium text-slate-700">
                                                <i class="fas fa-check-circle text-emerald-500"></i> Ready to save changes
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                                
                                <!-- PRO TIP for Step 4 -->
                                <div class="mt-6 p-3 sm:p-4 bg-amber-50 rounded-2xl border border-amber-100 flex gap-3 sm:gap-4">
                                    <div class="text-amber-500 mt-1 text-sm sm:text-base"><i class="fas fa-lightbulb"></i></div>
                                    <p class="text-[10px] sm:text-xs text-amber-800 leading-relaxed">
                                        <span class="font-bold block mb-1">PRO TIP</span>
                                        Review all changes carefully before saving. Your profile updates will be visible to other users immediately.
                                    </p>
                                </div>
                            </div>

                            <div class="mt-8 sm:mt-12 flex flex-col sm:flex-row items-center justify-between gap-3 sm:gap-0">
                                <button type="button" id="prevBtn" onclick="moveStep(-1)" class="w-full sm:w-auto px-6 py-3 text-slate-600 font-bold hover:bg-slate-100 rounded-xl transition-all opacity-0 pointer-events-none text-sm sm:text-base">
                                    <i class="fas fa-arrow-left mr-2"></i> Previous
                                </button>
                                <button type="button" id="nextBtn" onclick="moveStep(1)" class="w-full sm:w-auto px-8 py-3 bg-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-200 hover:bg-indigo-700 hover:-translate-y-0.5 transition-all text-sm sm:text-base">
                                    Next Step <i class="fas fa-arrow-right ml-2"></i>
                                </button>
                                <button type="submit" id="submitBtn" class="w-full sm:w-auto px-8 py-3 bg-emerald-600 text-white font-bold rounded-xl shadow-lg shadow-emerald-200 hover:bg-emerald-700 hover:-translate-y-0.5 transition-all hidden text-sm sm:text-base">
                                    <span id="submitBtnText">Update Profile <i class="fas fa-save ml-2"></i></span>
                                    <span id="submitBtnLoading" class="hidden">
                                        <i class="fas fa-spinner fa-spin mr-2"></i>Updating Profile...
                                    </span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Live Preview Card -->
                    <div class="lg:col-span-4 lg:sticky lg:top-8">
                        <div class="glass-panel rounded-2xl sm:rounded-3xl overflow-hidden border border-white/50 shadow-2xl">
                            <div class="p-3 sm:p-4 border-b border-slate-100 flex items-center justify-between bg-gradient-to-r from-white/80 to-indigo-50/50 backdrop-blur-sm">
                                <div class="flex items-center gap-2">
                                    <div class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></div>
                                    <span class="text-[10px] sm:text-xs font-bold text-slate-600 uppercase tracking-widest">Live Preview</span>
                                </div>
                                <span class="px-2.5 py-1 bg-gradient-to-r from-blue-500 to-indigo-500 text-white text-[9px] sm:text-[10px] font-bold rounded-full uppercase shadow-lg">Editing</span>
                            </div>
                            
                            <div class="p-6 sm:p-8 bg-gradient-to-br from-slate-50 to-slate-100">
                                <div class="flex flex-col items-center text-center">
                                    <div class="w-24 h-24 sm:w-32 sm:h-32 rounded-full flex items-center justify-center mb-4 shadow-xl shadow-indigo-200 overflow-hidden" id="previewAvatarContainer">
                                        {% if user.profilePicture %}
                                            <img src="{{ asset('images/profiles/' ~ user.profilePicture) }}" id="previewAvatar" class="w-full h-full object-cover">
                                        {% else %}
                                            <div class="w-full h-full bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center text-white text-4xl sm:text-5xl font-bold">
                                                <span id="previewInitial">{{ user.displayName|default(user.username)|slice(0,1)|upper }}</span>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <h2 id="previewDisplayName" class="text-xl sm:text-2xl font-bold text-slate-900 mb-1">{{ user.displayName ?: user.username }}</h2>
                                    <p id="previewEmail" class="text-xs text-slate-400 mb-4">{{ user.email }}</p>
                                    
                                    <div class="flex flex-wrap gap-2 justify-center mb-4">
                                        {% if user.isAdmin() %}
                                            <span class="px-3 py-1 bg-gradient-to-r from-purple-500 to-pink-500 text-white rounded-full text-xs font-semibold">
                                                <i class="fas fa-crown"></i> Admin
                                            </span>
                                        {% elseif user.isStaff() %}
                                            <span class="px-3 py-1 bg-gradient-to-r from-blue-500 to-cyan-500 text-white rounded-full text-xs font-semibold">
                                                <i class="fas fa-id-badge"></i> Staff
                                            </span>
                                        {% else %}
                                            <span class="px-3 py-1 bg-gradient-to-r from-slate-400 to-slate-500 text-white rounded-full text-xs font-semibold">
                                                <i class="fas fa-user"></i> User
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            <div class="p-4 sm:p-6 bg-white border-t border-slate-100">
                                <h4 class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">About</h4>
                                <p id="previewBio" class="text-sm text-slate-600 leading-relaxed mb-4">
                                    {{ user.bio ?: 'No bio added yet.' }}
                                </p>
                                
                                <h4 class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Zodiac Sign</h4>
                                <div class="flex items-center gap-2">
                                    <p id="previewZodiacSymbol" class="text-2xl">
                                        {% set zodiacSymbols = {'Aries': '♈', 'Taurus': '♉', 'Gemini': '♊', 'Cancer': '♋', 'Leo': '♌', 'Virgo': '♍', 'Libra': '♎', 'Scorpio': '♏', 'Sagittarius': '♐', 'Capricorn': '♑', 'Aquarius': '♒', 'Pisces': '♓'} %}
                                        {% if user.zodiacSign %}
                                            {{ zodiacSymbols[user.zodiacSign] }}
                                        {% else %}
                                            <span class="text-sm text-slate-400">—</span>
                                        {% endif %}
                                    </p>
                                    <p id="previewZodiacName" class="text-sm font-bold text-slate-700">{{ user.zodiacSign ?: 'None' }}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                {{ form_rest(form) }}
                {{ form_end(form) }}
                </div>
                <!-- End Main Container -->
            </div>
        </main>
    </div>

    <script src="{{ asset('ProfileManagementFolder/edit.js') }}"></script>
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
</body>
</html>
