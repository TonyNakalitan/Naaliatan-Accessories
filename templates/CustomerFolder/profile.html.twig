{% extends 'base.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('DashboardFolder/customer_dashboard.css') }}?v={{ random() }}">
    <style>
        * { font-family: 'Poppins', sans-serif; }

        .page-content {
            padding: 2rem 2.5rem;
            overflow-y: auto;
            height: 100%;
        }

        /* Profile layout */
        .profile-layout {
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 1.5rem;
            align-items: start;
        }

        /* Profile card */
        .profile-card {
            background: #fff;
            border-radius: 20px;
            border: 1px solid #f1f5f9;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            overflow: visible;
            position: sticky;
            top: 0;
        }

        .profile-card-top {
            height: 120px;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border-radius: 20px 20px 0 0;
            position: relative;
        }

        .profile-avatar {
            width: 80px;
            height: 80px;
            border-radius: 20px;
            border: 4px solid #fff;
            box-shadow: 0 6px 20px rgba(0,0,0,0.18);
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.9rem;
            font-weight: 800;
            color: #fff;
            background: linear-gradient(135deg, #2563eb, #7c3aed);
            position: absolute;
            bottom: -40px;
            left: 50%;
            transform: translateX(-50%);
        }
        .profile-avatar img { width: 100%; height: 100%; object-fit: cover; }

        .profile-card-body {
            padding: 3.25rem 1.5rem 1.75rem;
            text-align: center;
        }

        .profile-name {
            font-size: 1.1rem;
            font-weight: 700;
            color: #111827;
            margin-bottom: 0.2rem;
        }

        .profile-email {
            font-size: 0.8rem;
            color: #9ca3af;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.35rem;
        }

        .profile-meta {
            display: flex;
            flex-direction: column;
            gap: 0.65rem;
            text-align: left;
            margin-top: 1.25rem;
            padding-top: 1.25rem;
            border-top: 1px solid #f3f4f6;
        }

        .profile-meta-row {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 0.82rem;
            color: #6b7280;
        }
        .profile-meta-row i {
            width: 28px;
            height: 28px;
            border-radius: 8px;
            background: #f3f4f6;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            color: #6b7280;
            flex-shrink: 0;
        }
        .profile-meta-row span { font-weight: 500; color: #374151; }

        .btn-edit {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            width: 100%;
            padding: 0.75rem;
            border-radius: 14px;
            font-size: 0.85rem;
            font-weight: 600;
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            color: #fff;
            text-decoration: none;
            margin-top: 1.5rem;
            transition: all 0.2s ease;
            box-shadow: 0 4px 14px rgba(59,130,246,0.3);
        }
        .btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(59,130,246,0.4);
            color: #fff;
        }

        /* Bio card */
        .info-card {
            background: #fff;
            border-radius: 20px;
            border: 1px solid #f1f5f9;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            padding: 1.5rem;
        }

        .info-card-title {
            font-size: 1rem;
            font-weight: 700;
            color: #111827;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .info-card-title::before {
            content: '';
            width: 4px;
            height: 18px;
            background: linear-gradient(180deg, #3b82f6, #8b5cf6);
            border-radius: 2px;
        }

        .bio-text {
            font-size: 0.88rem;
            color: #6b7280;
            line-height: 1.7;
        }

        /* Recent orders */
        .order-row {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 0.85rem 0;
            border-bottom: 1px solid #f9fafb;
        }
        .order-row:last-child { border-bottom: none; }

        .order-row-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: #f3f4f6;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 0.9rem;
            color: #9ca3af;
        }

        .order-row-info { flex: 1; min-width: 0; }
        .order-row-number { font-size: 0.88rem; font-weight: 700; color: #111827; }
        .order-row-date { font-size: 0.75rem; color: #9ca3af; margin-top: 0.1rem; }

        .order-row-right { text-align: right; }
        .order-row-amount { font-size: 0.9rem; font-weight: 700; color: #111827; }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
            font-size: 0.68rem;
            font-weight: 600;
            margin-top: 0.25rem;
        }
        .status-pending   { background: #fef9c3; color: #a16207; }
        .status-completed { background: #dcfce7; color: #15803d; }
        .status-cancelled { background: #fee2e2; color: #b91c1c; }

        .btn-ghost-sm {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.4rem 0.85rem;
            border-radius: 9px;
            font-size: 0.75rem;
            font-weight: 600;
            background: #f8fafc;
            color: #64748b;
            border: 1px solid #e5e7eb;
            text-decoration: none;
            transition: all 0.2s ease;
            white-space: nowrap;
        }
        .btn-ghost-sm:hover { background: #f1f5f9; color: #374151; }

        .view-all-link {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            font-size: 0.82rem;
            font-weight: 600;
            color: #3b82f6;
            text-decoration: none;
            margin-top: 1rem;
            padding-top: 0.75rem;
            border-top: 1px solid #f3f4f6;
            transition: color 0.2s;
        }
        .view-all-link:hover { color: #2563eb; }

        /* Empty state */
        .empty-mini {
            text-align: center;
            padding: 2rem 1rem;
            color: #9ca3af;
            font-size: 0.85rem;
        }
        .empty-mini i { font-size: 2rem; display: block; margin-bottom: 0.5rem; opacity: 0.3; }
    </style>
{% endblock %}

{% block body %}
<div id="dashboard-app-wrapper" class="min-h-screen">

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <img src="{{ asset('images/NA.png') }}" alt="Naaliatan's Accessories" class="sidebar-logo">
        </div>
        <nav class="sidebar-nav">
            <a href="{{ path('app_customer_dashboard') }}" class="nav-item">
                <i class="fas fa-chart-line"></i>
                <span>Dashboard</span>
            </a>
            <a href="{{ path('app_customer_characters') }}" class="nav-item">
                <i class="fas fa-user-astronaut"></i>
                <span>Browse Products</span>
            </a>
            <a href="{{ path('app_customer_cart') }}" class="nav-item">
                <i class="fas fa-shopping-cart"></i>
                <span>My Cart</span>
                {% set cartCount = app.user.cart ? app.user.cart.cartItems|length : 0 %}
                {% if cartCount > 0 %}
                    <span class="nav-badge">{{ cartCount }}</span>
                {% endif %}
            </a>
            <a href="{{ path('app_customer_orders') }}" class="nav-item">
                <i class="fas fa-shopping-bag"></i>
                <span>My Orders</span>
            </a>
            <a href="{{ path('app_customer_profile') }}" class="nav-item active">
                <i class="fas fa-user-circle"></i>
                <span>My Profile</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" onclick="return confirm('Are you sure you want to logout?')">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <div id="app" class="relative w-full h-screen glass-container flex flex-col overflow-hidden">

        <!-- Header -->
        <header class="relative z-50 flex items-center justify-between px-10 py-8 flex-shrink-0">
            <div class="flex items-center gap-3">
                <button class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/80 hover:bg-white border border-gray-200 hover:shadow-md transition-all text-gray-700" id="sidebarToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="text-3xl font-bold tracking-tighter text-gray-800">My Profile</span>
            </div>

            <div class="flex items-center gap-6">
                <a href="{{ path('app_customer_profile') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors">
                    {% if app.user.profilePicture %}
                        <img src="{{ app.user.profilePicture|image_url('images/profiles') }}" alt="Profile" class="w-10 h-10 rounded-full object-cover border-2 border-white shadow-md">
                    {% else %}
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 text-white font-bold text-sm">
                            {% set displayText = app.user.displayName ?: app.user.username %}
                            {% set words = displayText|split(' ') %}
                            {% if words|length > 1 %}
                                {{ words[0]|slice(0,1)|upper }}{{ words[1]|slice(0,1)|upper }}
                            {% else %}
                                {{ displayText|slice(0,2)|upper }}
                            {% endif %}
                        </div>
                    {% endif %}
                    <div class="flex flex-col items-start">
                        <span class="font-semibold text-gray-800 text-sm">{{ app.user.displayName ?: app.user.username }}</span>
                        <span class="text-xs text-gray-500">Customer</span>
                    </div>
                </a>
            </div>
        </header>

        <!-- Content -->
        <main class="flex-1 overflow-y-auto page-content">

            <div class="profile-layout">

                <!-- Left: Profile card -->
                <div style="padding-top: 0;">
                    <div class="profile-card">
                        <div class="profile-card-top">
                            <div class="profile-avatar">
                                {% if user.profilePicture %}
                                    <img src="{{ user.profilePicture|image_url('images/profiles') }}" alt="Profile">
                                {% else %}
                                    {% set displayText = user.displayName ?: user.username %}
                                    {% set words = displayText|split(' ') %}
                                    {% if words|length > 1 %}
                                        {{ words[0]|slice(0,1)|upper }}{{ words[1]|slice(0,1)|upper }}
                                    {% else %}
                                        {{ displayText|slice(0,2)|upper }}
                                    {% endif %}
                                {% endif %}
                            </div>
                        </div>
                        <div class="profile-card-body">
                            <div class="profile-name">{{ user.displayName ?: user.username }}</div>
                            <div class="profile-email">
                                <i class="fas fa-envelope"></i>{{ user.email }}
                            </div>

                            <div class="profile-meta">
                                {% if user.zodiacSign %}
                                    <div class="profile-meta-row">
                                        <i class="fas fa-star"></i>
                                        <span>{{ user.zodiacSign }}</span>
                                    </div>
                                {% endif %}
                                <div class="profile-meta-row">
                                    <i class="fas fa-calendar-alt"></i>
                                    <span>Joined {{ user.createdAt ? user.createdAt|date('F Y') : 'N/A' }}</span>
                                </div>
                                <div class="profile-meta-row">
                                    <i class="fas fa-shield-alt"></i>
                                    <span>{{ user.roles|join(', ')|replace({'ROLE_': ''})|capitalize }}</span>
                                </div>
                            </div>

                            <a href="{{ path('app_customer_profile_edit') }}" class="btn-edit">
                                <i class="fas fa-pen"></i> Edit Profile
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Right: Bio + Recent Orders -->
                <div style="display:flex;flex-direction:column;gap:1.5rem;">

                    <!-- Bio -->
                    <div class="info-card">
                        <div class="info-card-title">About Me</div>
                        <p class="bio-text">{{ user.bio ?: 'No bio set yet. Tell others a little about yourself by editing your profile.' }}</p>
                    </div>

                    <!-- Recent Orders -->
                    <div class="info-card">
                        <div class="info-card-title">Recent Orders</div>

                        {% if recentOrders is empty %}
                            <div class="empty-mini">
                                <i class="fas fa-shopping-bag"></i>
                                No orders yet. Start shopping to see them here.
                            </div>
                        {% else %}
                            {% for order in recentOrders %}
                                <div class="order-row">
                                    <div class="order-row-icon">
                                        <i class="fas fa-shopping-bag"></i>
                                    </div>
                                    <div class="order-row-info">
                                        <div class="order-row-number">Order #{{ order.orderNumber }}</div>
                                        <div class="order-row-date">{{ order.createdAt ? order.createdAt|date('F j, Y') : 'N/A' }}</div>
                                    </div>
                                    <div class="order-row-right">
                                        <div class="order-row-amount">₱{{ order.totalAmount|number_format(2) }}</div>
                                        <div>
                                            <span class="status-badge status-{{ order.status }}">{{ order.status|capitalize }}</span>
                                        </div>
                                    </div>
                                    <a href="{{ path('app_customer_order_show', {'id': order.id}) }}" class="btn-ghost-sm">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                </div>
                            {% endfor %}

                            <a href="{{ path('app_customer_orders') }}" class="view-all-link">
                                View all orders <i class="fas fa-arrow-right"></i>
                            </a>
                        {% endif %}
                    </div>

                </div>
            </div>

        </main>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const sidebarToggle  = document.getElementById('sidebarToggle');
            const sidebar        = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');
            sidebarToggle?.addEventListener('click', () => {
                sidebar.classList.toggle('active');
                sidebarOverlay.classList.toggle('active');
            });
            sidebarOverlay?.addEventListener('click', () => {
                sidebar.classList.remove('active');
                sidebarOverlay.classList.remove('active');
            });
        });
    </script>
{% endblock %}

