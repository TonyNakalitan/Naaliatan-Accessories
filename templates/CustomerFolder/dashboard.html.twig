{% extends 'base.html.twig' %}

{% block title %}Customer Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('DashboardFolder/customer_dashboard.css') }}?v={{ random() }}">
{% endblock %}

{% block body %}
<div id="dashboard-app-wrapper" class="min-h-screen">

    <!-- Sidebar Overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <img src="{{ asset('images/NA.png') }}" alt="Naaliatan's Accessories" class="sidebar-logo">
        </div>
        <nav class="sidebar-nav">
            <a href="{{ path('app_customer_dashboard') }}" class="nav-item active">
                <i class="fas fa-chart-line"></i>
                <span>Dashboard</span>
            </a>
            <a href="{{ path('app_customer_characters') }}" class="nav-item">
                <i class="fas fa-user-astronaut"></i>
                <span>Browse Products</span>
            </a>
            <a href="{{ path('app_customer_cart') }}" class="nav-item">
                <i class="fas fa-shopping-cart"></i>
                <span>My Cart</span>
                {% set cartCount = app.user.cart ? app.user.cart.cartItems|length : 0 %}
                {% if cartCount > 0 %}
                    <span class="nav-badge">{{ cartCount }}</span>
                {% endif %}
            </a>
            <a href="{{ path('app_customer_orders') }}" class="nav-item">
                <i class="fas fa-shopping-bag"></i>
                <span>My Orders</span>
            </a>
            <a href="{{ path('app_customer_profile') }}" class="nav-item">
                <i class="fas fa-user-circle"></i>
                <span>My Profile</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="nav-item" onclick="return confirm('Are you sure you want to logout?')">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- App Wrapper -->
    <div id="app" class="relative w-full h-screen glass-container overflow-x-auto flex flex-col">

        <!-- Header -->
        <header class="relative z-50 flex items-center justify-between px-10 py-8">
            <div class="flex items-center gap-3">
                <button class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/80 hover:bg-white border border-gray-200 hover:shadow-md transition-all text-gray-700 hover:text-gray-900" id="sidebarToggle" title="Toggle Sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="text-3xl font-bold tracking-tighter text-gray-800">
                    My Dashboard
                </span>
            </div>

            <div class="hidden md:flex items-center bg-gray-100/50 rounded-full px-5 py-2 w-72 border border-gray-200">
                <i class="fa fa-search text-gray-400 mr-3"></i>
                <input type="text" id="searchInput" placeholder="Search overview..." class="bg-transparent outline-none text-sm w-full">
            </div>

            <div class="flex items-center gap-6">
                <a href="{{ path('app_customer_profile') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors">
                    {% if app.user.profilePicture %}
                        <img src="{{ app.user.profilePicture|image_url('images/profiles') }}" alt="Profile" class="w-10 h-10 rounded-full object-cover border-2 border-white shadow-md">
                    {% else %}
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 text-white font-bold text-sm">
                            {% set displayText = app.user.displayName ?: app.user.username %}
                            {% set words = displayText|split(' ') %}
                            {% if words|length > 1 %}
                                {{ words[0]|slice(0, 1)|upper }}{{ words[1]|slice(0, 1)|upper }}
                            {% else %}
                                {{ displayText|slice(0, 2)|upper }}
                            {% endif %}
                        </div>
                    {% endif %}
                    <div class="flex flex-col items-start">
                        <span class="font-semibold text-gray-800 text-sm">{{ app.user.displayName ?: app.user.username }}</span>
                        <span class="text-xs text-gray-500">Customer</span>
                    </div>
                </a>
            </div>
        </header>

        <!-- Viewport -->
        <main class="relative flex-1 overflow-x-auto">

            <!-- GRID VIEW -->
            <div id="gridView" class="grid-view absolute inset-0 flex flex-col justify-end px-12 transition-all duration-500 pb-8">
                <div id="statsCarousel" class="flex gap-8 items-end h-[500px] mb-6"></div>
                <div class="flex items-center justify-between pt-4 pb-2">
                    <div class="flex gap-6 text-sm font-medium text-gray-500">
                        <span>Total Orders: <span id="footerTotalOrders">{{ totalOrders }}</span></span>
                        <span>Pending: <span id="footerPendingOrders">{{ pendingOrders }}</span></span>
                        <span>Completed: <span id="footerCompletedOrders">{{ completedOrders }}</span></span>
                    </div>
                    <div class="flex gap-4">
                        <button onclick="prevSlide()" id="prevBtn" class="flex items-center gap-2 font-bold text-gray-800 hover:opacity-70 transition-opacity disabled:opacity-30 disabled:cursor-not-allowed">
                            <i class="fa fa-chevron-left text-xs"></i> Prev
                        </button>
                        <button onclick="nextSlide()" id="nextBtn" class="flex items-center gap-2 font-bold text-gray-800 hover:opacity-70 transition-opacity disabled:opacity-30 disabled:cursor-not-allowed">
                            Next <i class="fa fa-chevron-right text-xs"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- HERO VIEW -->
            <div id="heroView" class="hero-view absolute inset-0 z-40 bg-white">
                <div id="heroBg" class="absolute inset-0 w-1/2 rounded-r-[80px] transition-colors duration-700"></div>
                <button onclick="closeHero()" class="absolute top-8 right-10 z-50 flex items-center gap-2 font-bold text-gray-800 hover:scale-105 transition-transform">
                    <i class="fa fa-times text-red-500"></i> Close
                </button>
                <div class="relative z-10 h-full flex items-center px-16">
                    <div class="w-1/2 flex justify-center items-center">
                        <div class="hero-icon-frame">
                            <div id="heroIcon" class="hero-icon-wrapper"></div>
                        </div>
                    </div>
                    <div class="w-1/2 pl-12 pr-8">
                        <div class="hero-content-wrapper">
                            <h2 id="heroTitle" class="hero-title slide-in" style="animation-delay: 0.1s"></h2>
                            <div class="hero-meta-section slide-in" style="animation-delay: 0.2s">
                                <div class="meta-item">
                                    <i id="heroMetaIcon1" class="text-blue-500"></i>
                                    <span class="meta-label" id="heroMetaLabel1"></span>
                                    <span id="heroMetaValue1" class="meta-value"></span>
                                </div>
                                <div class="meta-item">
                                    <i id="heroMetaIcon2" class="text-purple-500"></i>
                                    <span class="meta-label" id="heroMetaLabel2"></span>
                                    <span id="heroMetaValue2" class="meta-value"></span>
                                </div>
                                <div class="meta-item">
                                    <i id="heroMetaIcon3" class="text-green-500"></i>
                                    <span class="meta-label" id="heroMetaLabel3"></span>
                                    <span id="heroMetaValue3" class="meta-value"></span>
                                </div>
                            </div>
                            <div class="hero-description-section slide-in" style="animation-delay: 0.3s">
                                <h3 class="description-title">Details</h3>
                                <div id="heroDescription" class="description-text"></div>
                            </div>
                            <div class="hero-actions slide-in" style="animation-delay: 0.4s" id="heroActions"></div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
    <script>
        const statsData = [
            {
                id: 'orders',
                title: 'My Orders',
                value: {{ totalOrders }},
                badge: 'All Time',
                icon: 'fa-shopping-bag',
                colorCode: '#3b82f6',
                description: 'Total orders you have placed in the store.',
                meta: [
                    { icon: 'fa-shopping-bag', label: 'Total Orders', value: '{{ totalOrders }}' },
                    { icon: 'fa-clock', label: 'Pending', value: '{{ pendingOrders }}' },
                    { icon: 'fa-check-circle', label: 'Completed', value: '{{ completedOrders }}' }
                ],
                actions: [
                    { label: 'View My Orders', url: '{{ path('app_customer_orders') }}', class: 'primary' }
                ]
            },
            {
                id: 'pending',
                title: 'Pending Orders',
                value: {{ pendingOrders }},
                badge: 'Awaiting',
                icon: 'fa-clock',
                colorCode: '#f59e0b',
                description: 'Orders that are currently pending and awaiting processing.',
                meta: [
                    { icon: 'fa-clock', label: 'Pending', value: '{{ pendingOrders }}' },
                    { icon: 'fa-shopping-bag', label: 'Total Orders', value: '{{ totalOrders }}' },
                    { icon: 'fa-calendar', label: 'Last Updated', value: '{{ "now"|date("M j, Y") }}' }
                ],
                actions: [
                    { label: 'View Orders', url: '{{ path('app_customer_orders') }}', class: 'primary' }
                ]
            },
            {
                id: 'completed',
                title: 'Completed',
                value: {{ completedOrders }},
                badge: 'Done',
                icon: 'fa-check-circle',
                colorCode: '#10b981',
                description: 'Orders that have been successfully completed and delivered.',
                meta: [
                    { icon: 'fa-check-circle', label: 'Completed', value: '{{ completedOrders }}' },
                    { icon: 'fa-shopping-bag', label: 'Total Orders', value: '{{ totalOrders }}' },
                    { icon: 'fa-calendar', label: 'Last Updated', value: '{{ "now"|date("M j, Y") }}' }
                ],
                actions: [
                    { label: 'View Orders', url: '{{ path('app_customer_orders') }}', class: 'primary' }
                ]
            },
            {
                id: 'cart',
                title: 'Cart Items',
                value: {{ cartItemCount }},
                badge: 'In Cart',
                icon: 'fa-shopping-cart',
                colorCode: '#8b5cf6',
                description: 'Items currently sitting in your shopping cart.',
                meta: [
                    { icon: 'fa-shopping-cart', label: 'Items in Cart', value: '{{ cartItemCount }}' },
                    { icon: 'fa-box-open', label: 'Browse Products', value: 'Shop Now' },
                    { icon: 'fa-calendar', label: 'Last Updated', value: '{{ "now"|date("M j, Y") }}' }
                ],
                actions: [
                    { label: 'View Cart', url: '{{ path('app_customer_cart') }}', class: 'primary' }
                ]
            },
            {
                id: 'shop',
                title: 'Browse Shop',
                value: '8',
                badge: 'Explore',
                icon: 'fa-store',
                colorCode: '#ec4899',
                description: 'Explore our full catalog of products and characters.',
                meta: [
                    { icon: 'fa-box-open', label: 'Products', value: 'Available' },
                    { icon: 'fa-user-astronaut', label: 'Characters', value: 'Available' },
                    { icon: 'fa-calendar', label: 'Last Updated', value: '{{ "now"|date("M j, Y") }}' }
                ],
                actions: [
                    { label: 'Browse Products', url: '{{ path('app_customer_characters') }}', class: 'primary' }
                ]
            }
        ];

        let currentIndex = 0;
        const visibleCount = 3;

        function adjustColor(color, amount) {
            const num = parseInt(color.replace("#",""), 16);
            const r = Math.min(255, Math.max(0, (num >> 16) + amount));
            const g = Math.min(255, Math.max(0, ((num >> 8) & 0x00FF) + amount));
            const b = Math.min(255, Math.max(0, (num & 0x0000FF) + amount));
            return "#" + ((r << 16) | (g << 8) | b).toString(16).padStart(6, '0');
        }

        function renderCarousel() {
            const container = document.getElementById('statsCarousel');
            container.innerHTML = '';
            const displayed = statsData.slice(currentIndex, currentIndex + visibleCount);
            displayed.forEach((stat) => {
                const colorLight = adjustColor(stat.colorCode, 30);
                const colorDark  = adjustColor(stat.colorCode, -30);
                const card = document.createElement('div');
                card.className = `stat-card relative w-1/3 h-full rounded-[40px] flex flex-col justify-end p-8 cursor-pointer group`;
                card.style.cssText = `background: linear-gradient(180deg, ${colorLight} 0%, ${colorDark} 100%);`;
                card.innerHTML = `
                    <div class="stat-icon-wrapper"><i class="fas ${stat.icon}"></i></div>
                    <div class="relative z-10 pt-8">
                        <h3 class="text-4xl font-bold text-white mb-1">${stat.title}</h3>
                        <p class="text-white/70 text-sm mb-2">${stat.badge}</p>
                        <p class="text-6xl font-extrabold text-white mb-4">${stat.value}</p>
                        <button class="bg-white/20 backdrop-blur-md text-white text-xs font-bold px-4 py-2 rounded-lg uppercase tracking-wider transition-all">View Details ></button>
                    </div>
                `;
                card.onclick = () => openHero(stat);
                container.appendChild(card);
            });
            updateNavigationButtons();
        }

        function updateNavigationButtons() {
            const prevBtn = document.getElementById('prevBtn');
            const nextBtn = document.getElementById('nextBtn');
            if (prevBtn && nextBtn) {
                prevBtn.disabled = currentIndex === 0;
                nextBtn.disabled = currentIndex + visibleCount >= statsData.length;
            }
        }

        function nextSlide() {
            if (currentIndex + visibleCount < statsData.length) { currentIndex++; renderCarousel(); }
        }

        function prevSlide() {
            if (currentIndex > 0) { currentIndex--; renderCarousel(); }
        }

        function openHero(stat) {
            const app      = document.getElementById('app');
            const heroBg   = document.getElementById('heroBg');
            const heroIcon = document.getElementById('heroIcon');
            const colorLight = adjustColor(stat.colorCode, 30);
            const colorDark  = adjustColor(stat.colorCode, -30);
            heroBg.style.background = `linear-gradient(180deg, ${colorLight} 0%, ${colorDark} 100%)`;
            heroIcon.innerHTML = `<i class="fas ${stat.icon}"></i>`;
            document.getElementById('heroTitle').innerText       = stat.title;
            document.getElementById('heroDescription').innerText = stat.description;
            stat.meta.forEach((meta, i) => {
                document.getElementById(`heroMetaIcon${i+1}`).className  = `fas ${meta.icon} text-blue-500`;
                document.getElementById(`heroMetaLabel${i+1}`).innerText = meta.label + ':';
                document.getElementById(`heroMetaValue${i+1}`).innerText = meta.value;
            });
            const actionsContainer = document.getElementById('heroActions');
            actionsContainer.innerHTML = '';
            stat.actions.forEach(action => {
                const btn = document.createElement('a');
                btn.href      = action.url;
                btn.className = `action-btn action-btn-${action.class}`;
                btn.innerHTML = `<i class="fa fa-arrow-right"></i><span>${action.label}</span>`;
                actionsContainer.appendChild(btn);
            });
            app.classList.add('hero-active');
            document.querySelectorAll('.slide-in').forEach(el => {
                el.style.animation = 'none';
                el.offsetHeight;
                el.style.animation = null;
            });
        }

        function closeHero() {
            document.getElementById('app').classList.remove('hero-active');
        }

        document.addEventListener('DOMContentLoaded', function () {
            renderCarousel();
            const sidebarToggle  = document.getElementById('sidebarToggle');
            const sidebar        = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');
            if (sidebarToggle && sidebar && sidebarOverlay) {
                sidebarToggle.addEventListener('click', () => {
                    sidebar.classList.toggle('active');
                    sidebarOverlay.classList.toggle('active');
                });
                sidebarOverlay.addEventListener('click', () => {
                    sidebar.classList.remove('active');
                    sidebarOverlay.classList.remove('active');
                });
            }
        });
    </script>
{% endblock %}

