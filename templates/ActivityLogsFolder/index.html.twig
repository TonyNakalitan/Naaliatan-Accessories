{% extends 'base.html.twig' %}

{% block title %}Activity Logs{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('ActivityLogsFolder/index.css') }}?v={{ random() }}">
{% endblock %}

{% block body %}
<div id="activity-app-wrapper" class="min-h-screen">

    <!-- App Wrapper -->
    <div id="app" class="relative w-full h-screen glass-container overflow-x-auto flex flex-col">

        <!-- Header -->
        <header class="relative z-50 flex items-center justify-between px-10 py-8">
            <div class="flex items-center gap-3">
                <button class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/80 hover:bg-white border border-gray-200 hover:shadow-md transition-all text-gray-700 hover:text-gray-900" id="sidebarToggle" title="Toggle Sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="text-3xl font-bold tracking-tighter text-gray-800">
                    Activity Logs
                </span>
            </div>

            <!-- Search bar -->
            <div class="hidden md:flex items-center bg-gray-100/50 rounded-full px-5 py-2 w-72 border border-gray-200">
                <i class="fa fa-search text-gray-400 mr-3"></i>
                <input type="text" id="searchInput" placeholder="Search activities..." class="bg-transparent outline-none text-sm w-full">
            </div>

            <div class="flex items-center gap-6">
                <!-- Action Filter Dropdown -->
                <div class="relative">
                    <select id="actionFilter" class="bg-white border border-gray-200 rounded-lg px-4 py-2 pr-10 text-sm font-medium text-gray-700 hover:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all cursor-pointer appearance-none">
                        <option value="all">All Actions</option>
                        <option value="CREATE">Create</option>
                        <option value="UPDATE">Update</option>
                        <option value="DELETE">Delete</option>
                        <option value="LOGIN">Login</option>
                        <option value="LOGOUT">Logout</option>
                        <option value="RESTOCK">Restock</option>
                    </select>
                    <i class="fas fa-chevron-down absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none text-xs"></i>
                </div>
                <a href="{{ path('app_admin_profile_edit') }}" class="flex items-center gap-3 px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors">
                    {% if app.user.profilePicture %}
                        <img src="{{ app.user.profilePicture|image_url('images/profiles') }}" alt="Profile" class="w-10 h-10 rounded-full object-cover border-2 border-white shadow-md">
                    {% else %}
                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 text-white font-bold text-sm">
                            {% set displayText = app.user.displayName ?: app.user.username %}
                            {% set words = displayText|split(' ') %}
                            {% if words|length > 1 %}
                                {{ words[0]|slice(0, 1)|upper }}{{ words[1]|slice(0, 1)|upper }}
                            {% else %}
                                {{ displayText|slice(0, 2)|upper }}
                            {% endif %}
                        </div>
                    {% endif %}
                    <div class="flex flex-col items-start">
                        <span class="font-semibold text-gray-800 text-sm">{{ app.user.displayName ?: app.user.username }}</span>
                        <span class="text-xs text-gray-500">Admin</span>
                    </div>
                </a>
            </div>
        </header>

        <!-- Viewport -->
        <main class="relative flex-1 overflow-x-auto">

            <!-- TABLE VIEW -->
            <div id="gridView" class="grid-view absolute inset-0 flex flex-col px-12 py-8 transition-all duration-500">
                <div class="flex-1 overflow-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b-2 border-gray-200">
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Action</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">User</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Role</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Description</th>
                                <th class="text-left py-4 px-4 font-semibold text-gray-700">Timestamp</th>
                            </tr>
                        </thead>
                        <tbody id="activityTableBody">
                            <!-- Rows injected by JS -->
                        </tbody>
                    </table>
                </div>

                <!-- Footer Stats -->
                <div class="flex items-center gap-6 pt-4 pb-2 text-sm font-medium text-gray-500">
                    <span>Total Logs: <span id="totalCount">{{ logs|length }}</span></span>
                    <span>Today: <span class="text-blue-600 font-bold">{{ todayCount|default(0) }}</span></span>
                    <span>This Week: <span class="text-purple-600 font-bold">{{ weekCount|default(0) }}</span></span>
                </div>
            </div>

            <!-- DETAIL / HERO VIEW -->
            <div id="heroView" class="hero-view absolute inset-0 z-40 bg-white">
                <div id="heroBg" class="absolute inset-0 w-1/2 rounded-r-[80px] transition-colors duration-700"></div>

                <button onclick="closeHero()" class="absolute top-8 right-10 z-50 flex items-center gap-2 font-bold text-gray-800 hover:scale-105 transition-transform">
                    <i class="fa fa-times text-red-500"></i> Close
                </button>

                <div class="relative z-10 h-full flex items-center px-16">
                    <!-- Left Side: Icon Frame -->
                    <div class="w-1/2 flex justify-center items-center">
                        <div class="hero-image-frame">
                            <div id="heroIcon" class="hero-icon"></div>
                        </div>
                    </div>

                    <!-- Right Side: Content -->
                    <div class="w-1/2 pl-12 pr-8">
                        <div class="hero-content-wrapper">
                            <h2 id="heroAction" class="hero-title slide-in" style="animation-delay: 0.1s"></h2>

                            <div class="hero-meta-section slide-in" style="animation-delay: 0.2s">
                                <div class="meta-item">
                                    <i class="fa fa-user text-blue-500"></i>
                                    <span class="meta-label">User:</span>
                                    <span id="heroUsername" class="meta-value"></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fa fa-clock text-purple-500"></i>
                                    <span class="meta-label">Timestamp:</span>
                                    <span id="heroTimestamp" class="meta-value"></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fa fa-tag text-red-500"></i>
                                    <span class="meta-label">Action Type:</span>
                                    <span id="heroActionType" class="action-type-badge"></span>
                                </div>
                                <div class="meta-item">
                                    <i class="fa fa-shield-alt text-green-500"></i>
                                    <span class="meta-label">Role:</span>
                                    <span id="heroRole" class="role-badge"></span>
                                </div>
                            </div>

                            <div class="hero-description-section slide-in" style="animation-delay: 0.3s">
                                <h3 class="description-title">Activity Details</h3>
                                <div class="description-text">
                                    <div class="info-row">
                                        <span class="info-label">Log ID:</span>
                                        <span id="heroId" class="info-value"></span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">Description:</span>
                                        <span id="heroDescription" class="info-value"></span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">Date:</span>
                                        <span id="heroDate" class="info-value"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('JSFolder/zoom-disable.js') }}"></script>
    <script>
        const allLogsData = [
            {% for log in logs %}
            {
                id: {{ log.id }},
                username: {{ log.username|default('Unknown')|json_encode|raw }},
                action: {{ log.action|default('UNKNOWN')|json_encode|raw }},
                targetData: {{ log.targetData|default('No details provided')|json_encode|raw }},
                role: {{ log.role|default('ROLE_USER')|json_encode|raw }},
                createdAt: {{ log.createdAt ? log.createdAt|date('Y-m-d H:i:s')|json_encode|raw : 'null' }},
                profilePicture: {{ (log.user and log.user.profilePicture) ? log.user.profilePicture|json_encode|raw : 'null' }}
            }{% if not loop.last %},{% endif %}
            {% endfor %}
        ];

        const baseUrl    = '{{ app.request.schemeAndHttpHost }}';
        const imagePath  = '{{ asset('images/profiles/') }}';

        let activities = allLogsData.map(log => ({
            ...log,
            action:    (log.action || 'UNKNOWN').toUpperCase(),
            colorCode: getActionColor(log.action),
            avatar:    log.profilePicture ? imagePath + log.profilePicture : null
        }));

        let filteredActivities = [...activities];

        /* ---- helpers ---- */
        function getActionColor(action) {
            switch ((action || '').toUpperCase()) {
                case 'CREATE':  return '#10b981';
                case 'UPDATE':  return '#f59e0b';
                case 'DELETE':  return '#ef4444';
                case 'LOGIN':   return '#3b82f6';
                case 'LOGOUT':  return '#8b5cf6';
                case 'RESTOCK': return '#14b8a6';
                default:        return '#64748b';
            }
        }

        function getActionIcon(action) {
            switch ((action || '').toUpperCase()) {
                case 'CREATE':  return 'fa-plus-circle';
                case 'UPDATE':  return 'fa-edit';
                case 'DELETE':  return 'fa-trash-alt';
                case 'LOGIN':   return 'fa-sign-in-alt';
                case 'LOGOUT':  return 'fa-sign-out-alt';
                case 'RESTOCK': return 'fa-boxes';
                default:        return 'fa-info-circle';
            }
        }

        function getRoleDisplay(role) {
            const r = (role || '').replace(/[\[\]"]/g, '').trim();
            if (r.includes('ROLE_ADMIN')) return 'Administrator';
            if (r.includes('ROLE_STAFF')) return 'Staff';
            return 'User';
        }

        function getRoleColor(role) {
            const r = (role || '');
            if (r.includes('ADMIN')) return '#ef4444';
            if (r.includes('STAFF')) return '#8b5cf6';
            return '#3b82f6';
        }

        function adjustColor(color, amount) {
            const num = parseInt(color.replace('#', ''), 16);
            const r = Math.min(255, Math.max(0, (num >> 16) + amount));
            const g = Math.min(255, Math.max(0, ((num >> 8) & 0x00FF) + amount));
            const b = Math.min(255, Math.max(0, (num & 0x0000FF) + amount));
            return '#' + ((r << 16) | (g << 8) | b).toString(16).padStart(6, '0');
        }

        function formatDate(dateStr) {
            if (!dateStr) return 'N/A';
            return new Date(dateStr).toLocaleDateString('en-US', {
                month: 'short', day: 'numeric', year: 'numeric',
                hour: '2-digit', minute: '2-digit'
            });
        }

        /* ---- table render ---- */
        function renderTable() {
            const tbody = document.getElementById('activityTableBody');
            tbody.innerHTML = '';

            if (!filteredActivities.length) {
                tbody.innerHTML = '<tr><td colspan="5" class="text-center text-gray-500 text-xl py-20">No activity logs found.</td></tr>';
                return;
            }

            filteredActivities.forEach(log => {
                const color    = log.colorCode;
                const icon     = getActionIcon(log.action);
                const initials = (log.username || '?').charAt(0).toUpperCase();
                const row      = document.createElement('tr');

                /* truncate long descriptions in the table */
                const shortDesc = (log.targetData || '').length > 60
                    ? (log.targetData || '').substring(0, 60) + '…'
                    : (log.targetData || 'No details');

                row.innerHTML = `
                    <td>
                        <div class="log-action-info">
                            <div class="log-action-icon" style="background:linear-gradient(135deg,${adjustColor(color,20)},${color});">
                                <i class="fas ${icon}"></i>
                            </div>
                            <span class="table-action-badge" style="background:${color};">${log.action}</span>
                        </div>
                    </td>
                    <td>
                        <div class="log-user-info">
                            ${log.avatar
                                ? `<img src="${log.avatar}" alt="${log.username}" class="log-user-avatar"
                                       onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
                                   <div class="log-user-fallback" style="display:none;">${initials}</div>`
                                : `<div class="log-user-fallback">${initials}</div>`
                            }
                            <span class="log-username">${log.username}</span>
                        </div>
                    </td>
                    <td>
                        <span class="table-role-badge" style="background:${getRoleColor(log.role)};">
                            ${getRoleDisplay(log.role)}
                        </span>
                    </td>
                    <td class="text-gray-600 text-sm">${shortDesc}</td>
                    <td class="text-gray-500 text-sm whitespace-nowrap">${formatDate(log.createdAt)}</td>
                `;
                row.style.cursor = 'pointer';
                row.addEventListener('click', () => openHero(log));
                tbody.appendChild(row);
            });
        }

        /* ---- filters ---- */
        function applyFilters() {
            const q      = (document.getElementById('searchInput')?.value || '').toLowerCase();
            const action = document.getElementById('actionFilter')?.value || 'all';

            filteredActivities = activities.filter(log => {
                const matchQ = !q ||
                    log.username.toLowerCase().includes(q) ||
                    log.action.toLowerCase().includes(q) ||
                    (log.targetData || '').toLowerCase().includes(q) ||
                    getRoleDisplay(log.role).toLowerCase().includes(q);
                const matchAction = action === 'all' || log.action === action.toUpperCase();
                return matchQ && matchAction;
            });

            document.getElementById('totalCount').textContent = filteredActivities.length;
            renderTable();
        }

        document.getElementById('searchInput')?.addEventListener('input', applyFilters);
        document.getElementById('actionFilter')?.addEventListener('change', applyFilters);

        /* ---- hero ---- */
        function openHero(log) {
            const app    = document.getElementById('app');
            const heroBg = document.getElementById('heroBg');
            const color  = log.colorCode;

            heroBg.style.background = `linear-gradient(180deg,${adjustColor(color,30)} 0%,${adjustColor(color,-30)} 100%)`;

            const heroIcon = document.getElementById('heroIcon');
            heroIcon.innerHTML = `<i class="fas ${getActionIcon(log.action)}"></i>`;
            heroIcon.style.background = `linear-gradient(135deg,${adjustColor(color,20)},${adjustColor(color,-20)})`;

            document.getElementById('heroAction').innerText    = log.action + ' Action';
            document.getElementById('heroUsername').innerText  = log.username;
            document.getElementById('heroTimestamp').innerText = formatDate(log.createdAt);
            document.getElementById('heroId').innerText        = '#' + log.id;
            document.getElementById('heroDescription').innerText = log.targetData || 'No details provided';
            document.getElementById('heroDate').innerText      = log.createdAt
                ? new Date(log.createdAt).toLocaleDateString('en-US', {
                      year: 'numeric', month: 'long', day: 'numeric',
                      hour: '2-digit', minute: '2-digit', second: '2-digit'
                  })
                : 'N/A';

            const heroActionType = document.getElementById('heroActionType');
            heroActionType.innerText            = log.action;
            heroActionType.style.backgroundColor = color;

            const heroRole = document.getElementById('heroRole');
            heroRole.innerText            = getRoleDisplay(log.role);
            heroRole.style.backgroundColor = getRoleColor(log.role);

            app.classList.add('hero-active');

            document.querySelectorAll('.slide-in').forEach(el => {
                el.style.animation = 'none';
                el.offsetHeight;
                el.style.animation = null;
            });
        }

        function closeHero() {
            document.getElementById('app').classList.remove('hero-active');
        }

        /* ---- init ---- */
        document.addEventListener('DOMContentLoaded', function() {
            renderTable();

            const sidebarToggle  = document.getElementById('sidebarToggle');
            const sidebar        = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');

            sidebarToggle?.addEventListener('click', () => {
                sidebar?.classList.toggle('active');
                sidebarOverlay?.classList.toggle('active');
            });
            sidebarOverlay?.addEventListener('click', () => {
                sidebar?.classList.remove('active');
                sidebarOverlay?.classList.remove('active');
            });
        });
    </script>
{% endblock %}
